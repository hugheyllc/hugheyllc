---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getCollection, render } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: any;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, seo_title, seo_description, date, author, excerpt, tags } = entry.data;
const siteUrl = 'https://hugheyllc.com';

// Read image directly from markdown frontmatter (Astro 6 strips 'image' field via schema)
let coverImage: string | undefined;
try {
  const filePath = path.join(process.cwd(), (entry as any).filePath);
  const raw = fs.readFileSync(filePath, 'utf8');
  const match = raw.match(/^image:\s*"([^"]+)"/m);
  if (match) coverImage = match[1];
} catch (e) { /* fallback gracefully */ }

const ogImage = coverImage ? `${siteUrl}${coverImage}` : `${siteUrl}/images/og-default.png`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": seo_title || title,
  "description": seo_description || excerpt,
  "datePublished": new Date(date).toISOString(),
  "dateModified": new Date(date).toISOString(),
  "author": {
    "@type": "Person",
    "name": "Joe Hughey",
    "url": "https://hugheyllc.com/about",
    "jobTitle": "Law Firm Marketing Consultant",
    "worksFor": { "@type": "Organization", "name": "Hughey LLC", "url": "https://hugheyllc.com" }
  },
  "publisher": {
    "@type": "Organization",
    "name": "Hughey LLC",
    "url": "https://hugheyllc.com",
    "logo": { "@type": "ImageObject", "url": "https://hugheyllc.com/images/logo-icon.png" }
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": `https://hugheyllc.com/blog/${entry.id}/` },
  ...(tags && tags.length > 0 ? { "keywords": tags.join(", ") } : {}),
  ...(coverImage ? { "image": { "@type": "ImageObject", "url": `${siteUrl}${coverImage}`, "width": 1536, "height": 1024 } } : {})
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://hugheyllc.com" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://hugheyllc.com/blog" },
    { "@type": "ListItem", "position": 3, "name": title, "item": `https://hugheyllc.com/blog/${entry.id}/` }
  ]
};
---

<BaseLayout
  title={seo_title || title}
  description={seo_description || excerpt}
  canonical={`https://hugheyllc.com/blog/${entry.id}/`}
  ogImage={ogImage}
  schema={[articleSchema, breadcrumbSchema]}
>
  <article style="background: var(--ink); color: var(--white);">
    <PageHero heading={title} subheading={excerpt} />

    {coverImage && (
      <div style="padding: 0; max-height: 420px; overflow: hidden; border-bottom: 1px solid rgba(200,151,58,0.12);">
        <img
          src={coverImage}
          alt={title}
          style="width: 100%; height: 420px; object-fit: cover; object-position: center; display: block; opacity: 0.85;"
          loading="eager"
        />
      </div>
    )}

    <!-- Meta bar -->
    <div style="border-bottom: 1px solid rgba(200, 151, 58, 0.12); padding: 18px 0;">
      <div class="w" style="display: flex; align-items: center; gap: 20px; flex-wrap: wrap;">
        <span style="font-size: 13px; color: rgba(255,255,255,0.45);">
          {new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </span>
        <span style="font-size: 13px; color: rgba(255,255,255,0.45);">By {author}</span>
        {tags && tags.length > 0 && (
          <div style="display: flex; gap: 8px; flex-wrap: wrap;">
            {tags.slice(0, 4).map((tag: string) => (
              <span style="font-size: 11px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; color: rgba(200,151,58,0.8); background: rgba(200,151,58,0.08); padding: 3px 10px; border-radius: 20px;">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </div>

    <!-- Body -->
    <div style="padding: 72px 0 80px;">
      <div class="w">
        <div class="prose">
          <Content />
        </div>
      </div>
    </div>

    <!-- Author -->
    <div style="background: rgba(200, 151, 58, 0.05); border-top: 1px solid rgba(200, 151, 58, 0.15); border-bottom: 1px solid rgba(200, 151, 58, 0.15); padding: 48px 0;">
      <div class="w">
        <div style="max-width: 760px;">
          <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 10px; color: var(--glt); text-transform: uppercase; letter-spacing: 0.08em; font-family: var(--man);">About the Author</h3>
          <p style="font-size: 15px; color: rgba(255, 255, 255, 0.65); line-height: 1.7;">
            {author} is the founder of Hughey LLC, a law firm marketing strategy consulting firm. With 20+ years of legal marketing experience, Joe works exclusively with law firms to build marketing operations that generate retained clients.
          </p>
        </div>
      </div>
    </div>

    <!-- FAQ transform script: converts markdown ## FAQs section into styled accordion -->
    <script>
      (function () {
        const prose = document.querySelector('.prose');
        if (!prose) return;
        // Find the ## FAQs heading
        const headings = prose.querySelectorAll('h2');
        let faqHeading = null;
        headings.forEach(h => { if (h.textContent.trim().toLowerCase().startsWith('faq')) faqHeading = h; });
        if (!faqHeading) return;

        // Collect all sibling p elements after the FAQ heading
        const pairs = [];
        let el = faqHeading.nextElementSibling;
        while (el && el.tagName === 'P') {
          const strong = el.querySelector('strong');
          // A question paragraph has only a <strong> (the bold question)
          if (strong && el.textContent.trim() === strong.textContent.trim()) {
            const answerEl = el.nextElementSibling;
            if (answerEl && answerEl.tagName === 'P') {
              pairs.push({ q: strong.textContent.trim(), a: answerEl.textContent.trim() });
              el = answerEl.nextElementSibling;
            } else { el = el.nextElementSibling; }
          } else { el = el.nextElementSibling; }
        }
        if (!pairs.length) return;

        // Build the FAQ section replacing the heading + pairs
        const section = document.createElement('div');
        section.className = 'inline-faq';
        section.innerHTML = '<h2 class="inline-faq-title">Frequently Asked Questions</h2><div class="inline-faq-list">' +
          pairs.map(p => `<details class="inline-faq-item"><summary class="inline-faq-q">${p.q}</summary><div class="inline-faq-a">${p.a}</div></details>`).join('') +
          '</div>';

        // Remove original elements
        faqHeading.replaceWith(section);
        // Remove the pairs from DOM
        let rem = section.nextElementSibling;
        const toRemove = [];
        for (let i = 0; i < pairs.length * 2; i++) {
          if (rem && rem.tagName === 'P') { toRemove.push(rem); rem = rem.nextElementSibling; }
        }
        toRemove.forEach(n => n.remove());
      })();
    </script>

    <!-- Back -->
    <div style="padding: 48px 0;">
      <div class="w">
        <a href="/blog/" style="display: inline-flex; align-items: center; gap: 8px; color: var(--glt); text-decoration: none; font-weight: 600; font-family: var(--man); font-size: 13px; letter-spacing: 0.06em; text-transform: uppercase; transition: color 0.2s;">
          ← Back to Blog
        </a>
      </div>
    </div>
  </article>

  <style>
    /* ── PROSE STYLES ──────────────────────────────────────── */
    .prose {
      max-width: 760px;
      font-size: 17px;
      line-height: 1.85;
      color: rgba(255, 255, 255, 0.82);
    }

    .prose :global(h1),
    .prose :global(h2) {
      font-size: clamp(24px, 3vw, 34px);
      font-weight: 800;
      margin-top: 56px;
      margin-bottom: 20px;
      color: var(--white);
      line-height: 1.2;
      letter-spacing: -0.02em;
    }

    .prose :global(h3) {
      font-size: clamp(20px, 2.5vw, 26px);
      font-weight: 700;
      margin-top: 44px;
      margin-bottom: 16px;
      color: var(--white);
      line-height: 1.3;
    }

    .prose :global(h4) {
      font-size: 18px;
      font-weight: 700;
      margin-top: 36px;
      margin-bottom: 12px;
      color: rgba(255, 255, 255, 0.9);
    }

    .prose :global(p) {
      margin-bottom: 24px;
    }

    .prose :global(ul),
    .prose :global(ol) {
      margin-bottom: 24px;
      padding-left: 28px;
    }

    .prose :global(li) {
      margin-bottom: 10px;
      color: rgba(255, 255, 255, 0.78);
    }

    .prose :global(a) {
      color: var(--glt);
      text-decoration: underline;
      text-underline-offset: 3px;
      transition: color 0.2s;
    }

    .prose :global(a:hover) {
      color: var(--white);
    }

    .prose :global(strong) {
      font-weight: 700;
      color: var(--white);
    }

    .prose :global(em) {
      font-style: italic;
      color: rgba(200, 151, 58, 0.9);
    }

    .prose :global(blockquote) {
      border-left: 3px solid var(--glt);
      padding: 16px 24px;
      margin: 32px 0;
      background: rgba(200, 151, 58, 0.06);
      border-radius: 0 4px 4px 0;
      color: rgba(255, 255, 255, 0.75);
      font-style: italic;
      font-size: 18px;
      line-height: 1.7;
    }

    .prose :global(hr) {
      border: none;
      border-top: 1px solid rgba(200, 151, 58, 0.2);
      margin: 48px 0;
    }

    .prose :global(code) {
      background: rgba(200, 151, 58, 0.1);
      color: rgba(200, 151, 58, 0.95);
      padding: 2px 7px;
      border-radius: 3px;
      font-size: 14px;
      font-family: 'Courier New', monospace;
    }

    .prose :global(pre) {
      background: rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(200, 151, 58, 0.15);
      padding: 24px;
      border-radius: 4px;
      overflow-x: auto;
      margin-bottom: 28px;
      font-size: 14px;
    }

    .prose :global(table) {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 28px;
      font-size: 15px;
    }

    .prose :global(th) {
      text-align: left;
      padding: 10px 16px;
      background: rgba(200, 151, 58, 0.1);
      color: var(--glt);
      font-weight: 700;
      border-bottom: 1px solid rgba(200, 151, 58, 0.2);
    }

    .prose :global(td) {
      padding: 10px 16px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      color: rgba(255, 255, 255, 0.75);
    }

    @media (max-width: 640px) {
      .prose {
        font-size: 16px;
      }
    }

    /* ── INLINE FAQ (matches FaqSection component) ──────── */
    .inline-faq {
      margin-top: 56px;
      padding-top: 0;
    }
    .inline-faq-title {
      font-size: clamp(24px, 3vw, 34px);
      font-weight: 800;
      color: var(--white);
      margin-bottom: 32px;
      line-height: 1.2;
      letter-spacing: -0.02em;
    }
    .inline-faq-list {
      max-width: 860px;
    }
    .inline-faq-item {
      border-bottom: 1px solid rgba(200, 151, 58, 0.12);
    }
    .inline-faq-item:first-of-type {
      border-top: 1px solid rgba(200, 151, 58, 0.12);
    }
    .inline-faq-q {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 22px 0;
      font-size: 17px;
      font-weight: 600;
      color: var(--white);
      cursor: pointer;
      list-style: none;
      gap: 16px;
      line-height: 1.4;
    }
    .inline-faq-q::-webkit-details-marker { display: none; }
    .inline-faq-q::after {
      content: '+';
      font-size: 22px;
      font-weight: 300;
      color: var(--gold);
      flex-shrink: 0;
      transition: transform 0.2s;
    }
    details[open] .inline-faq-q::after { transform: rotate(45deg); }
    .inline-faq-a {
      padding: 0 0 22px;
      font-size: 15px;
      line-height: 1.75;
      color: rgba(255, 255, 255, 0.7);
      max-width: 780px;
    }
  </style>
</BaseLayout>
