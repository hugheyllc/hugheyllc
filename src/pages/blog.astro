---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allBlogPosts = await getCollection('blog');

const posts = allBlogPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const featured = posts[0];
const rest = posts.slice(1);

function readTime(excerpt: string = '') {
  const words = excerpt.split(/\s+/).length;
  return Math.max(3, Math.ceil(words / 200));
}

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Hughey LLC — Law Firm Marketing Blog",
  "description": "Insights, strategies, and best practices for law firm marketing.",
  "url": "https://hugheyllc.com/blog/",
  "author": { "@type": "Person", "name": "Joe Hughey", "url": "https://hugheyllc.com/about/" },
  "publisher": { "@type": "Organization", "name": "Hughey LLC", "url": "https://hugheyllc.com" }
};

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": posts.slice(0, 10).map((post, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `https://hugheyllc.com/blog/${post.id}/`
  }))
};
---

<BaseLayout
  title="Law Firm Marketing Blog | Hughey LLC"
  description="Insights, strategies, and best practices for law firm marketing. From SEO to client intake to marketing analytics."
  canonical="https://hugheyllc.com/blog/"
  schema={[blogSchema, itemListSchema]}
>
  <div>
    <PageHero
      eyebrow="Insights & Strategy"
      heading="Law Firm Marketing<br /><em>Blog</em>"
      subheading="Strategies, frameworks, and data for law firm marketing — from analytics to client intake to agency management."
    />

    <!-- Light content section -->
    <div style="background: var(--page); padding: 72px 0 96px;">
      <div class="w">

        <!-- Featured post -->
        {featured && (
          <a href={`/blog/${featured.id}/`} class="featured-card rx">
            <div class="feat-meta">
              <span class="feat-eyebrow">Latest</span>
              <time class="feat-date">
                {new Date(featured.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <span class="feat-read">{readTime(featured.data.excerpt)} min read</span>
            </div>
            <h2 class="feat-title">{featured.data.title}</h2>
            <p class="feat-excerpt">{featured.data.excerpt}</p>
            <div class="feat-tags">
              {(featured.data.tags ?? []).slice(0, 4).map((tag: string) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
            <span class="feat-cta">Read article →</span>
          </a>
        )}

        <!-- Section label -->
        <div class="section-rule rx">
          <span class="section-label">All Articles</span>
        </div>

        <!-- Grid -->
        <div class="posts-grid">
          {rest.map((post) => (
            <article class="post-card rx card-hover">
              <div class="post-thumb">
                <img src={`/images/blog/${post.id}.jpg`} alt={post.data.title} loading="lazy" decoding="async" width="680" height="383" />
              </div>
              <div class="post-meta">
                <time class="post-date">
                  {new Date(post.data.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                </time>
                <span class="post-read">{readTime(post.data.excerpt)} min</span>
              </div>
              <h3 class="post-title">
                <a href={`/blog/${post.id}/`}>{post.data.title}</a>
              </h3>
              <p class="post-excerpt">{post.data.excerpt}</p>
              <div class="post-footer">
                {(post.data.tags ?? []).slice(0, 2).map((tag: string) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            </article>
          ))}
        </div>

        {posts.length === 0 && (
          <p style="text-align:center; color: var(--dim); padding: 80px 0;">No posts yet.</p>
        )}
      </div>
    </div>
  </div>

  <Footer />

  <style>
    /* ── Featured card ───────────────────────────── */
    .featured-card {
      display: block;
      background: var(--ink);
      color: var(--white);
      border-radius: 6px;
      padding: 48px 56px;
      text-decoration: none;
      margin-bottom: 64px;
      position: relative;
      overflow: hidden;
      transition: transform 0.25s cubic-bezier(0.16,1,0.3,1), box-shadow 0.25s;
      box-shadow: 0 4px 32px rgba(0,0,0,0.18);
    }

    .featured-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 80% 50%, rgba(200,151,58,0.12) 0%, transparent 60%);
      pointer-events: none;
    }

    .featured-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 48px rgba(0,0,0,0.28);
    }

    .feat-meta {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 20px;
    }

    .feat-eyebrow {
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      background: rgba(200,151,58,0.12);
      padding: 4px 10px;
      border-radius: 2px;
    }

    .feat-date, .feat-read {
      font-size: 12px;
      color: rgba(255,255,255,0.45);
      letter-spacing: 0.04em;
    }

    .feat-title {
      font-size: clamp(26px, 3.5vw, 42px);
      font-weight: 800;
      line-height: 1.15;
      letter-spacing: -0.02em;
      color: var(--white);
      margin-bottom: 16px;
      max-width: 820px;
    }

    .feat-excerpt {
      font-size: 16px;
      line-height: 1.7;
      color: rgba(255,255,255,0.65);
      max-width: 700px;
      margin-bottom: 24px;
    }

    .feat-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 28px;
    }

    .feat-cta {
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--gold);
      border-bottom: 1px solid rgba(200,151,58,0.4);
      padding-bottom: 2px;
      transition: color 0.2s, border-color 0.2s;
    }

    .featured-card:hover .feat-cta {
      color: var(--glt);
      border-color: var(--glt);
    }

    /* ── Section rule ────────────────────────────── */
    .section-rule {
      display: flex;
      align-items: center;
      gap: 20px;
      margin-bottom: 48px;
    }

    .section-rule::before, .section-rule::after {
      content: '';
      flex: 1;
      height: 1px;
      background: var(--bdr);
    }

    .section-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--dim);
      white-space: nowrap;
    }

    /* ── Posts grid ──────────────────────────────── */
    .posts-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(340px, 100%), 1fr));
      gap: 32px;
    }

    .post-thumb {
      aspect-ratio: 16 / 9;
      overflow: hidden;
      border-radius: 2px;
      margin-bottom: 16px;
    }

    .post-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      transition: transform 0.3s;
    }

    .post-card:hover .post-thumb img {
      transform: scale(1.03);
    }

    .post-card {
      background: var(--white);
      border: 1px solid var(--bdr);
      border-radius: 4px;
      padding: 28px 32px;
      display: flex;
      flex-direction: column;
      transition: transform 0.25s cubic-bezier(0.16,1,0.3,1), box-shadow 0.25s, border-color 0.25s;
    }

    .post-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 32px rgba(0,0,0,0.08);
      border-color: var(--gold);
    }

    .post-meta {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
    }

    .post-date {
      font-size: 11px;
      color: rgba(200,151,58,0.8);
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .post-read {
      font-size: 11px;
      color: var(--dim);
    }

    .post-title {
      font-size: 19px;
      font-weight: 700;
      line-height: 1.3;
      color: var(--ink);
      margin-bottom: 10px;
    }

    .post-title a {
      color: var(--ink);
      text-decoration: none;
      transition: color 0.2s;
    }

    .post-title a:hover {
      color: var(--gold);
    }

    .post-excerpt {
      font-size: 14px;
      color: var(--sub);
      line-height: 1.65;
      flex-grow: 1;
      margin-bottom: 20px;
    }

    .post-footer {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: auto;
    }

    /* ── Shared tag ──────────────────────────────── */
    .tag {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--gdim);
      background: rgba(200,151,58,0.08);
      padding: 3px 9px;
      border-radius: 2px;
    }

    @media (max-width: 640px) {
      .featured-card {
        padding: 32px 24px;
      }
    }
  </style>
</BaseLayout>
