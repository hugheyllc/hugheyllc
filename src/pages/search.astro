---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Search | Hughey LLC"
  description="Search the Hughey LLC site — blog articles, insights, services, and more."
  canonical="https://hugheyllc.com/search"
>
  <div>
    <PageHero
      eyebrow="Search"
      heading="Find What<br /><em>You Need</em>"
      subheading="Search across all articles, insights, and services."
    />

    <div style="background: var(--page); padding: 64px 0 96px; min-height: 60vh;">
      <div class="w">
        <div id="search-container"></div>
      </div>
    </div>
  </div>

  <Footer />

  <!-- Pagefind UI -->
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script src="/pagefind/pagefind-ui.js" is:inline></script>

  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      new PagefindUI({
        element: '#search-container',
        showImages: false,
        showSubResults: true,
        excerptLength: 20,
        resetStyles: false,
      });

      // Auto-focus and pre-fill from URL param
      const q = new URLSearchParams(window.location.search).get('q');
      if (q) {
        const input = document.querySelector('.pagefind-ui__search-input');
        if (input) {
          input.value = q;
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }
      }
    });
  </script>

  <style is:global>
    /* Override Pagefind defaults to match site design */
    :root {
      --pagefind-ui-scale: 1;
      --pagefind-ui-primary: #C8973A;
      --pagefind-ui-text: #111827;
      --pagefind-ui-background: #FFFFFF;
      --pagefind-ui-border: #E2D8C8;
      --pagefind-ui-tag: #F4EDE0;
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 3px;
      --pagefind-ui-image-border-radius: 4px;
      --pagefind-ui-image-box-ratio: 3 / 2;
      --pagefind-ui-font: 'Manrope', sans-serif;
    }

    .pagefind-ui__search-input {
      font-size: 16px !important;
      padding: 14px 20px !important;
      border-color: #E2D8C8 !important;
      background: #fff !important;
    }

    .pagefind-ui__search-input:focus {
      border-color: #C8973A !important;
      outline: none !important;
      box-shadow: 0 0 0 3px rgba(200,151,58,0.12) !important;
    }

    .pagefind-ui__search-clear {
      color: #8896A5 !important;
    }

    .pagefind-ui__results-area {
      margin-top: 32px !important;
    }

    .pagefind-ui__result {
      border-bottom: 1px solid #E2D8C8 !important;
      padding: 24px 0 !important;
    }

    .pagefind-ui__result-link {
      font-size: 18px !important;
      font-weight: 700 !important;
      color: #09131F !important;
      text-decoration: none !important;
      transition: color 0.2s !important;
    }

    .pagefind-ui__result-link:hover {
      color: #C8973A !important;
    }

    .pagefind-ui__result-excerpt {
      color: #4A5568 !important;
      font-size: 14px !important;
      line-height: 1.65 !important;
      margin-top: 8px !important;
    }

    .pagefind-ui__result-excerpt mark {
      background: rgba(200,151,58,0.2) !important;
      color: #09131F !important;
      border-radius: 2px !important;
      padding: 0 2px !important;
    }

    .pagefind-ui__button {
      background: #C8973A !important;
      color: #09131F !important;
      font-weight: 700 !important;
      border: none !important;
      padding: 10px 24px !important;
      border-radius: 2px !important;
      font-size: 13px !important;
      letter-spacing: 0.06em !important;
      text-transform: uppercase !important;
      cursor: pointer !important;
      transition: background 0.2s !important;
    }

    .pagefind-ui__button:hover {
      background: #DDA94E !important;
    }

    .pagefind-ui__message {
      color: #8896A5 !important;
      font-size: 14px !important;
    }
  </style>
</BaseLayout>
