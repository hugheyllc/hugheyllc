---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout
  title="Client Requests Dashboard | Hughey LLC"
  description="Manage client service requests."
  noindex={true}
>
  <div style="background: var(--ink); color: var(--white); min-height: 100vh;">
    <!-- Auth Gate -->
    <div id="authGate" style="display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 40px 20px;">
      <div style="max-width: 400px; width: 100%; text-align: center;">
        <img src="/images/logo.png" alt="Hughey LLC" width="140" height="86" style="height:86px;width:auto;display:block;margin:0 auto 32px;" />
        <h2 style="font-size: 22px; font-weight: 700; color: var(--white); margin-bottom: 8px;">Admin Dashboard</h2>
        <p style="color: rgba(255,255,255,0.5); font-size: 14px; margin-bottom: 28px;">Enter your access code to continue.</p>
        <form id="authForm" style="display: flex; flex-direction: column; gap: 16px;">
          <input type="password" id="authPassword" placeholder="Access code" autocomplete="off"
            style="width:100%;padding:14px 18px;background:rgba(255,255,255,0.05);border:1px solid rgba(200,151,58,0.2);border-radius:2px;color:var(--white);font-size:15px;font-family:inherit;text-align:center;letter-spacing:0.1em;" />
          <button type="submit" style="background:var(--gold);color:var(--ink);font-family:var(--man);font-weight:800;font-size:13px;letter-spacing:0.07em;text-transform:uppercase;padding:14px 28px;border:none;border-radius:2px;cursor:pointer;transition:background 0.2s;">
            Enter Dashboard
          </button>
          <div id="authError" style="display:none;color:#ff8080;font-size:13px;"></div>
        </form>
      </div>
    </div>

    <!-- Dashboard (hidden until auth) -->
    <div id="dashboard" style="display: none;">
      <!-- Header -->
      <div style="padding-top: 140px; padding-bottom: 32px; border-bottom: 1px solid rgba(200,151,58,0.12);">
        <div class="w">
          <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:16px;">
            <div>
              <div style="font-size:11px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:var(--glt);margin-bottom:8px;">Admin Dashboard</div>
              <h1 style="font-size:clamp(28px,4vw,42px);font-weight:800;letter-spacing:-0.02em;margin:0;">Client Requests</h1>
            </div>
            <a href="/client-requests/" class="action-btn" style="text-decoration:none;">+ New Request</a>
          </div>
        </div>
      </div>

      <!-- Stats Bar -->
      <div style="padding: 20px 0; border-bottom: 1px solid rgba(200,151,58,0.08);">
        <div class="w">
          <div class="stats-bar">
            <div class="stat-item">
              <span class="stat-num" id="statTotal">—</span>
              <span class="stat-label">Total</span>
            </div>
            <div class="stat-item">
              <span class="stat-num stat-open" id="statOpen">—</span>
              <span class="stat-label">Open</span>
            </div>
            <div class="stat-item">
              <span class="stat-num stat-progress" id="statProgress">—</span>
              <span class="stat-label">In Progress</span>
            </div>
            <div class="stat-item">
              <span class="stat-num stat-completed" id="statCompleted">—</span>
              <span class="stat-label">Completed</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Filters -->
      <div style="padding: 20px 0;">
        <div class="w">
          <div class="filters">
            <div class="filter-group">
              <label for="filterStatus">Status</label>
              <select id="filterStatus">
                <option value="all">All</option>
                <option value="open" selected>Open</option>
                <option value="in-progress">In Progress</option>
                <option value="completed">Completed</option>
              </select>
            </div>
            <div class="filter-group">
              <label for="filterPriority">Priority</label>
              <select id="filterPriority">
                <option value="all">All</option>
                <option value="urgent">Urgent</option>
                <option value="high">High</option>
                <option value="normal">Normal</option>
                <option value="low">Low</option>
              </select>
            </div>
            <div class="filter-group" style="flex:1;min-width:200px;">
              <label for="filterSearch">Search</label>
              <input type="text" id="filterSearch" placeholder="Name, email, ticket ID…" />
            </div>
            <button id="refreshBtn" class="action-btn-sm" title="Refresh">↻ Refresh</button>
          </div>
        </div>
      </div>

      <!-- Table -->
      <div style="padding: 0 0 80px;">
        <div class="w">
          <div id="loadingState" style="text-align:center;padding:60px 0;color:rgba(255,255,255,0.4);">Loading requests…</div>
          <div id="emptyState" style="display:none;text-align:center;padding:60px 0;">
            <p style="color:rgba(255,255,255,0.4);font-size:15px;margin-bottom:8px;">No requests found.</p>
            <p style="color:rgba(255,255,255,0.3);font-size:13px;">Try changing your filters or <a href="/client-requests/" style="color:var(--gold);">submit a new request</a>.</p>
          </div>
          <div class="table-wrap" id="tableWrap" style="display:none;">
            <table id="requestsTable">
              <thead>
                <tr>
                  <th class="sortable" data-sort="ticket_id">Ticket</th>
                  <th class="sortable" data-sort="client_name">Client</th>
                  <th class="sortable" data-sort="request_type">Type</th>
                  <th class="sortable" data-sort="priority">Priority</th>
                  <th>Status</th>
                  <th class="sortable" data-sort="created_at">Created</th>
                </tr>
              </thead>
              <tbody id="tableBody"></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- Detail Modal -->
      <div id="detailModal" class="modal-overlay" style="display:none;">
        <div class="modal-content">
          <button class="modal-close" id="modalClose">✕</button>
          <div id="modalBody">
            <!-- Populated by JS -->
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    let portalPassword = '';
    let allRequests: any[] = [];
    let currentSort = { field: 'created_at', asc: false };

    // Auth
    const authGate = document.getElementById('authGate')!;
    const dashboardEl = document.getElementById('dashboard')!;
    const authForm = document.getElementById('authForm')!;
    const authError = document.getElementById('authError')!;
    const authPasswordInput = document.getElementById('authPassword') as HTMLInputElement;

    const stored = sessionStorage.getItem('portal_auth');
    if (stored) {
      portalPassword = stored;
      authGate.style.display = 'none';
      dashboardEl.style.display = 'block';
      loadRequests();
    }

    authForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const pw = authPasswordInput.value.trim();
      if (!pw) return;

      try {
        const res = await fetch('/api/client-requests', {
          headers: { 'X-Portal-Password': pw },
        });
        if (res.status === 401) {
          authError.style.display = 'block';
          authError.textContent = 'Invalid access code.';
          return;
        }
        portalPassword = pw;
        sessionStorage.setItem('portal_auth', pw);
        authGate.style.display = 'none';
        dashboardEl.style.display = 'block';
        loadRequests();
      } catch {
        authError.style.display = 'block';
        authError.textContent = 'Connection error.';
      }
    });

    // API helpers
    async function apiFetch(path: string, opts: any = {}) {
      const res = await fetch(path, {
        ...opts,
        headers: {
          'Content-Type': 'application/json',
          'X-Portal-Password': portalPassword,
          ...(opts.headers || {}),
        },
      });
      return res;
    }

    // Load requests
    async function loadRequests() {
      const loading = document.getElementById('loadingState')!;
      const empty = document.getElementById('emptyState')!;
      const tableWrap = document.getElementById('tableWrap')!;

      loading.style.display = 'block';
      empty.style.display = 'none';
      tableWrap.style.display = 'none';

      const status = (document.getElementById('filterStatus') as HTMLSelectElement).value;
      const priority = (document.getElementById('filterPriority') as HTMLSelectElement).value;
      const search = (document.getElementById('filterSearch') as HTMLInputElement).value;

      const params = new URLSearchParams();
      if (status !== 'all') params.set('status', status);
      if (priority !== 'all') params.set('priority', priority);
      if (search) params.set('search', search);

      try {
        const res = await apiFetch(`/api/client-requests?${params}`);
        allRequests = await res.json();

        loading.style.display = 'none';

        if (!Array.isArray(allRequests) || allRequests.length === 0) {
          empty.style.display = 'block';
          allRequests = [];
        } else {
          tableWrap.style.display = 'block';
          renderTable();
        }

        updateStats();
      } catch {
        loading.textContent = 'Failed to load requests.';
      }
    }

    // Update stats
    function updateStats() {
      const total = allRequests.length;
      const open = allRequests.filter(r => r.status === 'open').length;
      const progress = allRequests.filter(r => r.status === 'in-progress').length;
      const completed = allRequests.filter(r => r.status === 'completed').length;

      document.getElementById('statTotal')!.textContent = String(total);
      document.getElementById('statOpen')!.textContent = String(open);
      document.getElementById('statProgress')!.textContent = String(progress);
      document.getElementById('statCompleted')!.textContent = String(completed);
    }

    // Render table
    function renderTable() {
      const tbody = document.getElementById('tableBody')!;
      const sorted = [...allRequests].sort((a, b) => {
        let valA = a[currentSort.field];
        let valB = b[currentSort.field];

        // Priority ordering
        if (currentSort.field === 'priority') {
          const order: Record<string, number> = { urgent: 0, high: 1, normal: 2, low: 3 };
          valA = order[valA] ?? 4;
          valB = order[valB] ?? 4;
        }

        if (valA < valB) return currentSort.asc ? -1 : 1;
        if (valA > valB) return currentSort.asc ? 1 : -1;
        return 0;
      });

      tbody.innerHTML = sorted.map(r => `
        <tr class="clickable-row" data-id="${r.id}">
          <td><span class="ticket-id">${r.ticket_id}</span></td>
          <td>${esc(r.client_name)}</td>
          <td>${esc(r.request_type)}</td>
          <td><span class="badge badge-${r.priority}">${r.priority}</span></td>
          <td>
            <select class="status-select status-${r.status}" data-id="${r.id}" onchange="updateStatus(this)">
              <option value="open" ${r.status === 'open' ? 'selected' : ''}>Open</option>
              <option value="in-progress" ${r.status === 'in-progress' ? 'selected' : ''}>In Progress</option>
              <option value="completed" ${r.status === 'completed' ? 'selected' : ''}>Completed</option>
            </select>
          </td>
          <td class="date-cell">${formatDate(r.created_at)}</td>
        </tr>
      `).join('');

      // Click rows to open detail
      tbody.querySelectorAll('.clickable-row').forEach(row => {
        row.addEventListener('click', (e) => {
          if ((e.target as HTMLElement).tagName === 'SELECT') return;
          const id = row.getAttribute('data-id');
          openDetail(id!);
        });
      });
    }

    function esc(str: string) {
      const d = document.createElement('div');
      d.textContent = str;
      return d.innerHTML;
    }

    function formatDate(iso: string) {
      const d = new Date(iso);
      return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
    }

    // Sort
    document.querySelectorAll('.sortable').forEach(th => {
      th.addEventListener('click', () => {
        const field = th.getAttribute('data-sort')!;
        if (currentSort.field === field) {
          currentSort.asc = !currentSort.asc;
        } else {
          currentSort = { field, asc: true };
        }
        // Update sort indicators
        document.querySelectorAll('.sortable').forEach(h => h.classList.remove('sort-asc', 'sort-desc'));
        th.classList.add(currentSort.asc ? 'sort-asc' : 'sort-desc');
        renderTable();
      });
    });

    // Status update
    (window as any).updateStatus = async function(select: HTMLSelectElement) {
      const id = select.getAttribute('data-id');
      const status = select.value;

      select.disabled = true;
      try {
        await apiFetch('/api/client-requests', {
          method: 'PATCH',
          body: JSON.stringify({ id, status }),
        });
        // Update local data
        const req = allRequests.find(r => r.id === id);
        if (req) req.status = status;
        select.className = `status-select status-${status}`;
        updateStats();
      } catch {
        alert('Failed to update status.');
      }
      select.disabled = false;
    };

    // Detail modal
    async function openDetail(id: string) {
      const modal = document.getElementById('detailModal')!;
      const body = document.getElementById('modalBody')!;
      const req = allRequests.find(r => r.id === id);
      if (!req) return;

      body.innerHTML = `
        <div class="detail-header">
          <span class="ticket-id-lg">${req.ticket_id}</span>
          <span class="badge badge-${req.priority}" style="font-size:11px;">${req.priority}</span>
          <span class="badge badge-status-${req.status}" style="font-size:11px;">${req.status}</span>
        </div>

        <div class="detail-grid">
          <div class="detail-item">
            <span class="detail-label">Client</span>
            <span class="detail-value">${esc(req.client_name)}</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Email</span>
            <a href="mailto:${esc(req.email)}" class="detail-value" style="color:var(--gold);text-decoration:none;">${esc(req.email)}</a>
          </div>
          <div class="detail-item">
            <span class="detail-label">Phone</span>
            <span class="detail-value">${req.phone ? `<a href="tel:${esc(req.phone)}" style="color:var(--gold);text-decoration:none;">${esc(req.phone)}</a>` : '—'}</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Type</span>
            <span class="detail-value">${esc(req.request_type)}</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Due Date</span>
            <span class="detail-value">${req.due_date ? formatDate(req.due_date) : '—'}</span>
          </div>
          <div class="detail-item">
            <span class="detail-label">Created</span>
            <span class="detail-value">${formatDate(req.created_at)}</span>
          </div>
        </div>

        <div class="detail-section">
          <span class="detail-label">Description</span>
          <div class="detail-description">${esc(req.description).replace(/\n/g, '<br>')}</div>
        </div>

        <div class="detail-section">
          <span class="detail-label">Notes</span>
          <textarea id="detailNotes" rows="4" placeholder="Add internal notes…">${esc(req.notes || '')}</textarea>
          <button id="saveNotesBtn" class="action-btn-sm" style="margin-top:10px;" onclick="saveNotes('${req.id}')">Save Notes</button>
        </div>
      `;

      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }

    (window as any).saveNotes = async function(id: string) {
      const textarea = document.getElementById('detailNotes') as HTMLTextAreaElement;
      const btn = document.getElementById('saveNotesBtn') as HTMLButtonElement;
      const notes = textarea.value;

      btn.disabled = true;
      btn.textContent = 'Saving…';

      try {
        await apiFetch('/api/client-requests', {
          method: 'PATCH',
          body: JSON.stringify({ id, notes }),
        });
        const req = allRequests.find(r => r.id === id);
        if (req) req.notes = notes;
        btn.textContent = 'Saved ✓';
        setTimeout(() => { btn.textContent = 'Save Notes'; btn.disabled = false; }, 1500);
      } catch {
        btn.textContent = 'Failed — try again';
        btn.disabled = false;
      }
    };

    // Close modal
    document.getElementById('modalClose')?.addEventListener('click', closeModal);
    document.getElementById('detailModal')?.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).id === 'detailModal') closeModal();
    });

    function closeModal() {
      document.getElementById('detailModal')!.style.display = 'none';
      document.body.style.overflow = '';
    }

    // Escape key closes modal
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeModal();
    });

    // Filters
    document.getElementById('filterStatus')?.addEventListener('change', loadRequests);
    document.getElementById('filterPriority')?.addEventListener('change', loadRequests);
    let searchTimeout: number;
    document.getElementById('filterSearch')?.addEventListener('input', () => {
      clearTimeout(searchTimeout);
      searchTimeout = window.setTimeout(loadRequests, 300);
    });
    document.getElementById('refreshBtn')?.addEventListener('click', loadRequests);
  </script>

  <style>
    /* ── Action Buttons ──────────────────────────────────────── */
    .action-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: var(--gold);
      color: var(--ink);
      font-family: var(--man);
      font-weight: 800;
      font-size: 12px;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      padding: 12px 22px;
      border: none;
      border-radius: 2px;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s;
    }
    .action-btn:hover { background: var(--glt); transform: translateY(-1px); }

    .action-btn-sm {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(200,151,58,0.15);
      color: var(--gold);
      font-family: var(--man);
      font-weight: 700;
      font-size: 11px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 8px 16px;
      border: 1px solid rgba(200,151,58,0.25);
      border-radius: 2px;
      cursor: pointer;
      transition: background 0.2s, border-color 0.2s;
      white-space: nowrap;
    }
    .action-btn-sm:hover { background: rgba(200,151,58,0.25); border-color: var(--gold); }
    .action-btn-sm:disabled { opacity: 0.5; cursor: not-allowed; }

    /* ── Stats Bar ───────────────────────────────────────────── */
    .stats-bar {
      display: flex;
      gap: 40px;
      flex-wrap: wrap;
    }
    .stat-item {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .stat-num {
      font-size: 28px;
      font-weight: 800;
      font-family: var(--bar);
      color: var(--white);
    }
    .stat-open { color: #3B82F6; }
    .stat-progress { color: #F59E0B; }
    .stat-completed { color: #1A9E6B; }
    .stat-label {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: rgba(255,255,255,0.4);
    }

    /* ── Filters ─────────────────────────────────────────────── */
    .filters {
      display: flex;
      gap: 16px;
      align-items: flex-end;
      flex-wrap: wrap;
    }
    .filter-group {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .filter-group label {
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.4);
    }
    .filter-group select,
    .filter-group input {
      padding: 9px 14px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(200,151,58,0.15);
      border-radius: 2px;
      color: var(--white);
      font-size: 13px;
      font-family: inherit;
      min-width: 130px;
    }
    .filter-group select:focus,
    .filter-group input:focus {
      outline: none;
      border-color: var(--gold);
    }
    .filter-group select option { background: #09131F; }

    /* ── Table ────────────────────────────────────────────────── */
    .table-wrap {
      overflow-x: auto;
      border: 1px solid rgba(200,151,58,0.12);
      border-radius: 4px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
    }
    thead th {
      text-align: left;
      padding: 12px 16px;
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: rgba(255,255,255,0.4);
      background: rgba(200,151,58,0.04);
      border-bottom: 1px solid rgba(200,151,58,0.12);
      white-space: nowrap;
    }
    .sortable { cursor: pointer; user-select: none; }
    .sortable:hover { color: var(--gold); }
    .sortable::after { content: ''; margin-left: 4px; }
    .sort-asc::after { content: ' ↑'; }
    .sort-desc::after { content: ' ↓'; }

    tbody td {
      padding: 12px 16px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
      vertical-align: middle;
    }
    .clickable-row { cursor: pointer; transition: background 0.15s; }
    .clickable-row:hover { background: rgba(200,151,58,0.04); }

    .ticket-id {
      font-weight: 700;
      font-family: var(--bar);
      color: var(--gold);
      font-size: 14px;
      letter-spacing: 0.03em;
    }

    .date-cell {
      color: rgba(255,255,255,0.45);
      white-space: nowrap;
      font-size: 12px;
    }

    /* ── Badges ───────────────────────────────────────────────── */
    .badge {
      display: inline-block;
      padding: 3px 10px;
      border-radius: 3px;
      font-size: 10px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .badge-low { background: rgba(107,114,128,0.2); color: #9CA3AF; }
    .badge-normal { background: rgba(59,130,246,0.15); color: #60A5FA; }
    .badge-high { background: rgba(245,158,11,0.15); color: #FBBF24; }
    .badge-urgent { background: rgba(239,68,68,0.15); color: #F87171; }
    .badge-status-open { background: rgba(59,130,246,0.15); color: #60A5FA; }
    .badge-status-in-progress { background: rgba(245,158,11,0.15); color: #FBBF24; }
    .badge-status-completed { background: rgba(26,158,107,0.15); color: #34D399; }

    /* ── Status Select ───────────────────────────────────────── */
    .status-select {
      padding: 4px 8px;
      background: transparent;
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 3px;
      color: var(--white);
      font-size: 11px;
      font-family: inherit;
      font-weight: 600;
      cursor: pointer;
    }
    .status-select option { background: #09131F; }
    .status-open { border-color: rgba(59,130,246,0.3); color: #60A5FA; }
    .status-in-progress { border-color: rgba(245,158,11,0.3); color: #FBBF24; }
    .status-completed { border-color: rgba(26,158,107,0.3); color: #34D399; }

    /* ── Modal ────────────────────────────────────────────────── */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(9,19,31,0.85);
      backdrop-filter: blur(8px);
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 20px;
    }
    .modal-content {
      background: #0F1D30;
      border: 1px solid rgba(200,151,58,0.2);
      border-radius: 6px;
      max-width: 640px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
      padding: 36px;
      position: relative;
    }
    .modal-close {
      position: absolute;
      top: 14px;
      right: 18px;
      background: none;
      border: none;
      color: rgba(255,255,255,0.4);
      font-size: 20px;
      cursor: pointer;
