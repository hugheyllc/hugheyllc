---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Client Requests Dashboard — Hughey LLC"
  description="Admin dashboard for client request tickets."
  noindex={true}
>
  <section class="ad-page">
    <div class="ad-container">
      <!-- Password Gate -->
      <div id="gate" class="ad-gate">
        <div class="ad-card ad-card-narrow">
          <h1>Admin Dashboard</h1>
          <p class="ad-sub">Enter your access code to continue.</p>
          <form id="gate-form" class="ad-gate-form">
            <input
              type="password"
              id="gate-password"
              placeholder="Access code"
              autocomplete="off"
              required
            />
            <button type="submit" class="ad-btn">Enter</button>
          </form>
          <p id="gate-error" class="ad-error" style="display:none;">Invalid access code.</p>
        </div>
      </div>

      <!-- Dashboard -->
      <div id="dashboard" style="display:none;">
        <!-- Header -->
        <div class="ad-header">
          <h1>Client Requests</h1>
        </div>

        <!-- Stats -->
        <div class="ad-stats" id="stats">
          <div class="ad-stat">
            <span class="ad-stat-num" id="stat-total">—</span>
            <span class="ad-stat-label">Total</span>
          </div>
          <div class="ad-stat ad-stat-open">
            <span class="ad-stat-num" id="stat-open">—</span>
            <span class="ad-stat-label">Open</span>
          </div>
          <div class="ad-stat ad-stat-progress">
            <span class="ad-stat-num" id="stat-progress">—</span>
            <span class="ad-stat-label">In Progress</span>
          </div>
          <div class="ad-stat ad-stat-done">
            <span class="ad-stat-num" id="stat-done">—</span>
            <span class="ad-stat-label">Completed</span>
          </div>
        </div>

        <!-- Filters -->
        <div class="ad-filters">
          <a href="/client-requests/" class="ad-btn ad-btn-outline">+ New Request</a>
          <select id="filter-status">
            <option value="all">All Statuses</option>
            <option value="open">Open</option>
            <option value="in-progress">In Progress</option>
            <option value="completed">Completed</option>
          </select>
          <select id="filter-priority">
            <option value="all">All Priorities</option>
            <option value="urgent">Urgent</option>
            <option value="high">High</option>
            <option value="normal">Normal</option>
            <option value="low">Low</option>
          </select>
          <input type="text" id="filter-search" placeholder="Search tickets..." />
          <button class="ad-btn" id="refresh-btn">Refresh</button>
        </div>

        <!-- Table -->
        <div class="ad-table-wrap">
          <table class="ad-table" id="tickets-table">
            <thead>
              <tr>
                <th>Ticket</th>
                <th>Client</th>
                <th>Type</th>
                <th>Priority</th>
                <th>Status</th>
                <th>Created</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="tickets-body">
              <tr><td colspan="7" class="ad-empty">Loading...</td></tr>
            </tbody>
          </table>
        </div>

        <!-- Detail Modal -->
        <div id="modal" class="ad-modal" style="display:none;">
          <div class="ad-modal-content">
            <button class="ad-modal-close" id="modal-close">&times;</button>
            <div id="modal-body"></div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* CRITICAL CONTRAST FIXES - Using !important to ensure deployment */
  .ad-table td {
    color: #ffffff !important;
  }
  
  .detail-notes textarea {
    min-height: 120px !important;
    color: #ffffff !important;
  }
  
  .detail-value {
    color: #ffffff !important;
  }

  .ad-page {
    min-height: 100vh;
    background: var(--ink);
    padding: 32px 20px;
  }

  .ad-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .ad-gate {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80vh;
  }

  .ad-card {
    background: var(--navy);
    border: 1px solid var(--steel);
    border-radius: 12px;
    padding: 40px;
  }

  .ad-card-narrow {
    max-width: 420px;
    width: 100%;
  }

  .ad-card h1 {
    font-family: var(--bas);
    color: var(--white);
    font-size: 1.5rem;
    margin-bottom: 8px;
  }

  .ad-sub {
    color: var(--dim);
    font-size: 0.9rem;
    margin-bottom: 20px;
  }

  .ad-gate-form {
    display: flex;
    gap: 12px;
  }

  .ad-gate-form input {
    flex: 1;
  }

  .ad-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }

  .ad-header h1 {
    font-family: var(--bas);
    color: var(--white);
    font-size: 1.75rem;
  }

  /* Stats */
  .ad-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }

  .ad-stat {
    background: var(--navy);
    border: 1px solid var(--steel);
    border-radius: 10px;
    padding: 20px;
    text-align: center;
  }

  .ad-stat-num {
    display: block;
    font-family: var(--bar);
    font-size: 2rem;
    font-weight: 700;
    color: var(--white);
  }

  .ad-stat-label {
    color: var(--dim);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .ad-stat-open .ad-stat-num { color: #3B82F6; }
  .ad-stat-progress .ad-stat-num { color: #F59E0B; }
  .ad-stat-done .ad-stat-num { color: var(--ok); }

  /* Filters */
  .ad-filters {
    display: flex;
    gap: 12px;
    margin-bottom: 20px;
    flex-wrap: wrap;
  }

  .ad-filters select,
  .ad-filters input {
    flex: 1;
    min-width: 150px;
  }

  .ad-filters .ad-btn-outline {
    flex: 0 0 auto;
  }

  input, select {
    padding: 10px 14px;
    background: var(--navy);
    border: 1px solid var(--steel);
    border-radius: 6px;
    color: var(--white);
    font-family: var(--man);
    font-size: 0.9rem;
  }

  input:focus, select:focus {
    outline: none;
    border-color: var(--gold);
  }

  /* Buttons */
  .ad-btn {
    padding: 10px 20px;
    background: var(--gold);
    color: var(--ink);
    font-family: var(--man);
    font-weight: 700;
    font-size: 0.85rem;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.2s;
    white-space: nowrap;
    text-decoration: none;
  }

  .ad-btn:hover { background: var(--glt); }

  .ad-btn-outline {
    background: transparent;
    color: var(--gold);
    border: 1px solid var(--gold);
  }

  .ad-btn-outline:hover {
    background: var(--gold);
    color: var(--ink);
  }

  .ad-btn-sm {
    padding: 5px 12px;
    font-size: 0.75rem;
    border-radius: 4px;
  }

  .ad-btn-status {
    background: rgba(55, 65, 81, 0.8);
    color: #e5e7eb;
    border: 1px solid rgba(75, 85, 99, 0.6);
    margin: 2px;
  }

  .ad-btn-status:hover { background: rgba(75, 85, 99, 0.9); color: #ffffff; }
  .ad-btn-status.active { background: var(--gold); color: var(--ink); }

  /* Table */
  .ad-table-wrap {
    overflow-x: auto;
    background: var(--navy);
    border: 1px solid var(--steel);
    border-radius: 10px;
  }

  .ad-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .ad-table th {
    text-align: left;
    padding: 12px 16px;
    color: var(--dim);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    border-bottom: 1px solid var(--steel);
    white-space: nowrap;
  }

  .ad-table td {
    padding: 12px 16px;
    color: #ffffff;
    border-bottom: 1px solid rgba(36, 58, 102, 0.5);
    vertical-align: middle;
  }

  .ad-table tbody tr {
    cursor: pointer;
    transition: background 0.15s;
  }

  .ad-table tbody tr:hover {
    background: rgba(200, 151, 58, 0.05);
  }

  .ad-empty {
    text-align: center;
    color: var(--dim);
    padding: 40px !important;
  }

  /* Badges */
  .badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 4px;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .badge-open { background: #2563EB; color: #ffffff; }
  .badge-in-progress { background: #D97706; color: #ffffff; }
  .badge-completed { background: #059669; color: #ffffff; }

  .badge-low { background: #374151; color: #e5e7eb; }
  .badge-normal { background: #2563EB; color: #ffffff; }
  .badge-high { background: #D97706; color: #ffffff; }
  .badge-urgent { background: #DC2626; color: #ffffff; }

  /* Modal */
  .ad-modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    padding: 20px;
  }

  .ad-modal-content {
    background: #0f1a2e;
    border: 1px solid var(--steel);
    border-radius: 12px;
    padding: 32px;
    max-width: 600px;
    width: 100%;
    max-height: 85vh;
    overflow-y: auto;
    position: relative;
  }

  .ad-modal-close {
    position: absolute;
    top: 12px;
    right: 16px;
    background: none;
    border: none;
    color: #e5e7eb;
    font-size: 1.75rem;
    cursor: pointer;
    line-height: 1;
    z-index: 10;
  }

  .ad-modal-close:hover {
    color: #ffffff;
  }

  .ad-error {
    color: #EF4444;
    font-size: 0.9rem;
    margin-top: 12px;
  }

  .detail-row {
    display: flex;
    justify-content: space-between;
    padding: 10px 0;
    border-bottom: 1px solid rgba(36, 58, 102, 0.5);
  }

  .detail-label {
    color: #9ca3af;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .detail-value {
    color: #ffffff;
    text-align: right;
    max-width: 60%;
  }

  .detail-desc {
    margin-top: 16px;
    padding: 16px;
    background: rgba(0, 0, 0, 0.4);
    border-radius: 8px;
    color: #ffffff !important;
    line-height: 1.6;
    white-space: pre-wrap;
  }

  .detail-notes {
    margin-top: 16px;
  }

  .detail-notes textarea {
    width: 100%;
    min-height: 120px;
    padding: 14px;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid var(--steel);
    border-radius: 8px;
    color: #ffffff;
    font-family: var(--man);
    font-size: 0.95rem;
    resize: vertical;
    line-height: 1.5;
  }

  .detail-notes textarea::placeholder {
    color: #9ca3af;
  }

  .detail-notes textarea:focus {
    outline: none;
    border-color: var(--gold);
  }

  .detail-actions {
    margin-top: 20px;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }



  @media (max-width: 768px) {
    .ad-stats {
      grid-template-columns: repeat(2, 1fr);
    }

    .ad-filters {
      flex-direction: column;
    }

    .ad-header {
      flex-direction: column;
      gap: 12px;
      align-items: flex-start;
    }

    .ad-gate-form {
      flex-direction: column;
    }
  }
</style>

<script>
  let storedPassword = '';
  let allTickets: any[] = [];

  // Gate
  document.getElementById('gate-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const pw = (document.getElementById('gate-password') as HTMLInputElement).value;
    storedPassword = pw;

    fetch('/api/client-requests?limit=0', {
      headers: { 'X-Portal-Password': pw },
    })
      .then((r) => {
        if (r.status === 401) {
          document.getElementById('gate-error')!.style.display = 'block';
          return;
        }
        document.getElementById('gate')!.style.display = 'none';
        document.getElementById('dashboard')!.style.display = 'block';
        loadTickets();
      })
      .catch(() => {
        document.getElementById('gate-error')!.style.display = 'block';
      });
  });

  // Filters
  document.getElementById('filter-status')?.addEventListener('change', loadTickets);
  document.getElementById('filter-priority')?.addEventListener('change', loadTickets);
  document.getElementById('refresh-btn')?.addEventListener('click', loadTickets);

  let searchTimeout: ReturnType<typeof setTimeout>;
  document.getElementById('filter-search')?.addEventListener('input', () => {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(loadTickets, 300);
  });

  async function loadTickets() {
    const status = (document.getElementById('filter-status') as HTMLSelectElement).value;
    const priority = (document.getElementById('filter-priority') as HTMLSelectElement).value;
    const search = (document.getElementById('filter-search') as HTMLInputElement).value.trim();

    const params = new URLSearchParams();
    if (status !== 'all') params.set('status', status);
    if (priority !== 'all') params.set('priority', priority);
    if (search) params.set('search', search);

    try {
      const res = await fetch(`/api/client-requests?${params.toString()}`, {
        headers: { 'X-Portal-Password': storedPassword },
      });

      if (!res.ok) throw new Error('Failed to load');

      allTickets = await res.json();
      renderTickets(allTickets);
      updateStats(allTickets);
    } catch (err) {
      document.getElementById('tickets-body')!.innerHTML =
        '<tr><td colspan="7" class="ad-empty">Failed to load tickets.</td></tr>';
    }
  }

  function renderTickets(tickets: any[]) {
    const tbody = document.getElementById('tickets-body')!;

    if (tickets.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" class="ad-empty">No tickets found.</td></tr>';
      return;
    }

    tbody.innerHTML = tickets
      .map(
        (t) => `
      <tr onclick="showDetail('${t.id}')" style="background:rgba(36,58,102,1) !important;">
        <td style="font-weight:700 !important;color:#fff !important;font-family:var(--bar) !important;letter-spacing:1px !important;padding:12px 16px !important;border-bottom:1px solid rgba(36,58,102,0.5) !important;vertical-align:middle !important;">${esc(t.ticket_id)}</td>
        <td style="padding:12px 16px !important;color:#fff !important;border-bottom:1px solid rgba(36,58,102,0.5) !important;vertical-align:middle !important;"><span style="color:#fff !important;font-weight:500 !important;display:block !important;">${esc(t.client_name)}</span><span style="font-size:0.8rem !important;color:#ffffff !important;opacity:0.85 !important;display:block !important;">${esc(t.email)}</span></td>
        <td style="color:#fff !important;padding:12px 16px !important;border-bottom:1px solid rgba(36,58,102,0.5) !important;">${esc(t.request_type)}</td>
        <td style="padding:12px 16px !important;border-bottom:1px solid rgba(36,58,102,0.5) !important;"><span class="badge badge-${t.priority}">${esc(t.priority)}</span></td>
        <td style="padding:12px 16px !important;border-bottom:1px solid rgba(36,58,102,0.5) !important;"><span class="badge badge-${t.status}">${esc(t.status)}</span></td>
        <td style="white-space:nowrap !important;font-size:0.85rem !important;color:#fff !important;padding:12px 16px !important;border-bottom:1px solid rgba(36,58,102,0.5) !important;">${formatDate(t.created_at)}</td>
        <td>
          <button class="ad-btn ad-btn-sm ad-btn-status" onclick="event.stopPropagation();quickStatus('${t.id}','open')" ${t.status === 'open' ? 'style="background:#2563EB;color:#fff;border-color:#2563EB;"' : ''}>Open</button>
          <button class="ad-btn ad-btn-sm ad-btn-status" onclick="event.stopPropagation();quickStatus('${t.id}','in-progress')" ${t.status === 'in-progress' ? 'style="background:#D97706;color:#fff;border-color:#D97706;"' : ''}>WIP</button>
          <button class="ad-btn ad-btn-sm ad-btn-status" onclick="event.stopPropagation();quickStatus('${t.id}','completed')" ${t.status === 'completed' ? 'style="background:#059669;color:#fff;border-color:#059669;"' : ''}>Done</button>
        </td>
      </tr>
    `
      )
      .join('');
  }

  function updateStats(tickets: any[]) {
    // For stats, we need unfiltered counts — refetch all if filters active
    const status = (document.getElementById('filter-status') as HTMLSelectElement).value;
    const hasFilters = status !== 'all';

    if (hasFilters) {
      // Just show filtered counts
      document.getElementById('stat-total')!.textContent = String(tickets.length);
      document.getElementById('stat-open')!.textContent = String(tickets.filter((t) => t.status === 'open').length);
      document.getElementById('stat-progress')!.textContent = String(tickets.filter((t) => t.status === 'in-progress').length);
      document.getElementById('stat-done')!.textContent = String(tickets.filter((t) => t.status === 'completed').length);
    } else {
      document.getElementById('stat-total')!.textContent = String(tickets.length);
      document.getElementById('stat-open')!.textContent = String(tickets.filter((t) => t.status === 'open').length);
      document.getElementById('stat-progress')!.textContent = String(tickets.filter((t) => t.status === 'in-progress').length);
      document.getElementById('stat-done')!.textContent = String(tickets.filter((t) => t.status === 'completed').length);
    }
  }

  // Quick status update
  (window as any).quickStatus = async function (id: string, newStatus: string) {
    try {
      const res = await fetch('/api/client-requests', {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'X-Portal-Password': storedPassword,
        },
        body: JSON.stringify({ id, status: newStatus }),
      });

      if (!res.ok) throw new Error('Update failed');
      loadTickets();
    } catch (err) {
      alert('Failed to update status');
    }
  };

  // Detail modal
  (window as any).showDetail = function (id: string) {
    const ticket = allTickets.find((t) => t.id === id);
    if (!ticket) return;

    const modal = document.getElementById('modal')!;
    const body = document.getElementById('modal-body')!;

    body.innerHTML = `
      <h2 style="font-family:var(--bas);color:var(--white);font-size:1.3rem;margin-bottom:20px;">
        <span style="color:var(--gold);font-family:var(--bar);letter-spacing:1px;">${esc(ticket.ticket_id)}</span>
      </h2>

      <div class="detail-row">
        <span class="detail-label">Client</span>
        <span class="detail-value">${esc(ticket.client_name)}</span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Email</span>
        <span class="detail-value"><a href="mailto:${esc(ticket.email)}" style="color:var(--gold);">${esc(ticket.email)}</a></span>
      </div>
      ${ticket.phone ? `<div class="detail-row"><span class="detail-label">Phone</span><span class="detail-value"><a href="tel:${esc(ticket.phone)}" style="color:var(--gold);">${esc(ticket.phone)}</a></span></div>` : ''}
      <div class="detail-row">
        <span class="detail-label">Type</span>
        <span class="detail-value">${esc(ticket.request_type)}</span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Priority</span>
        <span class="detail-value"><span class="badge badge-${ticket.priority}">${esc(ticket.priority)}</span></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Status</span>
        <span class="detail-value"><span class="badge badge-${ticket.status}">${esc(ticket.status)}</span></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Created</span>
        <span class="detail-value">${formatDate(ticket.created_at)}</span>
      </div>
      ${ticket.due_date ? `<div class="detail-row"><span class="detail-label">Due Date</span><span class="detail-value">${esc(ticket.due_date)}</span></div>` : ''}

      <h3 style="color:#ffffff !important;font-size:0.8rem;text-transform:uppercase;letter-spacing:1px;margin-top:20px;margin-bottom:8px;font-weight:700 !important;">Description</h3>
      <div class="detail-desc" style="color:#ffffff !important;background:rgba(0,0,0,0.4) !important;">${esc(ticket.description)}</div>

      <div class="detail-notes">
        <h3 style="color:#ffffff !important;font-size:0.85rem;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;font-weight:700 !important;">Internal Notes</h3>
        <textarea id="modal-notes" rows="8" placeholder="Add notes..." style="width:100% !important;min-height:120px !important;padding:12px !important;background:#1a2940 !important;border:1px solid rgba(200,151,58,0.4) !important;border-radius:6px !important;color:#ffffff !important;font-family:var(--man) !important;font-size:0.95rem !important;resize:vertical !important;line-height:1.5 !important;">${esc(ticket.notes || '')}</textarea>
        <button class="ad-btn" style="margin-top:12px !important;background:var(--gold) !important;color:var(--ink) !important;border:1px solid var(--gold) !important;font-weight:700 !important;padding:10px 20px !important;cursor:pointer !important;" onclick="saveNotes('${ticket.id}')">Save Notes</button>
      </div>

      <div class="detail-actions" style="padding:16px !important;background:rgba(200,151,58,0.08) !important;border:1px solid rgba(200,151,58,0.2) !important;border-radius:8px !important;margin-top:20px !important;">
        <p style="color:#ffffff !important;font-size:0.75rem;font-weight:700 !important;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:12px;margin-top:0 !important;">Update Status</p>
        <button class="ad-btn ad-btn-sm" style="${ticket.status === 'open' ? 'background:#3B82F6 !important;color:#ffffff !important;border:1px solid #3B82F6 !important;font-weight:700 !important;' : 'background:#2d3e57 !important;color:#ffffff !important;border:1px solid #3d4d63 !important;'}padding:8px 12px !important;margin:4px 4px 4px 0 !important;" onclick="updateAndClose('${ticket.id}','open')">Open</button>
        <button class="ad-btn ad-btn-sm" style="${ticket.status === 'in-progress' ? 'background:#F59E0B !important;color:#000000 !important;border:1px solid #F59E0B !important;font-weight:700 !important;' : 'background:#2d3e57 !important;color:#ffffff !important;border:1px solid #3d4d63 !important;'}padding:8px 12px !important;margin:4px 4px 4px 0 !important;" onclick="updateAndClose('${ticket.id}','in-progress')">In Progress</button>
        <button class="ad-btn ad-btn-sm" style="${ticket.status === 'completed' ? 'background:#10B981 !important;color:#ffffff !important;border:1px solid #10B981 !important;font-weight:700 !important;' : 'background:#2d3e57 !important;color:#ffffff !important;border:1px solid #3d4d63 !important;'}padding:8px 12px !important;margin:4px 4px 4px 0 !important;" onclick="updateAndClose('${ticket.id}','completed')">Done</button>
      </div>
    `;

    modal.style.display = 'flex';
  };

  (window as any).saveNotes = async function (id: string) {
    const notes = (document.getElementById('modal-notes') as HTMLTextAreaElement).value;
    try {
      await fetch('/api/client-requests', {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
          'X-Portal-Password': storedPassword,
        },
        body: JSON.stringify({ id, notes }),
      });
      loadTickets();
    } catch {}
  };

  (window as any).updateAndClose = async function (id: string, status: string) {
    await (window as any).quickStatus(id, status);
    document.getElementById('modal')!.style.display = 'none';
  };

  // Close modal
  document.getElementById('modal-close')?.addEventListener('click', () => {
    document.getElementById('modal')!.style.display = 'none';
  });

  document.getElementById('modal')?.addEventListener('click', (e) => {
    if (e.target === document.getElementById('modal')) {
      document.getElementById('modal')!.style.display = 'none';
    }
  });

  // Helpers
  function esc(str: string): string {
    if (!str) return '';
    const div = document.createElement('div');
    div.textContent = String(str);
    return div.innerHTML;
  }

  function formatDate(iso: string): string {
    if (!iso) return '—';
    const d = new Date(iso);
    return d.toLocaleDateString('en-US', {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
    });
  }
</script>
