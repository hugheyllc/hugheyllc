---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import FaqSection from '../components/FaqSection.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    number: '01',
    title: 'Data Analysis',
    subtitle: 'for Law Firms',
    slug: 'data-analysis-for-law-firms',
    problem: 'Your marketing data is scattered across platforms with no clear line to retained clients.',
    solution: 'We audit your analytics stack, implement proper conversion tracking, and build dashboards that show cost-per-retained-client by channel — so you know exactly what\'s working.',
    outcomes: ['Unified analytics dashboard', 'Cost-per-retained-client by channel', 'Attribution clarity across all touchpoints'],
  },
  {
    number: '02',
    title: 'Agency Management',
    subtitle: 'for Law Firms',
    slug: 'agency-management-for-law-firms',
    problem: 'Managing an SEO agency, PPC agency, and web developer separately creates gaps, overlap, and no accountability.',
    solution: 'We become your marketing operations director — integrating all vendors, aligning them on retained client metrics, and holding them accountable for results that actually matter.',
    outcomes: ['Unified vendor strategy', 'Monthly performance accountability', 'Marketing budget optimization'],
  },
  {
    number: '03',
    title: 'Intake Process',
    subtitle: 'Optimization',
    slug: 'intake-process-optimization',
    problem: 'Your marketing drives leads but your intake process drops 30–40% of them before they become clients.',
    solution: 'We redesign your intake workflow from first contact to retained client, implement the right technology stack, and train your team to convert more prospects.',
    outcomes: ['Redesigned intake workflow', 'Technology implementation', 'Team training & SOPs'],
  },
  {
    number: '04',
    title: 'Strategic Marketing',
    subtitle: 'for Law Firms',
    slug: 'strategic-marketing-for-law-firms',
    problem: 'Reactive marketing wastes budget, confuses your team, and produces inconsistent results.',
    solution: 'We develop a clear, integrated 12-month strategy with realistic timelines, budget allocation by channel, and monthly progress tracking tied to retained client goals.',
    outcomes: ['12-month integrated strategy', 'Channel budget allocation', 'Monthly progress reporting'],
  },
  {
    number: '05',
    title: 'Always Publishing.',
    subtitle: 'Always Ranking.',
    slug: 'always-publishing-always-ranking',
    problem: 'Your firm goes weeks without publishing content, your social presence is inconsistent, and your SEO infrastructure quietly degrades over time.',
    solution: 'We build an automated content and SEO system that publishes daily blog posts, distributes to LinkedIn and Twitter/X, and maintains clean technical SEO — without your team touching it.',
    outcomes: ['Daily blog publishing', 'Automated social distribution', 'SEO infrastructure built in'],
    badge: 'NEW',
  },
  {
    number: '06',
    title: 'Always Found.',
    subtitle: 'Always Local.',
    slug: 'always-found-always-local',
    problem: 'You show up on page 2 while competitors who do worse work rank first. Local search is winner-take-all — and most firms have never properly claimed their territory.',
    solution: 'We build and maintain your local search dominance — Google Business Profile, citations, location pages, and review systems — so your firm is the first result when someone nearby searches for your practice area.',
    outcomes: ['Google Business Profile optimized', '50+ citation sources cleaned', 'Location pages for every market'],
    badge: 'NEW',
  },
];

const faqs = [
  { q: 'What does a law firm marketing consultant do?', a: 'A law firm marketing consultant audits your marketing operations, analytics, and intake process to identify why leads are not converting into retained clients. Hughey LLC acts as the strategic layer above existing vendors, aligning all channels toward cost per retained client.' },
  { q: 'How is Hughey LLC different from a marketing agency?', a: 'Agencies execute tactics. Hughey LLC operates above the agency layer — analyzing data, building strategy, managing vendor accountability, and optimizing intake. We are responsible for whether all tactics combine to actually grow the firm.' },
  { q: 'What is cost per retained client?', a: 'Cost per retained client (CPRC) is the total marketing spend required to sign one new client. It connects marketing investment to real business outcomes — unlike cost per click or cost per lead, which are inputs, not results.' },
  { q: 'How long before I see results?', a: 'Intake optimizations typically show improvement within 30–60 days. Analytics clarity takes 60–90 days to instrument. Strategic marketing results compound over 6–12 months. We give you a realistic timeline during the initial consultation.' },
];
---

<BaseLayout
  title="Legal Marketing Services | Hughey LLC"
  description="Law firm marketing strategy and operations: data analysis, agency management, intake optimization, and strategic planning. Focused on retained clients."
  canonical="https://hugheyllc.com/services/"
>
  <div>
    <PageHero
      eyebrow="What We Do"
      heading="Six Services.<br /><em>One Goal.</em>"
      subheading="Every service is designed around a single metric: more retained clients per marketing dollar."
      cta={{ label: "Schedule a Free Strategy Call", href: "/contact/" }}
    />

    <!-- Light content section -->
    <div style="background: var(--page); padding: 80px 0 0;">
      <div class="w">

        <!-- Services list -->
        <div class="services-list">
          {services.map((service, i) => (
            <article class="service-row rx">
              <div class="svc-num">{service.number}</div>
              <div class="svc-body">
                <span class="section-accent"></span>
                <h2 class="svc-title">
                  {service.title} <span class="svc-sub">{service.subtitle}</span>
                  {service.badge && <span class="svc-badge">{service.badge}</span>}
                </h2>
                <p class="svc-problem">"{service.problem}"</p>
                <p class="svc-solution">{service.solution}</p>
                <div class="svc-outcomes">
                  {service.outcomes.map(o => (
                    <div class="outcome-item">
                      <span class="outcome-dot"></span>
                      {o}
                    </div>
                  ))}
                </div>
                <a href={`/services/${service.slug}/`} class="svc-link">Learn more →</a>
              </div>
              <div class="svc-accent-bar"></div>
            </article>
          ))}
        </div>

        <!-- Process strip -->
        <div class="process-strip rx">
          <p class="process-eyebrow">How every engagement works</p>
          <div class="process-steps">
            {['Audit', 'Strategy', 'Execute', 'Measure'].map((step, i) => (
              <div class="process-step">
                <div class="process-num">{i + 1}</div>
                <div class="process-label">{step}</div>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>

    <!-- FAQ section -->
    <FaqSection items={faqs} heading="Questions About Our Services" />

    <!-- CTA band -->
    <div style="background: var(--page); padding: 0 0 96px;">
      <div class="w">
        <div class="cta-band rx">
          <div class="cta-band-inner">
            <p class="cta-eyebrow">Not sure where to start?</p>
            <h3 class="cta-heading">Most firms benefit from starting with a data audit. Let's talk about what your situation calls for.</h3>
            <a href="/contact/" class="cta-btn">Schedule a Free Strategy Call →</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <Footer />

  <style>
    .services-list {
      display: flex;
      flex-direction: column;
    }

    .service-row {
      display: grid;
      grid-template-columns: 72px 1fr 6px;
      gap: 48px;
      align-items: start;
      padding: 56px 0;
      border-bottom: 1px solid var(--bdr);
      transition: background 0.2s;
    }

    .service-row:first-child { border-top: 1px solid var(--bdr); }
    .service-row:hover { background: rgba(200,151,58,0.02); }

    .svc-num {
      font-family: var(--bar);
      font-size: 44px;
      font-weight: 800;
      color: rgba(200,151,58,0.2);
      line-height: 1;
      padding-top: 10px;
      transition: color 0.3s;
    }

    .service-row:hover .svc-num { color: rgba(200,151,58,0.5); }

    .svc-body { padding-right: 32px; }

    .svc-title {
      font-size: clamp(22px, 2.5vw, 30px);
      font-weight: 800;
      color: var(--ink);
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin-bottom: 12px;
    }

    .svc-sub {
      font-weight: 400;
      color: var(--gold);
      font-size: 0.85em;
    }

    .svc-badge {
      display: inline-block;
      font-size: 10px;
      font-weight: 800;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--ink);
      background: var(--gold);
      padding: 4px 9px;
      border-radius: 2px;
      vertical-align: middle;
      margin-left: 8px;
      line-height: 1.2;
    }

    .svc-problem {
      font-size: 14px;
      color: var(--dim);
      font-style: italic;
      margin-bottom: 14px;
      line-height: 1.6;
    }

    .svc-solution {
      font-size: 15px;
      color: var(--sub);
      line-height: 1.75;
      margin-bottom: 20px;
    }

    .svc-outcomes {
      display: flex;
      flex-direction: column;
      gap: 7px;
      margin-bottom: 24px;
    }

    .outcome-item {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      color: var(--sub);
    }

    .outcome-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--gold);
      flex-shrink: 0;
    }

    .svc-link {
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--gold);
      text-decoration: none;
      border-bottom: 1px solid rgba(200,151,58,0.35);
      padding-bottom: 2px;
      transition: color 0.2s, border-color 0.2s;
    }

    .svc-link:hover { color: var(--gdim); border-color: var(--gdim); }

    .svc-accent-bar {
      width: 6px;
      height: 56px;
      background: linear-gradient(to bottom, var(--gold), transparent);
      border-radius: 3px;
      margin-top: 10px;
      opacity: 0;
      transition: opacity 0.3s;
    }

    .service-row:hover .svc-accent-bar { opacity: 1; }

    /* Process strip */
    .process-strip {
      padding: 64px 0;
      border-top: 1px solid var(--bdr);
      margin-top: 0;
    }

    .process-eyebrow {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--dim);
      text-align: center;
      margin-bottom: 40px;
    }

    .process-steps {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
      max-width: 640px;
      margin: 0 auto;
    }

    .process-step { text-align: center; }

    .process-num {
      width: 48px;
      height: 48px;
      border: 2px solid rgba(200,151,58,0.3);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      font-weight: 800;
      color: var(--gold);
      margin: 0 auto 12px;
      transition: border-color 0.2s, background 0.2s;
    }

    .process-step:hover .process-num {
      border-color: var(--gold);
      background: rgba(200,151,58,0.06);
    }

    .process-label {
      font-size: 13px;
      font-weight: 600;
      color: var(--ink);
    }

    /* CTA band */
    .cta-band {
      background: var(--ink);
      border-radius: 6px;
      overflow: hidden;
      position: relative;
    }

    .cta-band::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 80% 50%, rgba(200,151,58,0.12) 0%, transparent 60%);
    }

    .cta-band-inner { padding: 56px 64px; position: relative; z-index: 1; }

    .cta-eyebrow {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(200,151,58,0.7);
      margin-bottom: 12px;
    }

    .cta-heading {
      font-size: clamp(20px, 2.5vw, 30px);
      font-weight: 800;
      color: var(--white);
      margin-bottom: 28px;
      line-height: 1.3;
      max-width: 600px;
    }

    .cta-btn {
      display: inline-flex;
      align-items: center;
      background: var(--gold);
      color: var(--ink);
      font-family: var(--man);
      font-weight: 800;
      font-size: 13px;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      padding: 16px 32px;
      border-radius: 2px;
      text-decoration: none;
      transition: background 0.2s, transform 0.2s;
      box-shadow: 0 4px 24px rgba(200,151,58,0.35);
    }

    .cta-btn:hover { background: var(--glt); transform: translateY(-1px); }

    @media (max-width: 900px) {
      .service-row { grid-template-columns: 48px 1fr; gap: 24px; }
      .svc-accent-bar { display: none; }
      .svc-num { font-size: 32px; }
      .svc-body { padding-right: 0; }
      .process-steps { grid-template-columns: repeat(2, 1fr); }
      .cta-band-inner { padding: 40px 28px; }
    }
  </style>
</BaseLayout>
