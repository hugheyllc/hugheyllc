---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const services = [
  {
    number: '01',
    title: 'Data Analysis',
    subtitle: 'for Law Firms',
    slug: 'data-analysis-for-law-firms',
    problem: 'Your marketing data is scattered across platforms with no clear line to retained clients.',
    solution: 'We audit your analytics stack, implement proper conversion tracking, and build dashboards that show cost-per-retained-client by channel — so you know exactly what\'s working.',
    outcomes: ['Unified analytics dashboard', 'Cost-per-retained-client by channel', 'Attribution clarity across all touchpoints'],
  },
  {
    number: '02',
    title: 'Agency Management',
    subtitle: 'for Law Firms',
    slug: 'agency-management-for-law-firms',
    problem: 'Managing an SEO agency, PPC agency, and web developer separately creates gaps, overlap, and no accountability.',
    solution: 'We become your marketing operations director — integrating all vendors, aligning them on retained client metrics, and holding them accountable for results that actually matter.',
    outcomes: ['Unified vendor strategy', 'Monthly performance accountability', 'Marketing budget optimization'],
  },
  {
    number: '03',
    title: 'Intake Process',
    subtitle: 'Optimization',
    slug: 'intake-process-optimization',
    problem: 'Your marketing drives leads but your intake process drops 30–40% of them before they become clients.',
    solution: 'We redesign your intake workflow from first contact to retained client, implement the right technology stack, and train your team to convert more prospects.',
    outcomes: ['Redesigned intake workflow', 'Technology implementation', 'Team training & SOPs'],
  },
  {
    number: '04',
    title: 'Strategic Marketing',
    subtitle: 'for Law Firms',
    slug: 'strategic-marketing-for-law-firms',
    problem: 'Reactive marketing wastes budget, confuses your team, and produces inconsistent results.',
    solution: 'We develop a clear, integrated 12-month strategy with realistic timelines, budget allocation by channel, and monthly progress tracking tied to retained client goals.',
    outcomes: ['12-month integrated strategy', 'Channel budget allocation', 'Monthly progress reporting'],
  },
];
---

<BaseLayout
  title="Legal Marketing Services | Hughey LLC"
  description="Law firm marketing strategy and operations: data analysis, agency management, intake optimization, and strategic planning. Focused on retained clients."
  canonical="https://hugheyllc.com/services"
>
  <div style="background: var(--ink); color: var(--white); min-height: 100vh;">
    <PageHero eyebrow="What We Do" heading="Four Services.<br /><em>One Goal.</em>" subheading="Every service we offer is designed around a single metric: retained clients per marketing dollar." />

    <!-- Services List -->
    <div style="padding: 80px 0;">
      <div class="w">
        <div style="display: flex; flex-direction: column; gap: 0;">
          {services.map((service, i) => (
            <div class="service-row" style={`border-top: 1px solid rgba(200, 151, 58, 0.15); padding: 56px 0; ${i === services.length - 1 ? 'border-bottom: 1px solid rgba(200,151,58,0.15);' : ''}`}>
              <div style="display: grid; grid-template-columns: 80px 1fr 1fr; gap: 48px; align-items: start;">
                <!-- Number -->
                <div style="font-size: 13px; font-weight: 700; color: rgba(200,151,58,0.5); letter-spacing: 0.15em; font-family: var(--man); padding-top: 6px;">{service.number}</div>
                
                <!-- Title + Problem -->
                <div>
                  <h2 style="font-size: 32px; font-weight: 800; color: var(--white); line-height: 1.2; margin-bottom: 4px;">{service.title}</h2>
                  <p style="font-size: 18px; font-weight: 400; color: var(--gold); margin-bottom: 20px;">{service.subtitle}</p>
                  <p style="font-size: 15px; color: rgba(255,255,255,0.5); line-height: 1.6; margin-bottom: 20px; font-style: italic;">
                    "{service.problem}"
                  </p>
                  <a href={`/services/${service.slug}`} style="display: inline-flex; align-items: center; gap: 8px; color: var(--gold); text-decoration: none; font-weight: 700; font-size: 13px; letter-spacing: 0.05em; text-transform: uppercase; transition: color 0.2s;">
                    Learn More →
                  </a>
                </div>
                
                <!-- Solution + Outcomes -->
                <div>
                  <p style="font-size: 15px; color: rgba(255,255,255,0.8); line-height: 1.7; margin-bottom: 24px;">{service.solution}</p>
                  <div style="display: flex; flex-direction: column; gap: 8px;">
                    {service.outcomes.map(outcome => (
                      <div style="display: flex; align-items: center; gap: 10px; font-size: 13px; color: rgba(255,255,255,0.6);">
                        <span style="width: 6px; height: 6px; background: var(--gold); border-radius: 50%; flex-shrink: 0;"></span>
                        {outcome}
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Process Strip -->
    <div style="padding: 80px 0; background: rgba(200, 151, 58, 0.04); border-top: 1px solid rgba(200,151,58,0.12); border-bottom: 1px solid rgba(200,151,58,0.12);">
      <div class="w">
        <p style="text-align: center; font-size: 12px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(200,151,58,0.7); margin-bottom: 48px;">How Every Engagement Works</p>
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 32px; max-width: 960px; margin: 0 auto; position: relative;">
          {['Audit', 'Strategy', 'Execute', 'Measure'].map((step, i) => (
            <div style="text-align: center;">
              <div style="width: 56px; height: 56px; border: 2px solid rgba(200,151,58,0.4); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 16px; font-size: 20px; font-weight: 800; color: var(--gold);">{i + 1}</div>
              <h3 style="font-size: 16px; font-weight: 700; margin-bottom: 8px;">{step}</h3>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div style="padding: 80px 0;">
      <div class="w">
        <div style="text-align: center; max-width: 640px; margin: 0 auto;">
          <h2 style="font-size: 36px; font-weight: 800; margin-bottom: 16px;">Not Sure Where to Start?</h2>
          <p style="font-size: 16px; color: rgba(255,255,255,0.7); margin-bottom: 32px; line-height: 1.6;">
            Most firms benefit from starting with a data audit. Schedule a free call and we'll tell you exactly what your situation calls for.
          </p>
          <a href="/contact" style="display: inline-flex; align-items: center; gap: 9px; background: var(--gold); color: var(--ink); font-family: var(--man); font-weight: 800; font-size: 13px; letter-spacing: 0.07em; text-transform: uppercase; padding: 16px 34px; border-radius: 2px; text-decoration: none; transition: all 0.25s; box-shadow: 0 4px 28px rgba(200, 151, 58, 0.42);">
            Schedule a Free Strategy Call →
          </a>
        </div>
      </div>
    </div>
  </div>

  <style>
    .service-row:hover {
      background: rgba(200, 151, 58, 0.02);
    }

    a:hover {
      color: var(--glt) !important;
    }

    a[style*="background: var(--gold)"]:hover {
      background: var(--glt) !important;
      color: var(--ink) !important;
      transform: translateY(-1px);
      box-shadow: 0 6px 36px rgba(200, 151, 58, 0.52) !important;
    }

    em {
      color: var(--glt);
      font-style: italic;
    }

    @media (max-width: 900px) {
      .service-row > div {
        grid-template-columns: 1fr !important;
        gap: 24px !important;
      }

      .service-row > div > div:first-child {
        display: none;
      }
    }

    @media (max-width: 600px) {
      div[style*="grid-template-columns: repeat(4"] {
        grid-template-columns: repeat(2, 1fr) !important;
      }
    }
  </style>
</BaseLayout>
