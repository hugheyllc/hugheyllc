---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import FaqSection from '../components/FaqSection.astro';
import Footer from '../components/Footer.astro';

const faqs = [
  { q: 'Who is Joe Hughey?', a: 'Joe Hughey is the founder of Hughey LLC and has worked exclusively in law firm marketing since 2004. He works with law firms ranging from solo practitioners to large regional firms, helping them build marketing systems focused on retained client growth. He is based in St. Petersburg, Florida and serves firms nationally.' },
  { q: 'What makes Hughey LLC different from other legal marketing firms?', a: 'Hughey LLC focuses exclusively on law firms and operates at the strategy and operations level — not execution. We do not compete with your SEO agency or PPC firm. We sit above them, aligning all vendors and measuring everything against cost per retained client.' },
  { q: 'Does Hughey LLC work with law firms outside of Florida?', a: 'Yes. While we are headquartered in St. Petersburg, Florida and have deep expertise in the Gulf Coast legal market, we work with law firms nationally. All engagements can be conducted remotely.' },
];

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://hugheyllc.com/about/#joe-hughey",
  "name": "Joe Hughey",
  "jobTitle": "Founder & Law Firm Marketing Consultant",
  "worksFor": { "@id": "https://hugheyllc.com/#business" },
  "url": "https://hugheyllc.com/about",
  "sameAs": ["https://www.linkedin.com/in/joehughey/"],
  "address": { "@type": "PostalAddress", "addressLocality": "St. Petersburg", "addressRegion": "FL", "addressCountry": "US" },
  "knowsAbout": ["Law firm marketing", "Legal marketing strategy", "Client intake optimization", "Marketing analytics", "Agency management"]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://hugheyllc.com" },
    { "@type": "ListItem", "position": 2, "name": "About", "item": "https://hugheyllc.com/about" }
  ]
};

const backgroundItems = [
  '20+ years in legal marketing strategy and operations',
  'Expertise in marketing analytics, client intake systems, and agency management',
  'Published insights on law firm marketing data, SEO, paid search, and marketing attribution',
  'Speaker at legal marketing conferences and firm leadership events',
  'Based in St. Petersburg, Florida',
];
---

<BaseLayout
  title="About Hughey LLC | 20+ Years of Law Firm Marketing"
  description="Hughey LLC works exclusively with law firms to build marketing operations that generate retained clients. Founded by Joe Hughey, St. Petersburg, FL."
  canonical="https://hugheyllc.com/about"
  schema={[personSchema, breadcrumbSchema]}
>
  <div>
    <PageHero
      eyebrow="20+ Years. One Focus."
      heading="Focused on One Metric:<br /><em>Retained Clients</em>"
      subheading="We work exclusively with law firms to build marketing systems that connect every dollar spent to actual client retention."
      cta={{ label: "Schedule a Free Strategy Call", href: "/contact/" }}
    />

    <!-- Light content section -->
    <div style="background: var(--page); padding: 80px 0 0;">
      <div class="w">

        <!-- Our Story -->
        <section class="story-section rx">
          <div class="story-label">
            <span class="section-accent"></span>
            <h2 class="story-heading">Our Story</h2>
          </div>
          <div class="story-body">
            <p>Hughey LLC works exclusively with law firms to build marketing systems that generate retained clients — not just leads, not just brand awareness, but the specific metric that matters.</p>
            <p>20+ years in the legal marketing space has taught us one thing: most law firm marketing fails not because of the agencies or the tactics, but because of the disconnect between marketing operations and client intake. A campaign can look perfect in the agency report and yet the retained client count doesn't move.</p>
            <p>We solve for that disconnect. Our approach combines deep data analysis to understand what's actually driving clients, strategic direction that aligns marketing investment with intake capacity, and an operational framework that connects every channel to the metrics that matter.</p>
            <p>We serve law firms nationally, with particular expertise in personal injury, family law, business law, and complex civil litigation. Our home is Tampa Bay, Florida, where we work with firms across the Gulf Coast.</p>
          </div>
        </section>

        <!-- How We Work -->
        <section class="how-section rx">
          <span class="section-accent"></span>
          <h2 class="how-heading">How We Work</h2>
          <div class="how-grid">
            <div class="how-card rxl d1">
              <h3>Data Analysis</h3>
              <p>We start by understanding your current marketing data. What channels are actually driving retained clients? Where is money being wasted?</p>
            </div>
            <div class="how-card rxl d2">
              <h3>Strategic Direction</h3>
              <p>We develop integrated strategy that aligns marketing investment with your intake capacity and growth goals.</p>
            </div>
            <div class="how-card rxl d3">
              <h3>Operations Framework</h3>
              <p>We connect your marketing channels to intake to client retention, creating visibility into what actually matters.</p>
            </div>
          </div>
        </section>

        <!-- About Joe -->
        <section class="joe-section">
          <div class="joe-row rx">
            <div class="joe-text">
              <span class="section-accent"></span>
              <h2 class="joe-heading">About Joe</h2>
              <p class="joe-intro">Joe Hughey founded Hughey LLC and has focused exclusively on law firm marketing for 20+ years. He works with law firms ranging from solo practitioners to large regional firms — helping them build marketing operations that generate measurable retained clients.</p>
              <p class="joe-sub">His background includes:</p>
              <ul class="joe-list">
                {backgroundItems.map(item => (
                  <li>
                    <span class="joe-arrow">→</span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
              <p class="joe-philosophy">Joe's philosophy is simple: law firm marketing should be measured by one metric — retained clients. Everything else is a means to that end.</p>
            </div>
            <div class="joe-card">
              <div class="joe-photo-wrap">
                <img src="/images/joe-hughey.jpg" alt="Joe Hughey — Founder, Hughey LLC" class="joe-photo" />
              </div>
              <div class="joe-card-body">
                <div class="joe-name">Joe Hughey</div>
                <div class="joe-role">Founder, Hughey LLC</div>
                <div class="joe-location">St. Petersburg, FL</div>
                <a href="https://www.linkedin.com/in/joehughey/" rel="noopener noreferrer" target="_blank" class="joe-linkedin">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0H5C2.239 0 0 2.239 0 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5V5c0-2.761-2.238-5-5-5zM8 19H5V8h3v11zM6.5 6.732c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zM20 19h-3v-5.604c0-3.368-4-3.113-4 0V19h-3V8h3v1.765c1.396-2.586 7-2.777 7 2.476V19z"/></svg>
                  LinkedIn
                </a>
              </div>
            </div>
          </div>
        </section>

      </div>
    </div>

    <!-- FAQ -->
    <FaqSection items={faqs} heading="Questions About Hughey LLC" />

    <!-- CTA band -->
    <div style="background: var(--page); padding: 0 0 96px;">
      <div class="w">
        <div class="cta-band rx">
          <div class="cta-inner">
            <p class="cta-eyebrow">Let's talk about your firm</p>
            <h3 class="cta-heading">Schedule a free strategy call — no pitch, just an honest conversation.</h3>
            <a href="/contact/" class="cta-btn">Schedule a Free Strategy Call →</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <Footer />

  <style>
    /* Story */
    .story-section {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 64px;
      padding: 64px 0;
      border-bottom: 1px solid var(--bdr);
      align-items: start;
    }

    .story-heading {
      font-size: 28px;
      font-weight: 800;
      color: var(--ink);
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin-top: 12px;
    }

    .story-body p {
      font-size: 15px;
      line-height: 1.8;
      color: var(--sub);
      margin-bottom: 18px;
    }

    .story-body p:last-child { margin-bottom: 0; }

    /* How We Work */
    .how-section {
      padding: 64px 0;
      border-bottom: 1px solid var(--bdr);
    }

    .how-heading {
      font-size: 28px;
      font-weight: 800;
      color: var(--ink);
      letter-spacing: -0.02em;
      margin-bottom: 40px;
      margin-top: 12px;
    }

    .how-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 32px;
    }

    .how-card {
      background: var(--white);
      border: 1px solid var(--bdr);
      border-radius: 4px;
      padding: 28px 32px;
      transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
    }

    .how-card:hover {
      border-color: var(--gold);
      box-shadow: 0 8px 32px rgba(0,0,0,0.07);
      transform: translateY(-3px);
    }

    .how-card h3 {
      font-size: 16px;
      font-weight: 700;
      color: var(--gold);
      margin-bottom: 10px;
    }

    .how-card p {
      font-size: 14px;
      color: var(--sub);
      line-height: 1.65;
    }

    /* Joe */
    .joe-section {
      padding: 64px 0;
      border-bottom: 1px solid var(--bdr);
    }

    .joe-row {
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 64px;
      align-items: start;
    }

    .joe-heading {
      font-size: 28px;
      font-weight: 800;
      color: var(--ink);
      letter-spacing: -0.02em;
      margin-bottom: 20px;
      margin-top: 12px;
    }

    .joe-intro, .joe-philosophy {
      font-size: 15px;
      line-height: 1.8;
      color: var(--sub);
      margin-bottom: 18px;
    }

    .joe-sub {
      font-size: 14px;
      font-weight: 600;
      color: var(--ink);
      margin-bottom: 12px;
    }

    .joe-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 20px;
    }

    .joe-list li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 14px;
      color: var(--sub);
      line-height: 1.5;
    }

    .joe-arrow {
      color: var(--gold);
      font-weight: 700;
      flex-shrink: 0;
      margin-top: 1px;
    }

    /* Joe card */
    .joe-card {
      background: var(--white);
      border: 1px solid var(--bdr);
      border-radius: 6px;
      overflow: hidden;
      box-shadow: 0 4px 24px rgba(0,0,0,0.06);
    }

    .joe-photo-wrap {
      width: 100%;
      aspect-ratio: 1 / 1;
      overflow: hidden;
    }

    .joe-photo {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center 15%;
      display: block;
      transition: transform 0.4s;
    }

    .joe-card:hover .joe-photo { transform: scale(1.03); }

    .joe-card-body {
      padding: 20px 24px;
    }

    .joe-name {
      font-size: 16px;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 2px;
    }

    .joe-role {
      font-size: 13px;
      color: var(--gold);
      font-weight: 600;
      margin-bottom: 4px;
    }

    .joe-location {
      font-size: 12px;
      color: var(--dim);
      margin-bottom: 14px;
    }

    .joe-linkedin {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      font-weight: 600;
      color: #0077b5;
      text-decoration: none;
      transition: opacity 0.2s;
    }

    .joe-linkedin:hover { opacity: 0.75; }

    /* CTA band */
    .cta-band {
      background: var(--ink);
      border-radius: 6px;
      overflow: hidden;
      position: relative;
      margin-top: 80px;
    }

    .cta-band::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 80% 50%, rgba(200,151,58,0.12) 0%, transparent 60%);
    }

    .cta-inner { padding: 56px 64px; position: relative; z-index: 1; }

    .cta-eyebrow {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(200,151,58,0.7);
      margin-bottom: 12px;
    }

    .cta-heading {
      font-size: clamp(20px, 2.5vw, 28px);
      font-weight: 800;
      color: var(--white);
      margin-bottom: 28px;
      line-height: 1.3;
      max-width: 560px;
    }

    .cta-btn {
      display: inline-flex;
      align-items: center;
      background: var(--gold);
      color: var(--ink);
      font-family: var(--man);
      font-weight: 800;
      font-size: 13px;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      padding: 16px 32px;
      border-radius: 2px;
      text-decoration: none;
      transition: background 0.2s, transform 0.2s;
      box-shadow: 0 4px 24px rgba(200,151,58,0.35);
    }

    .cta-btn:hover { background: var(--glt); transform: translateY(-1px); }

    @media (max-width: 900px) {
      .story-section { grid-template-columns: 1fr; gap: 24px; }
      .how-grid { grid-template-columns: 1fr; }
      .joe-row { grid-template-columns: 1fr; }
      .joe-card { max-width: 280px; }
      .cta-inner { padding: 40px 28px; }
    }
  </style>
</BaseLayout>
