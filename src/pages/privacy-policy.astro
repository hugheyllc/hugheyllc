---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Privacy Policy | Hughey LLC"
  description="Privacy policy for Hughey LLC website."
  canonical="https://hugheyllc.com/privacy-policy"
>
  <div style="background: var(--ink); color: var(--white); min-height: 100vh;">
    <div style="min-height: 200px; background: linear-gradient(135deg, rgba(200, 151, 58, 0.1) 0%, rgba(27, 51, 96, 0.15) 100%); display: flex; flex-direction: column; justify-content: center; padding: 140px 0 80px;">
      <div class="w">
        <h1 style="font-size: clamp(36px, 5vw, 56px); font-weight: 800; line-height: 1.1;">Privacy Policy</h1>
      </div>
    </div>

    <div style="padding: 80px 0;">
      <div class="w">
        <div style="max-width: 800px; font-size: 16px; line-height: 1.8; color: rgba(255, 255, 255, 0.8);">
          <p style="margin-bottom: 24px;">Last updated: May 27, 2026</p>

          <h2 style="font-size: 24px; font-weight: 700; color: var(--white); margin: 40px 0 16px;">Information We Collect</h2>
          <p style="margin-bottom: 20px;">When you use our website or contact us, we may collect your name, email address, phone number, and information about your law firm. We collect this information when you submit our contact form or schedule a call.</p>

          <h2 style="font-size: 24px; font-weight: 700; color: var(--white); margin: 40px 0 16px;">How We Use Your Information</h2>
          <p style="margin-bottom: 20px;">We use the information you provide to respond to your inquiries, schedule consultations, and provide our marketing consulting services. We do not sell your personal information to third parties.</p>

          <h2 style="font-size: 24px; font-weight: 700; color: var(--white); margin: 40px 0 16px;">Analytics</h2>
          <p style="margin-bottom: 20px;">We use Google Analytics to understand how visitors use our website. This information helps us improve our site. Google Analytics uses cookies to collect anonymous usage data.</p>

          <h2 style="font-size: 24px; font-weight: 700; color: var(--white); margin: 40px 0 16px;">Contact</h2>
          <p style="margin-bottom: 20px;">If you have questions about this privacy policy, contact us at <a href="mailto:joe@joehughey.com" style="color: var(--gold);">Hughey LLC</a> or call <a href="tel:727-483-3222" style="color: var(--gold);">727-483-3222</a>.</p>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
