---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import FaqSection from '../../components/FaqSection.astro';
import Footer from '../../components/Footer.astro';

const faqs = [
  {
    q: 'Do I have to review every post before it goes live?',
    a: 'No — but you can if you want to. Most clients set it to fully automatic after seeing the first few posts. We calibrate the system to your voice during onboarding, and the output is consistently on-brand. If a post ever misses the mark, it takes 30 seconds to unpublish.',
  },
  {
    q: 'What if my firm is already on WordPress?',
    a: 'No migration needed. We connect the system directly to your existing WordPress site via a standard integration. Your theme, your plugins, your URL structure — all untouched. We just add the engine on top.',
  },
  {
    q: 'Will the content actually rank, or is this just filler?',
    a: 'Every post is written for a real search intent — not to hit a word count. We build proper SEO structure into every piece: schema markup, internal links, optimized titles and meta descriptions, image alt text. Ranking takes time, but the foundation is built right from day one.',
  },
  {
    q: 'How long does it take to set up?',
    a: 'WordPress integration: about one week. New site build: two to three weeks. After that, the system is self-running.',
  },
  {
    q: 'Do I own the content?',
    a: 'Yes — completely. Every post, every image, every social post is yours. If you ever stop working with us, the content stays on your site and the system can be handed off. You are never locked in.',
  },
  {
    q: 'Is the content compliant with my state bar advertising rules?',
    a: 'Yes — every piece of content is scanned against ABA Model Rules 7.1-7.5 and your state bar advertising rules before it publishes. Outcome guarantees, unsubstantiated superlatives, and missing disclaimers are automatically flagged and held for review. The system currently covers Florida, Texas, California, New York, Georgia, Illinois, Pennsylvania, Ohio, Michigan, and North Carolina.',
  },
  {
    q: 'What happens if a piece of content fails the compliance check?',
    a: 'It does not publish. The system holds it, flags the specific issue with a plain-English explanation and a suggested fix, and notifies you for review. Most flags resolve in under five minutes.',
  },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Always Publishing. Always Ranking.",
  "description": "Automated content and SEO system for law firms: daily blog publishing, social distribution to LinkedIn and Twitter/X, and SEO infrastructure built in — without your team touching it.",
  "provider": { "@type": "Organization", "name": "Hughey LLC", "url": "https://hugheyllc.com" },
  "areaServed": { "@type": "Country", "name": "United States" },
  "url": "https://hugheyllc.com/services/always-publishing-always-ranking/"
};

const schema = [
  serviceSchema,
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://hugheyllc.com" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://hugheyllc.com/services" },
      { "@type": "ListItem", "position": 3, "name": "Always Publishing. Always Ranking.", "item": "https://hugheyllc.com/services/always-publishing-always-ranking" }
    ]
  }
];

const problems = [
  {
    title: 'No content cadence',
    body: 'Law firms know they should be publishing but never do. No time, no writer, no system. Google rewards consistency. Your competitors who post regularly are ranking where you should be.',
  },
  {
    title: 'Social presence is an afterthought',
    body: 'Firms post occasionally when someone remembers. LinkedIn and Twitter/X reward accounts that show up daily. Sporadic posting gets ignored by the algorithm and by prospects.',
  },
  {
    title: 'SEO infrastructure breaks down over time',
    body: 'Old URLs break. Canonical tags get misconfigured. Schema markup never gets added. Each issue chips away at rankings you should own.',
  },
];

const features = [
  {
    title: 'Daily Blog Publishing',
    body: 'A new post goes live every morning. Relevant to your practice area, written for your market, optimized to rank. 365 posts per year without a single hour of your team\'s time.',
    icon: 'edit',
  },
  {
    title: 'Daily Social Distribution',
    body: 'Every post is automatically distributed to LinkedIn and Twitter/X with platform-optimized copy. Consistent presence. Daily touchpoints with potential clients and referral sources.',
    icon: 'share',
  },
  {
    title: 'SEO Infrastructure Built In',
    body: 'Every post is properly structured: canonical tags, schema markup, internal linking, XML sitemap, image optimization. Not an afterthought — built into every piece of content from day one.',
    icon: 'search',
  },
  {
    title: 'Local Market Targeting',
    body: 'Content targets your city and practice areas specifically. We build dedicated landing pages for every market you serve. The algorithm learns what your firm is about and where.',
    icon: 'map',
  },
  {
    title: 'Your Voice, Not Generic AI',
    body: 'We spend time with you upfront calibrating the system to your firm\'s tone, practice areas, and market positioning. Clients and referral sources will recognize your voice.',
    icon: 'mic',
  },
  {
    title: 'Works With Your Existing Site',
    body: 'Already on WordPress? No migration required. We connect the system directly to your existing site. If you need a new site, we build that too.',
    icon: 'plug',
  },
];

const idealClients = [
  'You know you should be publishing but your team doesn\'t have the bandwidth',
  'Your current site hasn\'t been updated in months and your social presence is inconsistent',
  'You want to build a content moat that compounds over time — not just run ads',
];
---

<BaseLayout
  title="Always Publishing. Always Ranking. | Hughey LLC"
  description="An automated content and SEO system for law firms. Daily blog posts. Daily social distribution. Clean technical SEO. Without your team touching it."
  canonical="https://hugheyllc.com/services/always-publishing-always-ranking/"
  schema={schema}
>
  <div class="apr-page">
    <PageHero
      eyebrow="NEW SERVICE"
      heading="Always Publishing.<br /><em>Always Ranking.</em>"
      subheading="Most law firms go weeks without publishing a single piece of content. Your competitors are. We fix that — permanently, automatically, without your staff touching it."
      cta={{ label: "Schedule a Free Call", href: "/contact/" }}
    />

    <!-- The Problem -->
    <section class="apr-section dark rx">
      <div class="w">
        <span class="section-accent"></span>
        <h2 class="apr-h2">Your firm is invisible online. <em>Here is why.</em></h2>
        <div class="problem-grid">
          {problems.map((p, i) => (
            <div class={`problem-card rxl d${i + 1}`}>
              <div class="problem-num">0{i + 1}</div>
              <h3>{p.title}</h3>
              <p>{p.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Bar-Compliant by Default -->
    <section class="apr-section compliance rx">
      <div class="w">
        <span class="section-accent"></span>
        <p class="compliance-eyebrow">A Differentiator Generic Agencies Cannot Match</p>
        <h2 class="apr-h2">Bar-Compliant <em>by default.</em></h2>
        <p class="compliance-lede">Generic content agencies do not know bar advertising rules. We built the compliance check directly into the publishing engine — every piece of content is scanned against ABA Model Rules 7.1–7.5 and your state bar rules before it ever goes live.</p>

        <div class="compliance-grid">
          <div class="compliance-card rxl d1">
            <div class="compliance-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
            </div>
            <h3>ABA Model Rules 7.1–7.5</h3>
            <p>Every blog post, social update, and landing page is scanned against the ABA Model Rules on lawyer advertising before publishing. No false or misleading statements. No improper communications. No outcome guarantees.</p>
          </div>
          <div class="compliance-card rxl d2">
            <div class="compliance-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <h3>Your State Bar Rules</h3>
            <p>State-specific advertising rules apply automatically based on where you practice — Florida, Texas, California, New York, Georgia, Illinois, Pennsylvania, Ohio, Michigan, North Carolina, and more.</p>
          </div>
          <div class="compliance-card rxl d3">
            <div class="compliance-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <h3>Auto-Hold for Review</h3>
            <p>Flagged content never publishes automatically. The system holds it, surfaces the specific rule it touches in plain English, and gives you a suggested fix. You stay in control of edge cases.</p>
          </div>
        </div>

        <div class="compliance-callout rx">
          <p><strong>No &ldquo;best attorney&rdquo; claims. No outcome guarantees. No missing disclaimers.</strong> Ever.</p>
        </div>
      </div>
    </section>

    <!-- What You Get -->
    <section class="apr-section dark alt rx">
      <div class="w">
        <span class="section-accent"></span>
        <h2 class="apr-h2">A complete content and ranking system — <em>built once, running forever.</em></h2>
        <div class="feature-list">
          {features.map((f, i) => (
            <div class={`feature-row rx d${(i % 3) + 1}`}>
              <div class="feature-icon">
                {f.icon === 'edit' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                )}
                {f.icon === 'share' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
                )}
                {f.icon === 'search' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                )}
                {f.icon === 'map' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                )}
                {f.icon === 'mic' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
                )}
                {f.icon === 'plug' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 2v6"/><path d="M15 2v6"/><path d="M6 8h12v4a6 6 0 0 1-12 0V8z"/><path d="M12 18v4"/></svg>
                )}
              </div>
              <div class="feature-body">
                <h3>{f.title}</h3>
                <p>{f.body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Why It Works -->
    <section class="apr-section dark rx">
      <div class="w narrow">
        <span class="section-accent"></span>
        <h2 class="apr-h2">Consistency wins. <em>Most firms can't sustain it manually.</em></h2>
        <div class="why-body">
          <p>Google favors law firms that publish consistently, maintain clean technical SEO, and build topical authority over time. The firms ranking at the top of your market didn't get there by accident — they have a content machine running.</p>
          <p>The difference: we can run yours automatically. No editorial calendar to maintain. No writer to manage. No technical SEO audits to commission.</p>
          <p>The system publishes, distributes, and optimizes every day — whether you're in court, on vacation, or focused on clients.</p>
        </div>
      </div>
    </section>

    <!-- Who It's For -->
    <section class="apr-section dark alt rx">
      <div class="w">
        <span class="section-accent"></span>
        <h2 class="apr-h2">Built for law firms that are <em>serious about organic growth.</em></h2>
        <div class="ideal-list">
          {idealClients.map((c, i) => (
            <div class={`ideal-item rxl d${i + 1}`}>
              <div class="ideal-check">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <p>{c}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <FaqSection items={faqs} heading="Questions About Always Publishing. Always Ranking." />

    <!-- Engagement Options -->
    <section class="apr-section" style="background: var(--ink); padding: 96px 0;">
      <div class="w" style="max-width: 900px; margin: 0 auto;">
        <p style="font-family: var(--man); font-size: 11px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--glt); text-align: center; margin-bottom: 12px;">How We Work Together</p>
        <h2 style="font-size: clamp(28px, 4vw, 42px); font-weight: 800; color: var(--white); text-align: center; margin: 0 0 64px; line-height: 1.15;">Engagement Options</h2>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">

          <!-- Build & Launch -->
          <div style="border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; padding: 36px; background: rgba(255,255,255,0.03);">
            <p style="font-family: var(--man); font-size: 11px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--glt); margin: 0 0 12px;">One-Time</p>
            <h3 style="font-size: 24px; font-weight: 800; color: var(--white); margin: 0 0 8px;">Build &amp; Launch</h3>
<p style="font-size: 14px; color: rgba(255,255,255,0.45); margin: 0 0 28px;">Priced based on your firm's size and site setup. Schedule a call to discuss.</p>
            <ul style="list-style: none; padding: 0; margin: 0 0 32px; display: flex; flex-direction: column; gap: 10px;">
              <li style="font-size: 15px; color: rgba(255,255,255,0.75); display: flex; gap: 10px;"><span style="color: var(--glt); flex-shrink: 0;">✓</span> Content engine setup &amp; 90-day topic queue</li>
              <li style="font-size: 15px; color: rgba(255,255,255,0.75); display: flex; gap: 10px;"><span style="color: var(--glt); flex-shrink: 0;">✓</span> Twitter/X &amp; LinkedIn automation</li>
              <li style="font-size: 15px; color: rgba(255,255,255,0.75); display: flex; gap: 10px;"><span style="color: var(--glt); flex-shrink: 0;">✓</span> SEO infrastructure (schema, redirects, sitemaps)</li>
              <li style="font-size: 15px; color: rgba(255,255,255,0.75); display: flex; gap: 10px;"><span style="color: var(--glt); flex-shrink: 0;">✓</span> Location landing pages for every market you serve</li>
              <li style="font-size: 15px; color: rgba(255,255,255,0.75); display: flex; gap: 10px;"><span style="color: var(--glt); flex-shrink: 0;">✓</span> Lead magnet page with email capture</li>
              <li style="font-size: 15px; color: rgba(255,255,255,0.75); display: flex; gap: 10px;"><span style="color: var(--glt); flex-shrink: 0;">✓</span> Voice calibration &amp; onboarding</li>
            </ul>
            <a href="/contact/" style="display: inline-flex; align-items: center; gap: 8px; background: var(--glt); color: var(--ink); font-family: var(--man); font-weight: 700; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; padding: 14px 24px; border-radius: 2px; text-decoration: none;">Schedule a Call →</a>
          </div>

          <!-- Managed Operations -->
          <div style="border: 1px solid rgba(200,151,58,0.35); border-radius: 4px; padding: 36px; background: rgba(200,151,58,0.05); position: relative;">
            <div style="position: absolute; top: -12px; left: 32px; background: var(--glt); color: var(--ink); font-family: var(--man); font-weight: 700; font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; padding: 4px 12px; border-radius: 2px;">Most Popular</div>
            <p style="font-family: var(--man); font-size: 11px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--glt); margin: 0 0 12px;">Monthly Retainer</p>
            <h3 style="font-size: 24px; font-weight: 800; color: var(--white); margin: 0 0 8px;">Managed Operations</h3>
<p style="font-size: 14px; color: rgba(255,255,255,0.45); margin: 0 0 28px;">Custom monthly retainer. Cancel anytime with 30 days notice.</p>
            <ul style="list-style: none; padding: 0; margin: 0 0 32px; display: flex; flex-direction: column; gap: 10px;">
              <li style="font-size: 15px; color: rgba(255,255,255,0.75); display: flex; gap: 10px;"><span style="color: var(--glt); flex-shrink: 0;">✓</span> Daily publishing runs (blog + image + Twitter + LinkedIn)</li>
              <li style="font-size: 15px; color: rgba(255,255,255,0.75); display: flex; gap: 10px;"><span style="color: var(--glt); flex-shrink: 0;">✓</span> Monthly content queue refresh</li>
              <li style="font-size: 15px; color: rgba(255,255,255,0.75); display: flex; gap: 10px;"><span style="color: var(--glt); flex-shrink: 0;">✓</span> SEO performance monitoring</li>
              <li style="font-size: 15px; color: rgba(255,255,255,0.75); display: flex; gap: 10px;"><span style="color: var(--glt); flex-shrink: 0;">✓</span> Social account health &amp; token maintenance</li>
              <li style="font-size: 15px; color: rgba(255,255,255,0.75); display: flex; gap: 10px;"><span style="color: var(--glt); flex-shrink: 0;">✓</span> Monthly performance report</li>
              <li style="font-size: 15px; color: rgba(255,255,255,0.75); display: flex; gap: 10px;"><span style="color: var(--glt); flex-shrink: 0;">✓</span> Platform updates as APIs change</li>
            </ul>
            <a href="/contact/" style="display: inline-flex; align-items: center; gap: 8px; background: var(--glt); color: var(--ink); font-family: var(--man); font-weight: 700; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; padding: 14px 24px; border-radius: 2px; text-decoration: none;">Schedule a Call →</a>
          </div>

        </div>

        <p style="text-align: center; font-size: 13px; color: rgba(255,255,255,0.3); margin-top: 32px;">API costs (~$40–80/month depending on usage) are passed through at cost. You own everything.</p>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="apr-bottom-cta">
      <div class="w">
        <div class="bottom-cta-inner rx">
          <p class="bottom-cta-eyebrow">Ready when you are</p>
          <h2 class="bottom-cta-heading">Stop being invisible. <em>Start publishing tomorrow.</em></h2>
          <p class="bottom-cta-body">Most firms talk about content marketing for years before doing anything about it. This is the version where you actually do it.</p>
          <a href="/contact/" class="bottom-cta-btn">Schedule a Free Strategy Call →</a>
        </div>
      </div>
    </section>
  </div>

  <Footer />

  <style>
    .apr-page {
      background: var(--ink);
    }

    .apr-section {
      padding: 96px 0;
      background: var(--ink);
      color: var(--white);
      position: relative;
      overflow: hidden;
    }

    .apr-section.alt {
      background: #0B1825;
      border-top: 1px solid rgba(200, 151, 58, 0.1);
      border-bottom: 1px solid rgba(200, 151, 58, 0.1);
    }

    .apr-section .w.narrow {
      max-width: 820px;
    }

    .apr-h2 {
      font-family: var(--man);
      font-size: clamp(28px, 4vw, 44px);
      font-weight: 800;
      color: var(--white);
      line-height: 1.15;
      letter-spacing: -0.02em;
      margin-bottom: 48px;
      max-width: 880px;
    }

    .apr-h2 em {
      color: var(--glt);
      font-style: italic;
      font-family: var(--bas);
      font-weight: 400;
    }

    /* ── Problem grid ─────────────────────────────────────── */
    .problem-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
    }

    .problem-card {
      background: rgba(255, 255, 255, 0.025);
      border: 1px solid rgba(200, 151, 58, 0.15);
      border-radius: 4px;
      padding: 36px 32px;
      transition: border-color 0.25s, transform 0.25s, background 0.25s;
    }

    .problem-card:hover {
      border-color: var(--gold);
      background: rgba(200, 151, 58, 0.04);
      transform: translateY(-3px);
    }

    .problem-num {
      font-family: var(--bar);
      font-size: 22px;
      font-weight: 800;
      color: var(--glt);
      margin-bottom: 16px;
      letter-spacing: 0.05em;
    }

    .problem-card h3 {
      font-size: 19px;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 12px;
      line-height: 1.3;
    }

    .problem-card p {
      font-size: 14.5px;
      color: rgba(255, 255, 255, 0.65);
      line-height: 1.7;
    }

    /* ── Bar Compliance ───────────────────────────────────── */
    .apr-section.compliance {
      background: #0A1320;
      border-top: 1px solid rgba(200, 151, 58, 0.18);
      border-bottom: 1px solid rgba(200, 151, 58, 0.18);
      position: relative;
    }

    .apr-section.compliance::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 15% 20%, rgba(200, 151, 58, 0.08) 0%, transparent 45%),
                  radial-gradient(circle at 85% 80%, rgba(200, 151, 58, 0.06) 0%, transparent 50%);
      pointer-events: none;
    }

    .apr-section.compliance .w { position: relative; z-index: 1; }

    .compliance-eyebrow {
      font-family: var(--man);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--glt);
      margin-bottom: 16px;
    }

    .compliance-lede {
      font-size: 17px;
      color: rgba(255, 255, 255, 0.72);
      line-height: 1.7;
      max-width: 820px;
      margin: -24px 0 56px;
    }

    .compliance-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 28px;
      margin-bottom: 48px;
    }

    .compliance-card {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(200, 151, 58, 0.22);
