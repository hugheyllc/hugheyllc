---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import FaqSection from '../../components/FaqSection.astro';
import Footer from '../../components/Footer.astro';

const faqs = [
  { q: 'What is law firm intake optimization?', a: 'Law firm intake optimization is the process of redesigning the workflow from a prospect\'s first contact with your firm to the moment they sign a retainer. This includes auditing how quickly leads are followed up, how they are qualified, what technology handles routing and scheduling, and how your intake team is trained. Most firms lose 30–40% of qualified leads in this window.' },
  { q: 'What percentage of law firm leads are lost before signing?', a: 'Industry data and our client work consistently show that 30–40% of qualified leads — people who contacted the firm and were a good fit — do not become retained clients due to intake process failures. The most common causes are slow follow-up (more than 5 minutes to first contact dramatically reduces conversion), poor qualification scripts, and manual scheduling friction.' },
  { q: 'What technology does a law firm need for intake optimization?', a: 'Most firms benefit from a dedicated legal CRM (such as Lawmatics or Clio Grow), a call tracking system (such as CallRail), automated follow-up sequences, and an online scheduling tool. The specific stack depends on your practice area, volume, and existing systems. We recommend technology based on your situation, not on partnerships.' },
  { q: 'How long does it take to see results from intake optimization?', a: 'Most firms see measurable improvement in form-to-consultation conversion rates within 30–60 days of implementing intake changes. The full impact, including the downstream effect on retained client numbers, is typically visible within 90 days.' },
];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Intake Process Optimization for Law Firms",
  "description": "Redesign your intake process to convert more leads to clients. Faster qualification. Better data. Higher conversion rates.",
  "provider": { "@type": "Organization", "name": "Hughey LLC", "url": "https://hugheyllc.com" },
  "areaServed": { "@type": "Country", "name": "United States" },
  "url": "https://hugheyllc.com/services/intake-process-optimization/"
};

const schema = [
  serviceSchema,
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://hugheyllc.com" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://hugheyllc.com/services" },
      { "@type": "ListItem", "position": 3, "name": "Intake Optimization", "item": "https://hugheyllc.com/services/intake-process-optimization" }
    ]
  }
];

const problemPoints = [
  '20 leads drop off because your intake form is too long',
  '15 leads are lost in the gap between form submission and phone call',
  '10 leads fall through because phone intake isn\'t consistent',
  '8 leads aren\'t followed up on because they\'re in multiple systems',
];

const outcomes = [
  '25-30% improvement in form-to-phone conversion',
  '15-20% improvement in phone-to-consultation conversion',
  'Intake team that\'s less overwhelmed and more organized',
  'Better data about prospect quality that feeds back to marketing',
  'On a 100-lead-per-month firm, that\'s 10-15 additional retained clients per month from the same marketing budget',
];
---

<BaseLayout
  title="Intake Process Optimization for Law Firms | Hughey LLC"
  description="Redesign your intake process to convert more leads to clients. Faster qualification. Better data. Higher conversion rates."
  canonical="https://hugheyllc.com/services/intake-process-optimization/"
  schema={schema}
>
  <div>
    <PageHero eyebrow="Service" heading="Intake Process<br /><em>Optimization</em>" subheading="We redesign your intake workflow, implement technology, and train your team to convert more prospects into clients." />

    <!-- Light content section -->
    <div style="background: var(--page); padding: 80px 0 0;">
      <div class="w">

        <!-- The Problem -->
        <section class="problem-section rx">
          <div class="problem-label">
            <span class="section-accent"></span>
            <h2 class="section-heading">The Problem</h2>
          </div>
          <div class="section-body">
            <p>Your marketing is driving 100 leads per month. But:</p>
            <ul class="problem-list">
              {problemPoints.map(item => (
                <li>
                  <span class="outcome-arrow">→</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
            <p>You're wasting 53% of your marketing budget. And even worse, you have no data about what type of prospect actually becomes a retained client—so you can't optimize your marketing to attract better prospects.</p>
          </div>
        </section>

        <!-- What We Do -->
        <section class="work-section rx">
          <span class="section-accent"></span>
          <h2 class="section-heading">What We Do</h2>
          <div class="work-grid">
            <div class="work-card rxl d1">
              <h3>Audit Current Process</h3>
              <p>We examine your forms, phone intake, coordinators, follow-up process, and CRM. We identify where leads are lost and why.</p>
            </div>
            <div class="work-card rxl d2">
              <h3>Redesign Workflow</h3>
              <p>We create a new intake process optimized for conversion: shorter forms, faster phone contact, consistent qualification, better data capture.</p>
            </div>
            <div class="work-card rxl d3">
              <h3>Implement Technology</h3>
              <p>We set up CRM, intake forms, phone systems, and integrations so data flows automatically and coordinators have all information they need.</p>
            </div>
            <div class="work-card rxl d4">
              <h3>Train Your Team</h3>
              <p>We train coordinators on the new process and tools. We document the workflow. We set up metrics to track performance.</p>
            </div>
          </div>
        </section>

        <!-- The Outcome -->
        <section class="outcome-section rx">
          <span class="section-accent"></span>
          <h2 class="section-heading">The Outcome</h2>
          <ul class="outcome-list">
            {outcomes.map(item => (
              <li>
                <span class="outcome-arrow">→</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </section>

      </div>
    </div>

    <!-- FAQ -->
    <FaqSection items={faqs} heading="Questions About Law Firm Intake Optimization" />

    <!-- CTA band -->
    <div style="background: var(--page); padding: 0 0 96px;">
      <div class="w">
        <div class="cta-band rx">
          <div class="cta-inner">
            <p class="cta-eyebrow">Let's optimize your intake</p>
            <h3 class="cta-heading">Schedule a free consultation to review your current intake process.</h3>
            <a href="/contact/" class="cta-btn">Schedule a Call →</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <Footer />

  <style>
    /* Problem (two-column) */
    .problem-section {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 64px;
      padding: 64px 0;
      border-bottom: 1px solid var(--bdr);
      align-items: start;
    }

    .section-heading {
      font-size: 28px;
      font-weight: 800;
      color: var(--ink);
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin-top: 12px;
    }

    .section-body p {
      font-size: 15px;
      line-height: 1.8;
      color: var(--sub);
      margin-bottom: 18px;
    }

    .section-body p:last-child { margin-bottom: 0; }

    .problem-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 18px;
    }

    .problem-list li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 15px;
      color: var(--sub);
      line-height: 1.6;
    }

    /* What We Do */
    .work-section {
      padding: 64px 0;
      border-bottom: 1px solid var(--bdr);
    }

    .work-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
      margin-top: 40px;
    }

    .work-card {
      background: var(--white);
      border: 1px solid var(--bdr);
      border-radius: 4px;
      padding: 28px 32px;
      transition: border-color 0.25s, box-shadow 0.25s, transform 0.25s;
    }

    .work-card:hover {
      border-color: var(--gold);
      box-shadow: 0 8px 32px rgba(0,0,0,0.07);
      transform: translateY(-3px);
    }

    .work-card h3 {
      font-size: 16px;
      font-weight: 700;
      color: var(--gold);
      margin-bottom: 10px;
    }

    .work-card p {
      font-size: 14px;
      color: var(--sub);
      line-height: 1.65;
    }

    /* Outcome */
    .outcome-section {
      padding: 64px 0;
      border-bottom: 1px solid var(--bdr);
    }

    .outcome-list {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 14px;
      margin-top: 32px;
    }

    .outcome-list li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      font-size: 15px;
      color: var(--sub);
      line-height: 1.6;
    }

    .outcome-arrow {
      color: var(--gold);
      font-weight: 700;
      flex-shrink: 0;
      margin-top: 1px;
    }

    /* CTA band */
    .cta-band {
      background: var(--ink);
      border-radius: 6px;
      overflow: hidden;
      position: relative;
      margin-top: 80px;
    }

    .cta-band::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 80% 50%, rgba(200,151,58,0.12) 0%, transparent 60%);
    }

    .cta-inner { padding: 56px 64px; position: relative; z-index: 1; }

    .cta-eyebrow {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(200,151,58,0.7);
      margin-bottom: 12px;
    }

    .cta-heading {
      font-size: clamp(20px, 2.5vw, 28px);
      font-weight: 800;
      color: var(--white);
      margin-bottom: 28px;
      line-height: 1.3;
      max-width: 560px;
    }

    .cta-btn {
      display: inline-flex;
      align-items: center;
      background: var(--gold);
      color: var(--ink);
      font-family: var(--man);
      font-weight: 800;
      font-size: 13px;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      padding: 16px 32px;
      border-radius: 2px;
      text-decoration: none;
      transition: background 0.2s, transform 0.2s;
      box-shadow: 0 4px 24px rgba(200,151,58,0.35);
    }

    .cta-btn:hover { background: var(--glt); transform: translateY(-1px); }

    @media (max-width: 900px) {
      .problem-section { grid-template-columns: 1fr; gap: 24px; }
      .work-grid { grid-template-columns: 1fr; }
      .cta-inner { padding: 40px 28px; }
    }
  </style>
</BaseLayout>
