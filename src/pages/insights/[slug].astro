---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const insights = await getCollection('insights');
  return insights.map((insight) => ({
    params: { slug: insight.data.slug },
    props: { insight },
  }));
}

interface Props {
  insight: any;
}

const { insight } = Astro.props;
const { Content } = await render(insight);
const { title, excerpt } = insight.data;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": excerpt,
  "datePublished": insight.data.date ? new Date(insight.data.date).toISOString() : new Date().toISOString(),
  "author": { "@type": "Person", "name": "Joe Hughey", "url": "https://hugheyllc.com/about" },
  "publisher": { "@type": "Organization", "name": "Hughey LLC", "url": "https://hugheyllc.com" },
  "mainEntityOfPage": { "@type": "WebPage", "@id": `https://hugheyllc.com/insights/${insight.data.slug}/` }
};
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://hugheyllc.com" },
    { "@type": "ListItem", "position": 2, "name": "Insights", "item": "https://hugheyllc.com/insights" },
    { "@type": "ListItem", "position": 3, "name": title, "item": `https://hugheyllc.com/insights/${insight.data.slug}/` }
  ]
};
---

<BaseLayout
  title={`${title} | Hughey LLC`}
  description={excerpt}
  canonical={`https://hugheyllc.com/insights/${insight.data.slug}`}
  schema={[articleSchema, breadcrumbSchema]}
>
  <div>
    <PageHero heading={title} subheading={excerpt} />

    <div style="background: var(--page); padding: 72px 0 0;">
      <div class="w">

        <div class="back-link rx">
          <a href="/insights/">← Back to Insights</a>
        </div>

        <div class="prose rx">
          <Content />
        </div>

      </div>
    </div>

    <!-- CTA band -->
    <div style="background: var(--page); padding: 0 0 96px;">
      <div class="w">
        <div class="cta-band rx">
          <div class="cta-inner">
            <p class="cta-eyebrow">Let's talk about your firm</p>
            <h3 class="cta-heading">Schedule a free strategy call — no pitch, just an honest conversation.</h3>
            <a href="/contact/" class="cta-btn">Schedule a Free Strategy Call →</a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <Footer />

  <style>
    /* Back link */
    .back-link { padding: 0 0 32px; }
    .back-link a { font-family: var(--man); font-size: 13px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--gold); text-decoration: none; transition: color 0.2s; }
    .back-link a:hover { color: var(--ink); }

    /* Prose */
    .prose {
      max-width: 760px;
      font-size: 17px;
      line-height: 1.85;
      color: var(--ink);
      padding-bottom: 80px;
      border-bottom: 1px solid var(--bdr);
      margin-bottom: 80px;
    }
    .prose :global(h2) { font-size: clamp(22px,2.8vw,32px); font-weight: 800; margin-top: 52px; margin-bottom: 18px; color: var(--ink); line-height: 1.2; letter-spacing: -0.02em; }
    .prose :global(h3) { font-size: clamp(18px,2.2vw,24px); font-weight: 700; margin-top: 40px; margin-bottom: 14px; color: var(--ink); line-height: 1.3; }
    .prose :global(h4) { font-size: 18px; font-weight: 700; margin-top: 32px; margin-bottom: 12px; color: var(--ink); }
    .prose :global(p) { margin-bottom: 22px; }
    .prose :global(ul), .prose :global(ol) { margin-bottom: 22px; padding-left: 28px; }
    .prose :global(li) { margin-bottom: 10px; color: var(--ink); }
    .prose :global(a) { color: var(--gold); text-decoration: underline; text-underline-offset: 3px; transition: color 0.2s; }
    .prose :global(a:hover) { color: var(--ink); }
    .prose :global(strong) { font-weight: 700; color: var(--ink); }
    .prose :global(em) { font-style: italic; color: rgba(0,0,0,0.7); }
    .prose :global(blockquote) { border-left: 3px solid var(--gold); padding: 16px 24px; margin: 32px 0; background: rgba(200,151,58,0.06); border-radius: 0 4px 4px 0; color: rgba(0,0,0,0.7); font-style: italic; }
    .prose :global(hr) { border: none; border-top: 1px solid var(--bdr); margin: 44px 0; }

    /* CTA band */
    .cta-band { background: var(--ink); border-radius: 4px; padding: 64px; position: relative; overflow: hidden; }
    .cta-band::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse at 60% 50%, rgba(200,151,58,0.18) 0%, transparent 70%); pointer-events: none; }
    .cta-inner { position: relative; z-index: 1; max-width: 600px; }
    .cta-eyebrow { font-family: var(--man); font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--gold); margin-bottom: 16px; }
    .cta-heading { font-size: clamp(22px,3vw,32px); font-weight: 800; color: var(--white); line-height: 1.25; margin-bottom: 32px; letter-spacing: -0.02em; }
    .cta-btn { display: inline-flex; align-items: center; gap: 8px; background: var(--gold); color: var(--ink); font-family: var(--man); font-weight: 800; font-size: 13px; letter-spacing: 0.07em; text-transform: uppercase; padding: 16px 32px; border-radius: 2px; text-decoration: none; transition: all 0.25s; box-shadow: 0 4px 28px rgba(200,151,58,0.35); }
    .cta-btn:hover { background: var(--glt); transform: translateY(-1px); box-shadow: 0 6px 36px rgba(200,151,58,0.5); }

    /* Animations */
    .rx { opacity: 0; transform: translateY(18px); animation: fadeUp 0.55s ease forwards; }
    @keyframes fadeUp { to { opacity: 1; transform: none; } }

    @media (max-width: 700px) {
      .cta-band { padding: 40px 28px; }
    }
  </style>
</BaseLayout>
