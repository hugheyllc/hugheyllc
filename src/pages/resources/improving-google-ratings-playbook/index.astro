---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHero from '../../../components/PageHero.astro';
import Footer from '../../../components/Footer.astro';

const chapters = [
  { num: '01', title: 'Why Google Ratings Matter (And What They Actually Move)', body: 'Visibility in local search, click-through rate lift, and the research proving one point on your rating moves the needle on calls and retained clients.' },
  { num: '02', title: 'The Three-Touch Review Request System', body: 'The exact timing, templates, and cadence for requesting reviews--email at 24-48h, SMS at 7 days, in-person ask at closing. Plus the vanity URL setup.' },
  { num: '03', title: 'Responding to Negative Reviews Without Legal Liability', body: 'The four-part response framework that is professional, compliant, and moves the conversation offline. Plus the legal red lines that get firms in trouble.' },
  { num: '04', title: 'Disputing Reviews: Which Violations Actually Stick', body: 'Which policy violations trigger removal vs. waste your time. Conflict-of-interest detection. Step-by-step flag process.' },
  { num: '05', title: 'Building Review Velocity Over 6-12 Months', body: 'The realistic timeline from 3.5 stars to 4.2+. Month-by-month progression. The velocity benchmarks that tell you when you are on track.' },
  { num: '06', title: 'Compliance: Bar Rules and Google Guidelines', body: 'What you can and cannot do with review incentives. Response requirements. What to check with your state bar.' },
  { num: '07', title: 'Tracking and Reporting', body: 'Metrics that matter. When to scale. How to prove it is working to the partner group.' },
];

const appendices = [
  'Appendix A — Email & SMS Request Templates (copy/paste, bar-compliant)',
  'Appendix B — Response Template Library (positive, negative, neutral scenarios)',
];

const outcomes = [
  'Set up the three-touch review request system with email, SMS, and in-person asks.',
  'Deploy a bar-compliant response framework that handles negative reviews professionally.',
  'Understand which review disputes actually work and which ones waste your time.',
  'Build realistic review velocity--3-8 per month--and know when you are on track.',
  'Create a sustainable system that improves your rating from 3.5 to 4.2+ in 6-12 months.',
  'Maintain your rating indefinitely with a documented monthly process.',
  'Show the partner group what the system is producing with clear metrics.',
];

const faqs = [
  { q: 'Who is this playbook for?', a: 'Law firms with a Google rating below 4.0 or fewer than 20 reviews. It is written for the office manager, marketing coordinator, or anyone managing client relations. No technical expertise required--just the willingness to ask clients for reviews and respond to them consistently.' },
  { q: 'How long does it take to work through?', a: 'The initial setup (vanity URL, email template, SMS cadence) takes 2-3 hours. After that, the monthly maintenance is 30-45 minutes--requests, responses, and occasional dispute flagging.' },
  { q: 'Can we actually improve from 3.5 to 4.2 stars?', a: 'Yes. Consistent review requests (3-8/month) compounded over 6-12 months will move your rating. The timeline depends on your current review count and consistency of execution.' },
  { q: 'What if we don\'t have a lot of cases per month?', a: 'Solo and small firms with 5-10 cases/month can sustain 3-5 review requests per month (30-50% of cases) indefinitely. That velocity maintains a 4.0+ rating. Larger firms target 6-8/month for upward momentum.' },
  { q: 'Does this cover bar compliance?', a: 'Yes. Chapter 6 walks through incentive rules, response requirements, and how to check with your specific state bar. Review management is tightly regulated, and the playbook keeps you legal.' },
  { q: 'Can we really remove negative reviews?', a: 'Only if they violate Google\'s specific policies--conflict of interest, spam, hate speech, impersonation, off-topic content. Most negative reviews won\'t qualify. The playbook tells you which violations stick and which are waste of effort.' },
  { q: 'What format is the playbook?', a: 'A single HTML page--clean design, print-ready. Bookmark it for reference. Use your browser\'s Print → Save as PDF if you prefer a local copy.' },
  { q: 'How do I get it after I submit the form?', a: 'An email arrives immediately with your download link and a copy of the playbook content. If anything goes wrong, email joe@hugheyllc.com.' },
];

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://hugheyllc.com" },
    { "@type": "ListItem", "position": 2, "name": "Resources", "item": "https://hugheyllc.com/resources/" },
    { "@type": "ListItem", "position": 3, "name": "Improving Google Ratings Playbook", "item": "https://hugheyllc.com/resources/improving-google-ratings-playbook/" }
  ]
};

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "The Law Firm Playbook for Improving Your Google Rating (And Handling Bad Reviews Ethically)",
  "description": "Free playbook: the complete system for building review velocity, responding to negative reviews without legal liability, and improving your Google rating from 3.5 to 4.2+ in 6-12 months.",
  "author": {
    "@type": "Person",
    "name": "Joe Hughey",
    "url": "https://hugheyllc.com/about/"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Hughey LLC",
    "url": "https://hugheyllc.com"
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": "https://hugheyllc.com/resources/improving-google-ratings-playbook/" }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
};
---

<BaseLayout
  title="Free Playbook: Improve Your Law Firm's Google Rating | Hughey LLC"
  description="Free playbook: the complete system for building review velocity, handling bad reviews ethically, and improving your Google rating from 3.5 to 4.2+ in 6-12 months. Email-gated."
  canonical="https://hugheyllc.com/resources/improving-google-ratings-playbook/"
  schema={[articleSchema, breadcrumbSchema, faqSchema]}
>
  <div style="background: var(--ink); color: var(--white); min-height: 100vh;">
    <PageHero
      eyebrow="Free Resource"
      heading="Your Google Rating Is<br /><em>Leaving Money on the Table</em>"
      subheading="A complete system for building review velocity, responding to negative reviews without legal liability, and improving your rating from 3.5 to 4.2+ in 6-12 months. Seven chapters, two appendices, every template you need."
    />

    <!-- Lead capture + preview -->
    <div style="padding: 64px 0;">
      <div class="w">
        <div class="lm-grid">

          <!-- Left: Form + Description -->
          <div>
            <p class="lm-intro">Most law firms treat Google ratings like they happen naturally. They don\'t. The firms that win are the ones with a system--a documented process for requesting reviews from satisfied clients, a framework for responding to bad reviews without violating bar rules, and a clear understanding of which disputes actually work. This playbook is that system.</p>

            <ul class="lm-bullets">
              <li>Seven chapters covering the complete review lifecycle</li>
              <li>Exact templates, timing, and cadence for requesting reviews</li>
              <li>The four-part negative review response framework (bar-compliant)</li>
              <li>Which review disputes actually succeed vs. waste your time</li>
              <li>Realistic 6-12 month timeline from 3.5 to 4.2+ stars</li>
              <li>Free. Delivered to your inbox in under a minute.</li>
            </ul>

            <form id="checklistForm" class="lm-form" novalidate>
              <div class="field-group">
                <label for="cl-name">Name *</label>
                <input type="text" id="cl-name" name="name" required autocomplete="name" />
              </div>
              <div class="field-group">
                <label for="cl-email">Email *</label>
                <input type="email" id="cl-email" name="email" required autocomplete="email" />
              </div>
              <input type="text" id="cl-honeypot" name="honeypot" style="display:none;" tabindex="-1" autocomplete="off" />

              <div id="cl-status" style="display:none;" role="alert"></div>

              <button type="submit" id="cl-submit">Get the Free Playbook →</button>

              <p class="lm-fine">No spam. No drip sequences. We may send you one occasional update — unsubscribe any time.</p>
            </form>
          </div>

          <!-- Right: Preview -->
          <div class="lm-preview-wrap">
            <div class="lm-preview">
              <div class="lm-preview-head">
                <span class="lm-tag">Preview</span>
                <h3>Improving Google<br /><em>Ratings</em></h3>
              </div>

              <div class="lm-preview-section">
                <h4>Seven Chapters</h4>
                <ol>
                  {chapters.slice(0, 4).map(c => <li><strong>{c.title}</strong></li>)}
                  <li style="opacity: 0.5;">+ 3 more chapters</li>
                </ol>
              </div>

              <div class="lm-preview-locked">
                <div class="lm-locked-content">
                  <div class="lm-locked-section">
                    <h4>Chapter 2: Three-Touch Request System</h4>
                    <ol>
                      <li>Email template (24-48h after case close)...</li>
                      <li>SMS follow-up (7 days if no review)...</li>
                      <li>In-person ask at final meeting...</li>
                    </ol>
                  </div>
                  <div class="lm-locked-section">
                    <h4>Chapter 3: Negative Review Response Framework</h4>
                    <ol>
                      <li>Four-part response (acknowledgment → resolve → context → commitment)...</li>
                      <li>Legal red lines (what NOT to do)...</li>
                    </ol>
                  </div>
                  <div class="lm-locked-section">
                    <h4>Chapter 4: Which Disputes Actually Work</h4>
                    <ol>
                      <li>Policy violations that trigger removal...</li>
                      <li>Step-by-step flag process...</li>
                    </ol>
                  </div>
                </div>
                <div class="lm-locked-overlay">
                  <div class="lm-locked-message">
                    <p class="lm-locked-title">+ 4 more chapters</p>
                    <p class="lm-locked-sub">Enter your email to unlock the full playbook.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- What's Inside -->
    <section style="padding: 80px 0; background: rgba(200, 151, 58, 0.04); border-top: 1px solid rgba(200, 151, 58, 0.15); border-bottom: 1px solid rgba(200, 151, 58, 0.15);">
      <div class="w">
        <div style="text-align: center; margin-bottom: 60px;">
          <p style="font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--glt); font-weight: 800; margin-bottom: 16px;">What's Inside</p>
          <h2 style="font-size: clamp(28px, 5vw, 44px); font-weight: 800; margin: 0;">Seven chapters.<br /><em>Built to be executed in order.</em></h2>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 24px; margin-bottom: 48px;">
          {chapters.map((c, i) => (
            <div style={`padding: 32px; background: rgba(200, 151, 58, 0.08); border: 1px solid rgba(200, 151, 58, 0.15); border-radius: 4px; display: flex; flex-direction: column; gap: 12px;`}>
              <div style="font-size: 32px; font-weight: 800; color: var(--glt);">{c.num}</div>
              <h3 style="font-size: 18px; font-weight: 700; color: var(--white); margin: 0; line-height: 1.4;">{c.title}</h3>
              <p style="font-size: 15px; color: rgba(255,255,255,0.7); margin: 0; line-height: 1.6;">{c.body}</p>
            </div>
          ))}
        </div>

        <div style="padding: 32px; background: rgba(200, 151, 58, 0.08); border: 1px solid rgba(200, 151, 58, 0.15); border-radius: 4px;">
          <p style="font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--glt); font-weight: 800; margin-bottom: 16px; margin-top: 0;">Plus two appendices</p>
          <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px;">
            {appendices.map(a => (
              <li style="display: flex; align-items: flex-start; gap: 12px; font-size: 15px; color: rgba(255,255,255,0.8);">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; margin-top: 3px; color: var(--glt);"><polyline points="20 6 9 17 4 12"/></svg>
                <span>{a}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- What you'll be able to do -->
    <section style="padding: 80px 0;">
      <div class="w">
        <div style="text-align: center; margin-bottom: 60px;">
          <p style="font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--glt); font-weight: 800; margin-bottom: 16px;">What you'll be able to do after</p>
          <h2 style="font-size: clamp(28px, 5vw, 44px); font-weight: 800; margin: 0;">Build a system that works.<br /><em>Month after month.</em></h2>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px;">
          {outcomes.map((o, i) => (
            <div style={`padding: 24px; background: rgba(200, 151, 58, 0.04); border: 1px solid rgba(200, 151, 58, 0.15); border-radius: 4px; display: flex; gap: 16px; align-items: flex-start;`}>
              <div style="flex-shrink: 0; width: 20px; height: 20px; background: var(--glt); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-top: 2px;">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--ink)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <p style="font-size: 15px; color: rgba(255,255,255,0.85); margin: 0; line-height: 1.6;">{o}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Who it's for -->
    <section style="padding: 80px 0; background: rgba(200, 151, 58, 0.04); border-top: 1px solid rgba(200, 151, 58, 0.15); border-bottom: 1px solid rgba(200, 151, 58, 0.15);">
      <div class="w" style="max-width: 800px;">
        <p style="font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--glt); font-weight: 800; margin-bottom: 16px; text-align: center;">Who it\'s for</p>
        <h2 style="font-size: clamp(28px, 5vw, 40px); font-weight: 800; text-align: center; margin-bottom: 32px;"><em>Built for firms</em> that want to do this themselves.</h2>
        <p style="font-size: 16px; color: rgba(255,255,255,0.78); line-height: 1.8; margin-bottom: 20px;">If your firm has a Google rating below 4.0 or fewer than 20 reviews, this playbook gives you the system to fix it. One capable person--office manager, marketing coordinator, or partner--can run this end-to-end.</p>
        <p style="font-size: 16px; color: rgba(255,255,255,0.78); line-height: 1.8; margin-bottom: 0;">If you\'d rather pay someone else to manage your reputation, that\'s a fair choice. If you want to keep the knowledge inside your firm, build review velocity yourself, and maintain it in 30-45 minutes a month — this is for you.</p>
      </div>
    </section>

    <!-- Full playbook (revealed on success) -->
    <div id="fullChecklist" style="display:none; padding: 60px 0; background: rgba(200, 151, 58, 0.04); border-top: 1px solid rgba(200, 151, 58, 0.15);">
      <div class="w">
        <div style="max-width: 920px; margin: 0 auto;">
          <h2 style="font-size: clamp(28px, 4vw, 40px); font-weight: 800; margin-bottom: 12px;">The Full Playbook</h2>
          <p style="font-size: 16px; color: rgba(255,255,255,0.7); line-height: 1.7; margin-bottom: 40px;">A copy is also in your inbox — but you can start here.</p>

          <div style="padding: 32px; background: rgba(200, 151, 58, 0.1); border: 1px solid rgba(200, 151, 58, 0.2); border-radius: 4px; margin-bottom: 40px;">
            <p style="margin: 0; font-size: 16px; color: rgba(255,255,255,0.85); line-height: 1.7;">The full playbook content will render here after you submit the form. For now, you can check your email for the complete resource.</p>
          </div>

          <div style="margin-top: 56px; padding: 32px; background: rgba(200, 151, 58, 0.08); border: 1px solid rgba(200, 151, 58, 0.2); border-radius: 4px; text-align: center;">
            <h3 style="font-size: 22px; font-weight: 800; margin-bottom: 12px;">Ready to build this into your firm?</h3>
            <p style="font-size: 15px; color: rgba(255,255,255,0.7); margin-bottom: 24px; line-height: 1.7;">Book a free strategy call. We\'ll walk through where your firm is today, what\'s worth fixing first, and whether you should do it in-house or bring in help.</p>
            <a href="/contact/" style="display: inline-flex; align-items: center; gap: 9px; background: var(--gold); color: var(--ink); font-family: var(--man); font-weight: 800; font-size: 13px; letter-spacing: 0.07em; text-transform: uppercase; padding: 16px 34px; border-radius: 2px; text-decoration: none; transition: all 0.25s;">
              Schedule a Free Call →
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- FAQ -->
  <section style="padding: 80px 0; background: rgba(200, 151, 58, 0.04); border-top: 1px solid rgba(200, 151, 58, 0.15);">
    <div class="w" style="max-width: 800px;">
      <h2 style="font-size: clamp(28px, 5vw, 40px); font-weight: 800; margin-bottom: 48px;">Frequently Asked Questions</h2>
      <div style="display: flex; flex-direction: column; gap: 32px;">
        {faqs.map(faq => (
          <div>
            <h3 style="font-size: 18px; font-weight: 700; color: var(--glt); margin-bottom: 12px;">{faq.q}</h3>
            <p style="font-size: 15px; color: rgba(255,255,255,0.78); line-height: 1.8; margin: 0;">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />

  <script>
    const form = document.getElementById('checklistForm') as HTMLFormElement;
    const statusEl = document.getElementById('cl-status') as HTMLDivElement;
    const submitBtn = document.getElementById('cl-submit') as HTMLButtonElement;
    const fullList = document.getElementById('fullChecklist') as HTMLDivElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      statusEl.style.display = 'none';

      const data = {
        name: (form.querySelector('#cl-name') as HTMLInputElement).value.trim(),
        email: (form.querySelector('#cl-email') as HTMLInputElement).value.trim(),
        honeypot: (form.querySelector('#cl-honeypot') as HTMLInputElement).value,
      };

      try {
        const res = await fetch('/api/resources/google-ratings-playbook-download', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const result = await res.json();

        statusEl.style.display = 'block';
        if (result.success) {
          statusEl.className = 'status-success';
          statusEl.textContent = result.message || 'Sent. Check your inbox.';
          submitBtn.textContent = 'Sent ✓';
          fullList.style.display = 'block';
          fullList.scrollIntoView({ behavior: 'smooth', block: 'start' });
        } else {
          statusEl.className = 'status-error';
          statusEl.textContent = result.error || 'Something went wrong. Try again.';
          submitBtn.disabled = false;
          submitBtn.textContent = 'Get the Free Playbook →';
        }
      } catch {
        statusEl.style.display = 'block';
        statusEl.className = 'status-error';
        statusEl.textContent = 'Network error. Email joe@hugheyllc.com if the issue persists.';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Get the Free Playbook →';
      }
    });
  </script>

  <style>
    em { color: var(--glt); font-style: italic; }

    .lm-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: start;
      max-width: 1180px;
      margin: 0 auto;
    }

    .lm-intro {
      font-size: 17px;
      line-height: 1.75;
      color: rgba(255,255,255,0.78);
      margin-bottom: 28px;
    }

    .lm-bullets {
      list-style: none;
      padding: 0;
      margin: 0 0 36px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .lm-bullets li {
      position: relative;
      padding-left: 22px;
      font-size: 15px;
      color: rgba(255,255,255,0.7);
      line-height: 1.65;
    }

    .lm-bullets li:before {
      content: '✓';
      position: absolute;
      left: 0;
      color: var(--glt);
      font-weight: 800;
    }

    .lm-form {
      display: flex;
      flex-direction: column;
      gap: 16px;
      margin-bottom: 24px;
    }

    .field-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .field-group label {
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      color: rgba(255,255,255,0.9);
    }

    .field-group input {
      padding: 14px 16px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(200, 151, 58, 0.2);
      border-radius: 2px;
      color: var(--white);
      font-size: 15px;
      font-family: var(--mono);
      transition: all 0.25s;
    }

    .field-group input:focus {
      outline: none;
      background: rgba(255,255,255,0.12);
      border-color: var(--glt);
    }

    #cl-submit {
      padding: 16px 24px;
      background: var(--glt);
      color: var(--ink);
      border: none;
      border-radius: 2px;
      font-family: var(--man);
      font-weight: 800;
      font-size: 13px;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.25s;
    }

    #cl-submit:hover:not(:disabled) {
      background: #e8c547;
      transform: translateY(-2px);
    }

    #cl-submit:disabled {
      opacity: 0.65;
      cursor: not-allowed;
    }

    .lm-fine {
      font-size: 12px;
      color: rgba(255,255,255,0.5);
      margin: 0;
    }

    .lm-preview-wrap {
      position: relative;
    }

    .lm-preview {
      padding: 32px;
      background: rgba(200, 151, 58, 0.08);
      border: 1px solid rgba(200, 151, 58, 0.15);
      border-radius: 4px;
      position: relative;
      overflow: hidden;
    }

    .lm-preview-head {
      margin-bottom: 32px;
    }

    .lm-tag {
      display: inline-block;
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--glt);
      margin-bottom: 12px;
    }

    .lm-preview-head h3 {
      font-size: 24px;
      font-weight: 800;
      color: var(--white);
      margin: 0;
      line-height: 1.2;
    }

    .lm-preview-section {
      margin-bottom: 24px;
    }

    .lm-preview-section h4 {
      font-size: 14px;
      font-weight: 700;
      color: var(--glt);
      margin-bottom: 12px;
      margin-top: 0;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .lm-preview-section ol {
      margin: 0;
      padding-left: 20px;
      font-size: 14px;
      color: rgba(255,255,255,0.7);
      line-height: 1.6;
    }

    .lm-preview-section li {
      margin-bottom: 6px;
    }

    .lm-preview-locked {
      position: relative;
    }

    .lm-locked-content {
      opacity: 0.4;
      pointer-events: none;
      filter: blur(2px);
    }

    .lm-locked-overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(180deg, rgba(26,41,64,0) 0%, rgba(26,41,64,0.7) 60%, rgba(26,41,64,0.95) 100%);
      display: flex;
      align-items: flex-end;
      justify-content: center;
      padding: 32px;
      text-align: center;
    }

    .lm-locked-message {
      z-index: 1;
    }

    .lm-locked-title {
      font-size: 16px;
      font-weight: 800;
      color: var(--white);
      margin-bottom: 8px;
      margin-top: 0;
    }

    .lm-locked-sub {
      font-size: 14px;
      color: rgba(255,255,255,0.7);
      margin: 0;
    }

