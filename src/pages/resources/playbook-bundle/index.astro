---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageHero from '../../../components/PageHero.astro';
import FaqSection from '../../../components/FaqSection.astro';
import Footer from '../../../components/Footer.astro';

const STRIPE_URL = 'https://buy.stripe.com/4gMaEZ63T5hledgdADd7q02';

const alwaysFoundChapters = [
  { num: '01', title: 'Why Local Search Is Winner-Take-All' },
  { num: '02', title: 'Google Business Profile — Your Most Important Local Asset' },
  { num: '03', title: 'Citations — The Foundation Nobody Builds' },
  { num: '04', title: 'Location Pages — How Google Knows Where You Serve' },
  { num: '05', title: 'Reviews — The Ranking Signal You Control' },
  { num: '06', title: 'Schema Markup — Speak Google\'s Language' },
  { num: '07', title: 'Monthly Maintenance' },
  { num: '08', title: 'Tracking and Reporting' },
];

const alwaysReviewedChapters = [
  { num: '01', title: 'Why Reviews Are Your Most Powerful Local Ranking Signal' },
  { num: '02', title: 'Setting Up Your Review Infrastructure' },
  { num: '03', title: 'The Review Request System' },
  { num: '04', title: 'Review Gating — What It Is and Why It\'s Dangerous' },
  { num: '05', title: 'Responding to Reviews' },
  { num: '06', title: 'Building Review Velocity — The Monthly System' },
  { num: '07', title: 'Leveraging Reviews Beyond Google' },
  { num: '08', title: 'Monitoring, Protecting, and Recovering' },
];

const faqs = [
  { q: 'Who is the bundle for?', a: 'Law firms with 5–30 attorneys who want to build both their local search presence and their review profile in-house. If you need to rank in the Map Pack and build review velocity simultaneously, both systems need to be running. The bundle gives you both for one price.' },
  { q: 'Why buy the bundle instead of one playbook?', a: 'The two systems reinforce each other. Reviews are a local ranking signal — the Always Reviewed system feeds directly into the local SEO work in Always Found. Running them in isolation is possible, but building them together is more effective. The bundle saves $47 versus buying separately.' },
  { q: 'Can I start with just one and add the other later?', a: 'Yes — each playbook is complete on its own. But if you know you need both, the bundle is the better deal. You save $47 and both systems are available to your team from day one.' },
  { q: 'Is there a sequence — which should I start with?', a: 'Start with Always Found (local SEO) to get your GBP optimized and citations built. Then layer Always Reviewed on top to build review velocity that reinforces those rankings. If you already have a solid GBP and citation profile, you can start with either.' },
  { q: 'How do I get both playbooks after I buy?', a: 'Stripe sends you to a thank-you page that triggers an email with your access links. Both playbooks are included. The email arrives within a minute or two. If anything goes wrong, email joe@hugheyllc.com.' },
  { q: 'Do you offer refunds?', a: 'Email joe@hugheyllc.com within 14 days if the playbooks do not match what was promised here. No questions asked.' },
];

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "The Law Firm Playbook Bundle — Always Found + Always Reviewed",
  "description": "Both law firm marketing playbooks together: the complete local SEO system (Always Found) and the complete review system (Always Reviewed). 16 chapters, 13 appendices, every template you need. $147 — saves $47 vs. buying separately.",
  "brand": { "@type": "Brand", "name": "Hughey LLC" },
  "image": "https://hugheyllc.com/images/og-default.svg",
  "url": "https://hugheyllc.com/resources/playbook-bundle/",
  "offers": {
    "@type": "Offer",
    "price": "147.00",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "url": "https://hugheyllc.com/resources/playbook-bundle/"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://hugheyllc.com" },
    { "@type": "ListItem", "position": 2, "name": "Resources", "item": "https://hugheyllc.com/resources/" },
    { "@type": "ListItem", "position": 3, "name": "Playbook Bundle", "item": "https://hugheyllc.com/resources/playbook-bundle/" }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
};
---

<BaseLayout
  title="The Law Firm Playbook Bundle — Always Found + Always Reviewed ($147) | Hughey LLC"
  description="Both law firm marketing playbooks: the complete local SEO system and the complete review system. 16 chapters, 13 appendices, every template. $147 — saves $47 vs. buying separately."
  canonical="https://hugheyllc.com/resources/playbook-bundle/"
  schema={[productSchema, breadcrumbSchema, faqSchema]}
>
  <div class="pb-page">
    <PageHero
      eyebrow="Bundle · $147 · Saves $47 · Instant Download"
      heading="Both Systems.<br /><em>One Price.</em>"
      subheading="The Always Found local SEO playbook and the Always Reviewed review system playbook — together for $147. Sixteen chapters, thirteen appendices, every template you need to dominate local search and build review velocity without an agency."
      cta={{ label: "Get the Bundle — $147 →", href: STRIPE_URL }}
    />

    <!-- Above-the-fold reinforcement -->
    <section class="pb-section dark">
      <div class="w pb-fold">
        <div class="pb-fold-text rx">
          <p class="pb-pre">For firms building both systems in-house.</p>
          <h2 class="pb-h2">Local SEO and reviews aren't separate efforts — <em>they're the same system running in parallel.</em></h2>
          <p class="pb-lede">Reviews are a local ranking signal. Your GBP optimization affects how many people see your review request. Your citation profile determines which markets you rank in before a single review is ever requested. Both playbooks are designed to be run together — and the bundle makes that straightforward.</p>
          <ul class="pb-trust">
            <li><strong>$47 savings</strong> vs. buying Always Found + Always Reviewed separately ($194 total).</li>
            <li><strong>16 chapters</strong> · 13 appendices · both complete systems.</li>
            <li><strong>No subscription.</strong> Two files, yours forever.</li>
          </ul>
          <a href={STRIPE_URL} class="pb-cta">Get the Bundle — $147 →</a>
          <p class="pb-fine">Secure checkout via Stripe. Both playbooks delivered to your inbox in under a minute.</p>
        </div>

        <div class="pb-fold-card rx">
          <div class="pb-card-head">
            <span class="pb-card-tag">Bundle · Best Value</span>
            <h3>Both Playbooks.<br /><em>One Build.</em></h3>
            <p class="pb-card-sub">Always Found + Always Reviewed · 2026 Edition</p>
          </div>
          <div class="pb-card-divider"></div>
          <ul class="pb-card-list">
            <li>Always Found — Local SEO (8 chapters)</li>
            <li>Always Reviewed — Review System (8 chapters)</li>
            <li>13 appendices across both books</li>
            <li>50+ citation sources + review templates</li>
            <li>Copy-paste schema snippets</li>
            <li>Bar-compliant request scripts</li>
          </ul>
          <div class="pb-card-price">
            <span class="pb-price">$147</span>
            <span class="pb-price-sub">one-time · saves $47 · instant download</span>
          </div>
          <div class="pb-card-compare">
            <span>Always Found alone: $97</span>
            <span>Always Reviewed alone: $97</span>
            <strong>Bundle saves $47</strong>
          </div>
        </div>
      </div>
    </section>

    <!-- What's included -->
    <section class="pb-section dark alt">
      <div class="w">
        <span class="section-accent"></span>
        <p class="pb-pre">What's included</p>
        <h2 class="pb-h2">Two complete playbooks. <em>Sixteen chapters built to run together.</em></h2>

        <div class="bundle-grid">
          <!-- Always Found -->
          <div class="bundle-book rx">
            <div class="bundle-book-header">
              <span class="bundle-book-tag">Playbook 1</span>
              <h3>Always Found.<br /><em>Always Local.</em></h3>
              <p class="bundle-book-sub">The Law Firm Local SEO Playbook · 8 Chapters · 6 Appendices</p>
            </div>
            <ul class="bundle-chapter-list">
              {alwaysFoundChapters.map(c => (
                <li>
                  <span class="chapter-num-sm">{c.num}</span>
                  <span>{c.title}</span>
                </li>
              ))}
            </ul>
            <div class="bundle-book-appendices">
              <p class="appendix-label">Plus 6 appendices:</p>
              <p class="appendix-items">Citation Source List (50+) · Location Page Template · Review Request Templates · Schema Snippets · Maintenance Checklists · Glossary</p>
            </div>
          </div>

          <!-- Always Reviewed -->
          <div class="bundle-book rx">
            <div class="bundle-book-header">
              <span class="bundle-book-tag">Playbook 2</span>
              <h3>Always Reviewed.<br /><em>Always Ranked.</em></h3>
              <p class="bundle-book-sub">The Law Firm Review System Playbook · 8 Chapters · 7 Appendices</p>
            </div>
            <ul class="bundle-chapter-list">
              {alwaysReviewedChapters.map(c => (
                <li>
                  <span class="chapter-num-sm">{c.num}</span>
                  <span>{c.title}</span>
                </li>
              ))}
            </ul>
            <div class="bundle-book-appendices">
              <p class="appendix-label">Plus 7 appendices:</p>
              <p class="appendix-items">Direct Review Link Setup · Complete Request Templates · 10 Positive Response Templates · 10 Negative Response Templates · Velocity Tracking Scorecard · Platform Priority Matrix · Glossary</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Who it's for -->
    <section class="pb-section dark">
      <div class="w narrow">
        <span class="section-accent"></span>
        <p class="pb-pre">Who it's for</p>
        <h2 class="pb-h2">Built for law firm owners and marketing managers who need <em>both systems running — not just one.</em></h2>
        <div class="who-body">
          <p>If your firm is invisible in local search and also has a thin review profile, fixing one without the other leaves work on the table. A fully optimized GBP with no reviews is less convincing. A strong review count with a poorly maintained GBP misses the ranking leverage. The bundle is for firms that want to build both the right way, in the right order.</p>
          <p>The typical buyer is a law firm owner who does their own marketing, an office manager or marketing coordinator taking over from an agency, or an in-house hire who needs a clear system rather than a vague mandate. No agency experience required. No additional tools or subscriptions needed.</p>
          <p>If you only need one of the two systems, each playbook is available individually for $97. If you need both — and most growing firms do — the bundle saves $47 and gives your team a complete roadmap from day one.</p>
        </div>
      </div>
    </section>

    <!-- Buy CTA -->
    <section class="pb-section dark alt">
      <div class="w">
        <div class="buy-band rx">
          <p class="buy-pre">Both systems. One price. Yours to keep.</p>
          <h2 class="buy-h">Build the complete local presence. <em>Own the market.</em></h2>
          <p class="buy-body">$147, one-time. Both playbooks sent to your inbox the moment Stripe confirms. No subscription. No upsell. No drip sequence trying to sell you something else.</p>
          <div class="buy-compare">
            <div class="buy-compare-item">
              <span class="buy-compare-label">Always Found alone</span>
              <span class="buy-compare-price strikethrough">$97</span>
            </div>
            <div class="buy-compare-plus">+</div>
            <div class="buy-compare-item">
              <span class="buy-compare-label">Always Reviewed alone</span>
              <span class="buy-compare-price strikethrough">$97</span>
            </div>
            <div class="buy-compare-equals">=</div>
            <div class="buy-compare-item bundle-price-item">
              <span class="buy-compare-label">Bundle price</span>
              <span class="buy-compare-price bundle-highlight">$147</span>
            </div>
          </div>
          <a href={STRIPE_URL} class="buy-btn">Get the Bundle — $147 →</a>
          <p class="buy-fine">Secure checkout via Stripe · Questions? joe@hugheyllc.com</p>
          <div class="buy-individual-links">
            <p>Or buy individually: <a href="/resources/always-found-playbook/">Always Found — $97</a> · <a href="/resources/always-reviewed-playbook/">Always Reviewed — $97</a></p>
          </div>
        </div>
      </div>
    </section>

    <FaqSection items={faqs} heading="Questions About the Bundle" />
  </div>

  <Footer />

  <style>
    .pb-page { background: var(--ink); }

    .pb-section {
      padding: 88px 0;
      background: var(--ink);
      color: var(--white);
      position: relative;
      overflow: hidden;
    }

    .pb-section.alt {
      background: #0B1825;
      border-top: 1px solid rgba(200, 151, 58, 0.1);
      border-bottom: 1px solid rgba(200, 151, 58, 0.1);
    }

    .pb-section .w.narrow {
      max-width: 820px;
    }

    .pb-pre {
      font-family: var(--man);
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--glt);
      margin-bottom: 14px;
    }

    .pb-h2 {
      font-family: var(--man);
      font-size: clamp(28px, 4vw, 44px);
      font-weight: 800;
      color: var(--white);
      line-height: 1.15;
      letter-spacing: -0.02em;
      margin-bottom: 36px;
      max-width: 880px;
    }

    .pb-h2 em {
      color: var(--glt);
      font-style: italic;
      font-family: var(--bas);
      font-weight: 400;
    }

    /* ── Above-the-fold split ─────────────────────────────── */
    .pb-fold {
      display: grid;
      grid-template-columns: 1.15fr 1fr;
      gap: 64px;
      align-items: center;
    }

    .pb-fold-text .pb-h2 {
      font-size: clamp(26px, 3.2vw, 36px);
      margin-bottom: 22px;
    }

    .pb-lede {
      font-size: 16.5px;
      color: rgba(255, 255, 255, 0.75);
      line-height: 1.75;
      margin-bottom: 28px;
    }

    .pb-trust {
      list-style: none;
      padding: 0;
      margin: 0 0 32px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .pb-trust li {
      font-size: 14.5px;
      color: rgba(255, 255, 255, 0.72);
      position: relative;
      padding-left: 22px;
    }

    .pb-trust li::before {
      content: '✓';
      position: absolute;
      left: 0;
      color: var(--glt);
      font-weight: 700;
    }

    .pb-trust strong { color: var(--white); }

    .pb-cta {
      display: inline-flex;
      align-items: center;
      background: var(--glt);
      color: var(--ink);
      font-family: var(--man);
      font-weight: 800;
      font-size: 14px;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      padding: 18px 36px;
      border-radius: 2px;
      text-decoration: none;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 6px 28px rgba(200, 151, 58, 0.35);
    }

    .pb-cta:hover {
      background: #ecbf6a;
      transform: translateY(-2px);
      box-shadow: 0 10px 36px rgba(200, 151, 58, 0.45);
    }

    .pb-fine {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.4);
      margin: 14px 0 0;
    }

    /* Fold card */
    .pb-fold-card {
      background: linear-gradient(180deg, rgba(255,255,255,0.05) 0%, rgba(255,255,255,0.02) 100%);
      border: 1px solid rgba(200, 151, 58, 0.25);
      border-radius: 6px;
      padding: 40px 36px;
      box-shadow: 0 24px 64px rgba(0, 0, 0, 0.35);
    }

    .pb-card-head { text-align: center; }

    .pb-card-tag {
      display: inline-block;
      font-family: var(--man);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--glt);
      background: rgba(200, 151, 58, 0.12);
      padding: 5px 12px;
      border-radius: 20px;
      margin-bottom: 18px;
    }

    .pb-card-head h3 {
      font-family: var(--man);
      font-size: 30px;
      font-weight: 800;
      color: var(--white);
      line-height: 1.1;
      margin: 0 0 12px;
    }

    .pb-card-head h3 em {
      color: var(--glt);
      font-style: italic;
      font-family: var(--bas);
      font-weight: 400;
    }

    .pb-card-sub {
      font-size: 12.5px;
      color: rgba(255, 255, 255, 0.5);
      letter-spacing: 0.04em;
      margin: 0;
    }

    .pb-card-divider {
      height: 1px;
      background: rgba(200, 151, 58, 0.2);
      margin: 26px 0;
    }

    .pb-card-list {
      list-style: none;
      padding: 0;
      margin: 0 0 28px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .pb-card-list li {
      font-size: 14.5px;
      color: rgba(255, 255, 255, 0.78);
      position: relative;
      padding-left: 22px;
      line-height: 1.5;
    }

    .pb-card-list li::before {
      content: '→';
      position: absolute;
      left: 0;
      color: var(--glt);
      font-weight: 700;
    }

    .pb-card-price {
      text-align: center;
      padding-top: 22px;
      border-top: 1px solid rgba(200, 151, 58, 0.2);
    }

    .pb-price {
      display: block;
      font-family: var(--man);
      font-size: 48px;
      font-weight: 800;
      color: var(--glt);
      line-height: 1;
    }

    .pb-price-sub {
      display: block;
      font-size: 12px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.5);
      margin-top: 8px;
    }

    .pb-card-compare {
      display: flex;
      flex-direction: column;
      gap: 6px;
      margin-top: 18px;
      padding-top: 16px;
      border-top: 1px solid rgba(255,255,255,0.06);
      font-size: 12.5px;
      color: rgba(255, 255, 255, 0.45);
      text-align: center;
    }

    .pb-card-compare strong {
      color: var(--glt);
      font-size: 13px;
    }

    /* ── Bundle grid ──────────────────────────────────────── */
    .bundle-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }

    .bundle-book {
      background: rgba(255, 255, 255, 0.03);
      border: 1px solid rgba(200, 151, 58, 0.18);
      border-radius: 6px;
      padding: 36px 32px;
    }

    .bundle-book-header {
      margin-bottom: 28px;
    }

    .bundle-book-tag {
      display: inline-block;
      font-family: var(--man);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--glt);
      background: rgba(200, 151, 58, 0.12);
      padding: 4px 10px;
      border-radius: 20px;
      margin-bottom: 14px;
    }

    .bundle-book-header h3 {
      font-family: var(--man);
      font-size: 26px;
      font-weight: 800;
      color: var(--white);
      line-height: 1.15;
      margin: 0 0 8px;
    }

    .bundle-book-header h3 em {
      color: var(--glt);
      font-style: italic;
      font-family: var(--bas);
      font-weight: 400;
    }

    .bundle-book-sub {
      font-size: 12px;
      color: rgba(255, 255, 255, 0.45);
      letter-spacing: 0.04em;
      margin: 0;
    }

    .bundle-chapter-list {
      list-style: none;
      padding: 0;
      margin: 0 0 22px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .bundle-chapter-list li {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      font-size: 14px;
      color: rgba(255, 255, 255, 0.75);
      line-height: 1.45;
    }

    .chapter-num-sm {
      font-family: var(--man);
      font-size: 11px;
      font-weight: 700;
      color: var(--glt);
      min-width: 22px;
      letter-spacing: 0.05em;
      padding-top: 1px;
    }

    .bundle-book-appendices {
      padding-top: 18px;
      border-top: 1px solid rgba(200, 151, 58, 0.15);
    }

    .appendix-label {
      font-family: var(--man);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--glt);
      margin: 0 0 8px;
    }

    .appendix-items {
      font-size: 13px;
      color: rgba(255, 255, 255, 0.5);
      line-height: 1.6;
      margin: 0;
    }

    /* ── Who it's for ────────────────────────────────────── */
    .who-body p {
      font-size: 17px;
      color: rgba(255, 255, 255, 0.72);
      line-height: 1.8;
      margin-bottom: 22px;
    }
    .who-body p:last-child { margin-bottom: 0; }

    /* ── Buy band ────────────────────────────────────────── */
    .buy-band {
      position: relative;
      background: linear-gradient(135deg, #0B1825 0%, #112440 100%);
      border: 1px solid rgba(200, 151, 58, 0.25);
      border-radius: 8px;
      padding: 72px 56px;
      text-align: center;
      overflow: hidden;
    }

    .buy-band::before {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at 30% 30%, rgba(200, 151, 58, 0.14) 0%, transparent 55%),
                  radial-gradient(circle at 75% 70%, rgba(200, 151, 58, 0.08) 0%, transparent 60%);
      pointer-events: none;
    }

    .buy-band > * { position: relative; z-index: 1; }

    .buy-pre {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--glt);
      margin-bottom: 16px;
    }

    .buy-h {
      font-family: var(--man);
      font-size: clamp(28px, 4.5vw, 44px);
      font-weight: 800;
      color: var(--white);
      line-height: 1.15;
      letter-spacing: -0.02em;
      margin: 0 0 20px;
    }

    .buy-h em {
      color: var(--glt);
      font-style: italic;
      font-family: var(--bas);
      font-weight: 400;
    }

    .buy-body {
      font-size: 16.5px;
      color: rgba(255, 255, 255, 0.7);
      line-height: 1.7;
      max-width: 620px;
      margin: 0 auto 32px;
    }

    .buy-compare {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 16px;
      margin: 0 auto 32px;
      flex-wrap: wrap;
    }

    .buy-compare-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
    }

    .buy-compare-label {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.45);
    }

    .buy-compare-price {
      font-family: var(--man);
      font-size: 28px;
      font-weight: 800;
      color: rgba(255, 255, 255, 0.45);
    }

    .buy-compare-price.strikethrough {
      text-decoration: line-through;
      text-decoration-color: rgba(200, 151, 58, 0.5);
    }

    .buy-compare-price.bundle-highlight {
      color: var(--glt);
      font-size: 36px;
    }

    .bundle-price-item .buy-compare-label {
      color: var(--glt);
    }

    .buy-compare-plus,
    .buy-compare-equals {
      font-size: 22px;
      color: rgba(255, 255, 255, 0.3);
      font-weight: 300;
      padding-top: 16px;
    }

    .buy-btn {
      display: inline-flex;
      align-items: center;
