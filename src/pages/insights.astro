---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { getCollection } from 'astro:content';

const insights = await getCollection('insights');
---

<BaseLayout
  title="Legal Marketing Insights | Hughey LLC"
  description="Strategic insights on law firm marketing operations, data analysis, intake systems, KPIs, and choosing the right marketing partner."
  canonical="https://hugheyllc.com/insights"
>
  <div style="background: var(--ink); color: var(--white); min-height: 100vh;">
    <PageHero eyebrow="Deep Dives" heading="Marketing Intelligence<br /><em>Insights</em>" subheading="Long-form frameworks and analysis for law firm marketing operations." />

    <div style="padding: 80px 0;">
      <div class="w">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(min(520px, 100%), 1fr)); gap: 40px;">
          {insights.map((insight) => (
            <article style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(200, 151, 58, 0.15); border-radius: 4px; padding: 40px; display: flex; flex-direction: column;">
              <h2 style="font-size: 24px; font-weight: 700; color: var(--white); margin-bottom: 16px; line-height: 1.3;">
                {insight.data.title}
              </h2>
              <p style="font-size: 14px; color: rgba(255, 255, 255, 0.6); margin-bottom: 24px; flex-grow: 1; line-height: 1.6;">
                {insight.data.excerpt}
              </p>
              <a href={`/insights/${insight.data.slug}`} style="display: inline-flex; align-items: center; gap: 8px; color: var(--gold); text-decoration: none; font-weight: 600; transition: color 0.2s;">
                Read More →
              </a>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>

  <style>
    a:hover {
      color: var(--glt) !important;
    }
  </style>
</BaseLayout>
