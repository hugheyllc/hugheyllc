---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Client Request Portal | Hughey LLC"
  description="Submit a service request to Hughey LLC."
  noindex={true}
>
  <div style="background: var(--ink); color: var(--white); min-height: 100vh;">
    <!-- Auth Gate -->
    <div id="authGate" style="display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 40px 20px;">
      <div style="max-width: 400px; width: 100%; text-align: center;">
        <img src="/images/logo.png" alt="Hughey LLC" width="140" height="86" style="height:86px;width:auto;display:block;margin:0 auto 32px;" />
        <h2 style="font-size: 22px; font-weight: 700; color: var(--white); margin-bottom: 8px;">Client Portal</h2>
        <p style="color: rgba(255,255,255,0.5); font-size: 14px; margin-bottom: 28px;">Enter your access code to continue.</p>
        <form id="authForm" style="display: flex; flex-direction: column; gap: 16px;">
          <input type="password" id="authPassword" placeholder="Access code" autocomplete="off"
            style="width:100%;padding:14px 18px;background:rgba(255,255,255,0.05);border:1px solid rgba(200,151,58,0.2);border-radius:2px;color:var(--white);font-size:15px;font-family:inherit;text-align:center;letter-spacing:0.1em;" />
          <button type="submit" style="background:var(--gold);color:var(--ink);font-family:var(--man);font-weight:800;font-size:13px;letter-spacing:0.07em;text-transform:uppercase;padding:14px 28px;border:none;border-radius:2px;cursor:pointer;transition:background 0.2s;">
            Enter Portal
          </button>
          <div id="authError" style="display:none;color:#ff8080;font-size:13px;"></div>
        </form>
      </div>
    </div>

    <!-- Main Content (hidden until auth) -->
    <div id="mainContent" style="display: none;">
      <PageHero eyebrow="Client Portal" heading="Submit a <em>Request</em>" subheading="Tell us what you need. We'll create a ticket and get back to you." />

      <div style="padding: 80px 0;">
        <div class="w">
          <div class="form-container">
            <form id="requestForm" novalidate>
              <div class="field-row">
                <div class="field-group">
                  <label for="clientName">Client / Firm Name *</label>
                  <input type="text" id="clientName" name="client_name" required autocomplete="organization" />
                </div>
                <div class="field-group">
                  <label for="requestType">Request Type *</label>
                  <select id="requestType" name="request_type" required>
                    <option value="">Select type…</option>
                    <option value="Website Update">Website Update</option>
                    <option value="SEO / Content">SEO / Content</option>
                    <option value="Google Ads">Google Ads</option>
                    <option value="Social Media">Social Media</option>
                    <option value="Analytics / Reporting">Analytics / Reporting</option>
                    <option value="Intake Optimization">Intake Optimization</option>
                    <option value="Strategy Review">Strategy Review</option>
                    <option value="Design / Creative">Design / Creative</option>
                    <option value="Technical Issue">Technical Issue</option>
                    <option value="Other">Other</option>
                  </select>
                </div>
              </div>

              <div class="field-row">
                <div class="field-group">
                  <label for="email">Email *</label>
                  <input type="email" id="email" name="email" required autocomplete="email" />
                </div>
                <div class="field-group">
                  <label for="phone">Phone</label>
                  <input type="tel" id="phone" name="phone" autocomplete="tel" />
                </div>
              </div>

              <div class="field-row">
                <div class="field-group">
                  <label for="priority">Priority *</label>
                  <select id="priority" name="priority" required>
                    <option value="normal" selected>Normal</option>
                    <option value="low">Low</option>
                    <option value="high">High</option>
                    <option value="urgent">Urgent</option>
                  </select>
                </div>
                <div class="field-group">
                  <label for="dueDate">Due Date</label>
                  <input type="date" id="dueDate" name="due_date" />
                </div>
              </div>

              <div class="field-group">
                <label for="description">Description *</label>
                <textarea id="description" name="description" required rows="6" placeholder="Describe what you need in detail…"></textarea>
              </div>

              <div id="statusMessage" style="display:none;" role="alert"></div>

              <button type="submit" id="submitBtn">
                Submit Request →
              </button>
            </form>

            <!-- Success State -->
            <div id="successState" style="display:none; text-align:center; padding: 60px 20px;">
              <div style="width:64px;height:64px;border-radius:50%;background:rgba(26,158,107,0.15);display:flex;align-items:center;justify-content:center;margin:0 auto 24px;">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#1A9E6B" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </div>
              <h2 style="font-size:24px;font-weight:700;color:var(--white);margin-bottom:8px;">Request Submitted</h2>
              <p style="font-size:16px;color:rgba(255,255,255,0.6);margin-bottom:4px;">Your ticket ID is:</p>
              <p id="ticketIdDisplay" style="font-size:28px;font-weight:800;color:var(--gold);letter-spacing:0.05em;margin-bottom:24px;font-family:var(--bar);"></p>
              <p style="font-size:14px;color:rgba(255,255,255,0.45);margin-bottom:32px;">We'll review your request and get back to you shortly.</p>
              <button id="newRequestBtn" style="background:transparent;border:1px solid rgba(200,151,58,0.35);color:var(--glt);font-family:var(--man);font-weight:600;font-size:12px;letter-spacing:0.06em;text-transform:uppercase;padding:12px 24px;border-radius:2px;cursor:pointer;transition:border-color 0.2s,color 0.2s;">
                Submit Another Request
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    let portalPassword = '';

    // Auth
    const authGate = document.getElementById('authGate');
    const mainContent = document.getElementById('mainContent');
    const authForm = document.getElementById('authForm');
    const authError = document.getElementById('authError');
    const authPasswordInput = document.getElementById('authPassword') as HTMLInputElement;

    // Check stored auth
    const stored = sessionStorage.getItem('portal_auth');
    if (stored) {
      portalPassword = stored;
      authGate.style.display = 'none';
      mainContent.style.display = 'block';
    }

    authForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const pw = authPasswordInput.value.trim();
      if (!pw) return;

      // Test the password by making a GET request
      try {
        const res = await fetch('/api/client-requests', {
          headers: { 'X-Portal-Password': pw },
        });
        if (res.status === 401) {
          authError.style.display = 'block';
          authError.textContent = 'Invalid access code.';
          return;
        }
        portalPassword = pw;
        sessionStorage.setItem('portal_auth', pw);
        authGate.style.display = 'none';
        mainContent.style.display = 'block';
      } catch {
        authError.style.display = 'block';
        authError.textContent = 'Connection error. Please try again.';
      }
    });

    // Request Form
    const form = document.getElementById('requestForm') as HTMLFormElement;
    const statusEl = document.getElementById('statusMessage') as HTMLDivElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
    const successState = document.getElementById('successState');
    const ticketIdDisplay = document.getElementById('ticketIdDisplay');
    const newRequestBtn = document.getElementById('newRequestBtn');

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting…';
      statusEl.style.display = 'none';

      const data = {
        client_name: (form.querySelector('#clientName') as HTMLInputElement).value,
        email: (form.querySelector('#email') as HTMLInputElement).value,
        phone: (form.querySelector('#phone') as HTMLInputElement).value || null,
        request_type: (form.querySelector('#requestType') as HTMLSelectElement).value,
        description: (form.querySelector('#description') as HTMLTextAreaElement).value,
        priority: (form.querySelector('#priority') as HTMLSelectElement).value,
        due_date: (form.querySelector('#dueDate') as HTMLInputElement).value || null,
      };

      try {
        const res = await fetch('/api/client-requests', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Portal-Password': portalPassword,
          },
          body: JSON.stringify(data),
        });

        const result = await res.json();

        if (result.success) {
          form.style.display = 'none';
          successState.style.display = 'block';
          ticketIdDisplay.textContent = result.ticket_id;
          form.reset();
        } else {
          statusEl.style.display = 'block';
          statusEl.className = 'status-error';
          statusEl.textContent = result.error || 'Failed to submit. Please try again.';
          submitBtn.disabled = false;
          submitBtn.textContent = 'Submit Request →';
        }
      } catch {
        statusEl.style.display = 'block';
        statusEl.className = 'status-error';
        statusEl.textContent = 'Connection error. Please try again or call 727-483-3222.';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Submit Request →';
      }
    });

    newRequestBtn?.addEventListener('click', () => {
      successState.style.display = 'none';
      form.style.display = 'flex';
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit Request →';
    });
  </script>

  <style>
    em { color: var(--glt); font-style: italic; }

    .form-container {
      max-width: 720px;
      margin: 0 auto;
    }

    form {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .field-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .field-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255, 255, 255, 0.5);
    }

    input, select, textarea {
      width: 100%;
      padding: 12px 16px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(200, 151, 58, 0.2);
      border-radius: 2px;
      color: var(--white);
      font-size: 14px;
      font-family: inherit;
      transition: border-color 0.2s, background 0.2s;
      box-sizing: border-box;
    }

    input:focus, select:focus, textarea:focus {
      outline: none;
      border-color: var(--gold);
      background: rgba(255, 255, 255, 0.08);
    }

    select option { background: #09131F; }

    textarea { resize: vertical; }

    input[type="date"] {
      color-scheme: dark;
    }

    button[type="submit"] {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 9px;
      background: var(--gold);
      color: var(--ink);
      font-family: var(--man);
      font-weight: 800;
      font-size: 13px;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      padding: 16px 34px;
      border: none;
      border-radius: 2px;
      cursor: pointer;
      transition: all 0.25s;
      box-shadow: 0 4px 28px rgba(200, 151, 58, 0.42);
      align-self: flex-start;
    }

    button[type="submit"]:hover:not(:disabled) {
      background: var(--glt);
      transform: translateY(-1px);
      box-shadow: 0 6px 36px rgba(200, 151, 58, 0.52);
    }

    button[type="submit"]:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .status-error {
      padding: 14px 18px;
      background: rgba(255, 100, 100, 0.1);
      border: 1px solid rgba(255, 100, 100, 0.2);
      border-radius: 2px;
      color: #ff8080;
      font-size: 14px;
      line-height: 1.5;
    }

    @media (max-width: 640px) {
      .field-row { grid-template-columns: 1fr; }
    }
  </style>

  <Footer />
</BaseLayout>
