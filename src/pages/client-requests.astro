---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Client Request Portal — Hughey LLC"
  description="Submit a service request to Hughey LLC."
  noindex={true}
>
  <section class="cr-page">
    <div class="cr-container">
      <!-- Password Gate -->
      <div id="gate" class="cr-gate">
        <div class="cr-card">
          <h1>Client Portal</h1>
          <p class="cr-sub">Enter your access code to continue.</p>
          <form id="gate-form" class="cr-gate-form">
            <input
              type="password"
              id="gate-password"
              placeholder="Access code"
              autocomplete="off"
              required
            />
            <button type="submit" class="cr-btn">Enter</button>
          </form>
          <p id="gate-error" class="cr-error" style="display:none;">Invalid access code.</p>
        </div>
      </div>

      <!-- Request Form -->
      <div id="form-section" class="cr-form-section" style="display:none;">
        <div class="cr-card">
          <h1>New Request</h1>
          <p class="cr-sub">Tell us what you need and we'll get back to you.</p>

          <form id="request-form" class="cr-form">
            <div class="cr-field">
              <label for="client_name">Client / Firm Name <span class="req">*</span></label>
              <input type="text" id="client_name" name="client_name" required />
            </div>

            <div class="cr-row">
              <div class="cr-field">
                <label for="email">Email <span class="req">*</span></label>
                <input type="email" id="email" name="email" required />
              </div>
              <div class="cr-field">
                <label for="phone">Phone</label>
                <input type="tel" id="phone" name="phone" />
              </div>
            </div>

            <div class="cr-row">
              <div class="cr-field">
                <label for="request_type">Request Type <span class="req">*</span></label>
                <select id="request_type" name="request_type" required>
                  <option value="">Select type...</option>
                  <option value="SEO Audit">SEO Audit</option>
                  <option value="Content Strategy">Content Strategy</option>
                  <option value="Website Update">Website Update</option>
                  <option value="Analytics Review">Analytics Review</option>
                  <option value="PPC Campaign">PPC Campaign</option>
                  <option value="Intake Optimization">Intake Optimization</option>
                  <option value="Vendor Evaluation">Vendor Evaluation</option>
                  <option value="Social Media">Social Media</option>
                  <option value="General Consulting">General Consulting</option>
                  <option value="Other">Other</option>
                </select>
              </div>
              <div class="cr-field">
                <label for="priority">Priority</label>
                <select id="priority" name="priority">
                  <option value="normal" selected>Normal</option>
                  <option value="low">Low</option>
                  <option value="high">High</option>
                  <option value="urgent">Urgent</option>
                </select>
              </div>
            </div>

            <div class="cr-field">
              <label for="description">Description <span class="req">*</span></label>
              <textarea id="description" name="description" rows="5" required placeholder="Describe what you need..."></textarea>
            </div>

            <div class="cr-field">
              <label for="due_date">Preferred Due Date</label>
              <input type="date" id="due_date" name="due_date" />
            </div>

            <p id="form-error" class="cr-error" style="display:none;"></p>

            <button type="submit" id="submit-btn" class="cr-btn cr-btn-wide">
              Submit Request
            </button>
          </form>
        </div>
      </div>

      <!-- Success State -->
      <div id="success-section" class="cr-success" style="display:none;">
        <div class="cr-card cr-card-center">
          <div class="cr-check">✓</div>
          <h1>Request Submitted</h1>
          <p class="cr-sub">Your ticket ID is:</p>
          <p class="cr-ticket-id" id="ticket-id"></p>
          <p class="cr-sub">We'll review your request and follow up shortly. Save your ticket ID for reference.</p>
          <button class="cr-btn" onclick="location.reload()">Submit Another</button>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .cr-page {
    min-height: 100vh;
    background: var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
  }

  .cr-container {
    width: 100%;
    max-width: 640px;
  }

  .cr-card {
    background: var(--navy);
    border: 1px solid var(--steel);
    border-radius: 12px;
    padding: 40px;
  }

  .cr-card-center {
    text-align: center;
  }

  .cr-card h1 {
    font-family: var(--bas);
    color: var(--white);
    font-size: 1.75rem;
    margin-bottom: 8px;
  }

  .cr-sub {
    color: var(--dim);
    font-size: 0.95rem;
    margin-bottom: 24px;
  }

  .cr-gate-form {
    display: flex;
    gap: 12px;
  }

  .cr-gate-form input {
    flex: 1;
  }

  .cr-form .cr-field {
    margin-bottom: 20px;
  }

  .cr-form label {
    display: block;
    color: var(--gcm);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 6px;
  }

  .req {
    color: var(--gold);
  }

  .cr-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  input, select, textarea {
    width: 100%;
    padding: 10px 14px;
    background: var(--ink);
    border: 1px solid var(--steel);
    border-radius: 6px;
    color: var(--white);
    font-family: var(--man);
    font-size: 0.95rem;
    transition: border-color 0.2s;
  }

  input:focus, select:focus, textarea:focus {
    outline: none;
    border-color: var(--gold);
  }

  select {
    cursor: pointer;
  }

  textarea {
    resize: vertical;
    min-height: 100px;
  }

  .cr-btn {
    padding: 10px 24px;
    background: var(--gold);
    color: var(--ink);
    font-family: var(--man);
    font-weight: 700;
    font-size: 0.9rem;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.2s;
  }

  .cr-btn:hover {
    background: var(--glt);
  }

  .cr-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .cr-btn-wide {
    width: 100%;
    padding: 14px;
    font-size: 1rem;
  }

  .cr-error {
    color: #EF4444;
    font-size: 0.9rem;
    margin-top: 12px;
  }

  .cr-check {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--ok);
    color: var(--white);
    font-size: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
  }

  .cr-ticket-id {
    font-family: var(--bar);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--gold);
    margin: 8px 0 20px;
    letter-spacing: 2px;
  }

  @media (max-width: 600px) {
    .cr-card {
      padding: 28px 20px;
    }

    .cr-row {
      grid-template-columns: 1fr;
      gap: 0;
    }

    .cr-gate-form {
      flex-direction: column;
    }
  }
</style>

<script>
  let storedPassword = '';

  // Gate form
  document.getElementById('gate-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const pw = (document.getElementById('gate-password') as HTMLInputElement).value;
    storedPassword = pw;

    // Validate by making a test GET
    fetch('/api/client-requests?limit=0', {
      headers: { 'X-Portal-Password': pw },
    })
      .then((r) => {
        if (r.status === 401) {
          document.getElementById('gate-error')!.style.display = 'block';
          return;
        }
        document.getElementById('gate')!.style.display = 'none';
        document.getElementById('form-section')!.style.display = 'block';
      })
      .catch(() => {
        document.getElementById('gate-error')!.style.display = 'block';
      });
  });

  // Request form
  document.getElementById('request-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('submit-btn') as HTMLButtonElement;
    const errEl = document.getElementById('form-error')!;
    errEl.style.display = 'none';
    btn.disabled = true;
    btn.textContent = 'Submitting...';

    const formData = {
      client_name: (document.getElementById('client_name') as HTMLInputElement).value.trim(),
      email: (document.getElementById('email') as HTMLInputElement).value.trim(),
      phone: (document.getElementById('phone') as HTMLInputElement).value.trim() || null,
      request_type: (document.getElementById('request_type') as HTMLSelectElement).value,
      description: (document.getElementById('description') as HTMLTextAreaElement).value.trim(),
      priority: (document.getElementById('priority') as HTMLSelectElement).value,
      due_date: (document.getElementById('due_date') as HTMLInputElement).value || null,
    };

    try {
      const res = await fetch('/api/client-requests', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Portal-Password': storedPassword,
        },
        body: JSON.stringify(formData),
      });

      const data = await res.json();

      if (!res.ok) {
        throw new Error(data.error || 'Failed to submit request');
      }

      // Show success
      document.getElementById('form-section')!.style.display = 'none';
      document.getElementById('success-section')!.style.display = 'block';
      document.getElementById('ticket-id')!.textContent = data.ticket_id;
    } catch (err: any) {
      errEl.textContent = err.message || 'Something went wrong. Please try again.';
      errEl.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Submit Request';
    }
  });
</script>
