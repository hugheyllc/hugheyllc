---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
---

<BaseLayout
  title="Schedule a Strategy Call | Hughey LLC"
  description="Book a free 30-minute discovery call with Joe Hughey. No pitch — just an honest conversation about your law firm's marketing."
  canonical="https://hugheyllc.com/contact"
>
  <div style="background: var(--ink); color: var(--white); min-height: 100vh;">
    <PageHero eyebrow="Get In Touch" heading="Book a Free<br /><em>Discovery Call</em>" subheading="30 minutes with Joe. No pitch — just an honest conversation about what's working and what's not." />

    <!-- Scheduler + Info -->
    <div style="padding: 80px 0;">
      <div class="w">
        <div class="contact-grid">

          <!-- Calendar Embed -->
          <div class="calendar-col">
            <div style="background: rgba(255,255,255,0.03); border: 1px solid rgba(200,151,58,0.15); border-radius: 4px; overflow: hidden;">
              <iframe
                width="100%"
                height="600"
                src="https://app.onecal.io/b/joe-hughey/30-minute-discovery-call-with-joe-hughey"
                frameborder="0"
                style="display: block;"
                title="Schedule a discovery call with Joe Hughey"
              ></iframe>
            </div>
          </div>

          <!-- Info Sidebar -->
          <div class="info-col">
            <div style="background: rgba(200, 151, 58, 0.05); border: 1px solid rgba(200, 151, 58, 0.15); border-radius: 4px; padding: 40px; margin-bottom: 32px;">
              <h3 style="font-size: 18px; font-weight: 700; color: var(--gold); margin-bottom: 28px;">Contact</h3>
              
              <div style="margin-bottom: 24px;">
                <p style="font-size: 11px; color: rgba(200, 151, 58, 0.8); text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 4px;">Phone</p>
                <a href="tel:7274833222" style="font-size: 16px; color: var(--white); font-weight: 600; text-decoration: none;">727-483-3222</a>
              </div>

              <div style="margin-bottom: 24px;">
                <p style="font-size: 11px; color: rgba(200, 151, 58, 0.8); text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 4px;">Email</p>
                <a href="mailto:joe@joehughey.com" style="font-size: 15px; color: var(--white); font-weight: 600; text-decoration: none;">joe@joehughey.com</a>
              </div>

              <div>
                <p style="font-size: 11px; color: rgba(200, 151, 58, 0.8); text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 4px;">Location</p>
                <p style="font-size: 14px; color: rgba(255, 255, 255, 0.7); line-height: 1.6;">St. Petersburg, FL</p>
              </div>
            </div>

            <div style="background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(200, 151, 58, 0.15); border-radius: 4px; padding: 40px;">
              <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 16px;">What to Expect</h3>
              <div style="display: flex; flex-direction: column; gap: 16px;">
                {[
                  'A direct conversation — not a sales call',
                  'Honest assessment of your current marketing situation',
                  'Clear next steps, whether you work with us or not',
                ].map(item => (
                  <div style="display: flex; align-items: flex-start; gap: 12px;">
                    <span style="color: var(--gold); font-weight: 700; flex-shrink: 0; margin-top: 1px;">→</span>
                    <p style="font-size: 14px; color: rgba(255, 255, 255, 0.7); line-height: 1.5; margin: 0;">{item}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>

  <style>
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 380px;
      gap: 48px;
      align-items: start;
    }

    .calendar-col {
      min-width: 0;
    }

    .info-col {
      position: sticky;
      top: 120px;
    }

    a:hover {
      color: var(--gold) !important;
    }

    em {
      color: var(--glt);
      font-style: italic;
    }

    @media (max-width: 900px) {
      .contact-grid {
        grid-template-columns: 1fr;
      }

      .info-col {
        position: static;
      }
    }
  </style>
</BaseLayout>
