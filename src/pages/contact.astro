---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://hugheyllc.com" },
    { "@type": "ListItem", "position": 2, "name": "Contact", "item": "https://hugheyllc.com/contact" }
  ]
};

const contactSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Hughey LLC",
  "url": "https://hugheyllc.com/contact/",
  "description": "Schedule a free strategy call with Joe Hughey, law firm marketing consultant.",
  "mainEntity": {
    "@type": "Person",
    "name": "Joe Hughey",
    "email": "joe@joehughey.com",
    "telephone": "+17274833222",
    "url": "https://hugheyllc.com/about/"
  }
};
---

<BaseLayout
  title="Schedule a Free Strategy Call | Hughey LLC"
  description="Contact Hughey LLC to discuss your law firm's marketing. Schedule a free strategy call."
  canonical="https://hugheyllc.com/contact"
  schema={[breadcrumbSchema, contactSchema]}
>
  <div style="background: var(--ink); color: var(--white); min-height: 100vh;">
    <PageHero eyebrow="Get In Touch" heading="Schedule a Free<br /><em>Strategy Call</em>" subheading="No sales pitch — just an honest conversation about what's working and what's not at your firm." />

    <!-- Contact Section -->
    <div style="padding: 80px 0;">
      <div class="w">
        <div class="contact-grid">

          <!-- Form -->
          <div class="rx">
            <form id="contactForm" novalidate>
              <div class="field-group">
                <label for="name">Name *</label>
                <input type="text" id="name" name="name" required autocomplete="name" />
              </div>

              <div class="field-group">
                <label for="firmName">Firm Name *</label>
                <input type="text" id="firmName" name="firmName" required autocomplete="organization" />
              </div>

              <div class="field-row">
                <div class="field-group">
                  <label for="email">Email *</label>
                  <input type="email" id="email" name="email" required autocomplete="email" />
                </div>
                <div class="field-group">
                  <label for="phone">Phone *</label>
                  <input type="tel" id="phone" name="phone" required autocomplete="tel" />
                </div>
              </div>

              <div class="field-group">
                <label for="source">How did you find us? *</label>
                <select id="source" name="source" required>
                  <option value="">Select…</option>
                  <option value="Search engine">Search engine</option>
                  <option value="Referral">Referral</option>
                  <option value="Social media">Social media</option>
                  <option value="Speaking engagement">Speaking engagement</option>
                  <option value="Conference">Conference</option>
                  <option value="Other">Other</option>
                </select>
              </div>

              <div class="field-group">
                <label for="message">What's your biggest marketing challenge? *</label>
                <textarea id="message" name="message" required rows="5"></textarea>
              </div>

              <!-- Honeypot -->
              <input type="text" id="honeypot" name="honeypot" style="display:none;" tabindex="-1" autocomplete="off" />

              <!-- Status -->
              <div id="statusMessage" style="display:none;" role="alert"></div>

              <button type="submit" id="submitBtn">
                Send Message →
              </button>
            </form>
          </div>

          <!-- Sidebar -->
          <div class="contact-sidebar rxr d2">
            <div class="sidebar-block">
              <h3>Contact</h3>
              <div class="contact-detail">
                <span class="detail-label">Phone</span>
                <a href="tel:7274833222" class="detail-value">727-483-3222</a>
              </div>
              <div class="contact-detail">
                <span class="detail-label">Email</span>
                <a href="mailto:joe@joehughey.com" class="detail-value">Hughey LLC</a>
              </div>
              <div class="contact-detail">
                <span class="detail-label">Location</span>
                <span class="detail-value">St. Petersburg, FL</span>
              </div>
            </div>

            <div class="sidebar-block">
              <h3>What to Expect</h3>
              <div class="expect-list">
                <div class="expect-item">
                  <span class="arrow">→</span>
                  <p>A direct conversation, not a sales call</p>
                </div>
                <div class="expect-item">
                  <span class="arrow">→</span>
                  <p>Honest assessment of your current marketing situation</p>
                </div>
                <div class="expect-item">
                  <span class="arrow">→</span>
                  <p>Clear next steps whether you work with us or not</p>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('contactForm') as HTMLFormElement;
    const statusEl = document.getElementById('statusMessage') as HTMLDivElement;
    const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending…';
      statusEl.style.display = 'none';

      const data = {
        name: (form.querySelector('#name') as HTMLInputElement).value,
        firmName: (form.querySelector('#firmName') as HTMLInputElement).value,
        email: (form.querySelector('#email') as HTMLInputElement).value,
        phone: (form.querySelector('#phone') as HTMLInputElement).value,
        source: (form.querySelector('#source') as HTMLSelectElement).value,
        message: (form.querySelector('#message') as HTMLTextAreaElement).value,
        honeypot: (form.querySelector('#honeypot') as HTMLInputElement).value,
      };

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
        const result = await res.json();

        statusEl.style.display = 'block';
        if (result.success) {
          statusEl.className = 'status-success';
          statusEl.textContent = result.message;
          form.reset();
          submitBtn.textContent = 'Sent ✓';
        } else {
          statusEl.className = 'status-error';
          statusEl.textContent = result.error || 'An error occurred. Please try again.';
          submitBtn.disabled = false;
          submitBtn.textContent = 'Send Message →';
        }
      } catch {
        statusEl.style.display = 'block';
        statusEl.className = 'status-error';
        statusEl.textContent = 'An error occurred. Please call 727-483-3222.';
        submitBtn.disabled = false;
        submitBtn.textContent = 'Send Message →';
      }
    });
  </script>

  <style>
    em { color: var(--glt); font-style: italic; }

    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 360px;
      gap: 64px;
      align-items: start;
    }

    form {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }

    .field-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .field-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255, 255, 255, 0.5);
    }

    input, select, textarea {
      width: 100%;
      padding: 12px 16px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(200, 151, 58, 0.2);
      border-radius: 2px;
      color: var(--white);
      font-size: 14px;
      font-family: inherit;
      transition: border-color 0.2s, background 0.2s;
      box-sizing: border-box;
    }

    input:focus, select:focus, textarea:focus {
      outline: none;
      border-color: var(--gold);
      background: rgba(255, 255, 255, 0.08);
    }

    select option { background: #09131F; }

    textarea { resize: vertical; }

    button[type="submit"] {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 9px;
      background: var(--gold);
      color: var(--ink);
      font-family: var(--man);
      font-weight: 800;
      font-size: 13px;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      padding: 16px 34px;
      border: none;
      border-radius: 2px;
      cursor: pointer;
      transition: all 0.25s;
      box-shadow: 0 4px 28px rgba(200, 151, 58, 0.42);
      align-self: flex-start;
    }

    button[type="submit"]:hover:not(:disabled) {
      background: var(--glt);
      transform: translateY(-1px);
      box-shadow: 0 6px 36px rgba(200, 151, 58, 0.52);
    }

    button[type="submit"]:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }

    .status-success {
      padding: 14px 18px;
      background: rgba(200, 151, 58, 0.12);
      border: 1px solid rgba(200, 151, 58, 0.3);
      border-radius: 2px;
      color: var(--gold);
      font-size: 14px;
      line-height: 1.5;
    }

    .status-error {
      padding: 14px 18px;
      background: rgba(255, 100, 100, 0.1);
      border: 1px solid rgba(255, 100, 100, 0.2);
      border-radius: 2px;
      color: #ff8080;
      font-size: 14px;
      line-height: 1.5;
    }

    /* Sidebar */
    .contact-sidebar {
      position: sticky;
      top: 140px;
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .sidebar-block {
      background: rgba(200, 151, 58, 0.05);
      border: 1px solid rgba(200, 151, 58, 0.15);
      border-radius: 4px;
      padding: 32px;
    }

    .sidebar-block h3 {
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--gold);
      margin-bottom: 20px;
    }

    .contact-detail {
      display: flex;
      flex-direction: column;
      gap: 3px;
      margin-bottom: 16px;
    }

    .contact-detail:last-child { margin-bottom: 0; }

    .detail-label {
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: rgba(255, 255, 255, 0.35);
    }

    .detail-value {
      font-size: 15px;
      font-weight: 600;
      color: var(--white);
      text-decoration: none;
      transition: color 0.2s;
    }

    a.detail-value:hover { color: var(--gold); }

    .expect-list {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .expect-item {
      display: flex;
      align-items: flex-start;
      gap: 12px;
    }

    .arrow {
      color: var(--gold);
      font-weight: 700;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .expect-item p {
      font-size: 14px;
      color: rgba(255, 255, 255, 0.65);
      line-height: 1.5;
      margin: 0;
    }

    @media (max-width: 900px) {
      .contact-grid { grid-template-columns: 1fr; }
      .contact-sidebar { position: static; }
      .field-row { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
