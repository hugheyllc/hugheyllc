---
import Nav from '../components/Nav.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  schema?: any;
  noindex?: boolean;
  preloadImage?: string;
}

const { title, description, canonical: canonicalProp, ogImage, schema, noindex = false, preloadImage } = Astro.props;
const siteUrl = 'https://hugheyllc.com';
const defaultOgImage = `${siteUrl}/images/og-default.svg`;
// Always emit a canonical — fall back to current URL with trailing slash
const canonical = canonicalProp ?? (siteUrl + Astro.url.pathname.replace(/\/?$/, '/'));

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "@id": "https://hugheyllc.com/#business",
  "name": "Hughey LLC",
  "description": "Law firm marketing operations consulting — helping law firms build systems that generate retained clients.",
  "url": "https://hugheyllc.com",
  "telephone": "+17274833222",
  "email": "joe@hugheyllc.com",
  "founder": {
    "@type": "Person",
    "name": "Joe Hughey",
    "url": "https://hugheyllc.com/about",
    "sameAs": "https://www.linkedin.com/in/joehughey/"
  },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "5412 Dover St NE",
    "addressLocality": "St. Petersburg",
    "addressRegion": "FL",
    "postalCode": "33703",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 27.8206,
    "longitude": -82.6331
  },
  "areaServed": {
    "@type": "Country",
    "name": "United States"
  },
  "serviceArea": {
    "@type": "GeoCircle",
    "geoMidpoint": {
      "@type": "GeoCoordinates",
      "latitude": 27.8206,
      "longitude": -82.6331
    }
  },
  "knowsAbout": [
    "Law firm marketing",
    "Legal marketing strategy",
    "Marketing analytics",
    "Client intake optimization",
    "SEO for law firms",
    "Google Ads for lawyers"
  ],
  "openingHours": ["Mo-Fr 09:00-17:00"],
  "sameAs": [
    "https://www.linkedin.com/in/joehughey/",
    "https://www.facebook.com/profile.php?id=61577138003264"
  ]
};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://hugheyllc.com/#org",
  "name": "Hughey LLC",
  "url": "https://hugheyllc.com",
  "logo": {
    "@type": "ImageObject",
    "url": "https://hugheyllc.com/images/logo.png",
    "width": 512,
    "height": 512
  },
  "founder": { "@type": "Person", "name": "Joe Hughey" },
  "sameAs": [
    "https://www.linkedin.com/in/joehughey/",
    "https://www.facebook.com/profile.php?id=61577138003264",
    "https://x.com/HugheyJoe90718"
  ]
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Preconnect to Google Fonts (eliminates 300ms DNS + TCP round trip) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Self-hosted Barlow Condensed 800 (LCP font) — eliminates Google Fonts DNS round-trip -->
    <link rel="preload" href="/fonts/barlow-condensed-800.woff2" as="font" type="font/woff2" crossorigin />
    <style>
      @font-face {
        font-family: 'Barlow Condensed';
        font-style: normal;
        font-weight: 800;
        font-display: swap;
        src: url('/fonts/barlow-condensed-800.woff2') format('woff2');
      }
    </style>
    <!-- Remaining fonts non-blocking (Barlow 700, Manrope, etc.) -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Libre+Baskerville:ital@1&family=Barlow+Condensed:wght@700&family=Dancing+Script:wght@600&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@300;400;500;600;700;800&family=Libre+Baskerville:ital@1&family=Barlow+Condensed:wght@700&family=Dancing+Script:wght@600&display=swap" /></noscript>
    <meta name="generator" content={Astro.generator} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/images/logo.png" />
    <link rel="apple-touch-icon" href="/images/logo.png" />

    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1"} />
    <link rel="canonical" href={canonical} />
    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical ?? siteUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage ?? defaultOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Hughey LLC" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImage ?? defaultOgImage} />
    <meta name="twitter:site" content="@HugheyJoe90718" />
    <meta name="twitter:creator" content="@HugheyJoe90718" />

    <!-- LocalBusiness Schema (every page) -->
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <!-- Organization Schema -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    <!-- Speakable Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebPage",
      "speakable": {
        "@type": "SpeakableSpecification",
        "cssSelector": [".h-hl", ".h-sub", "h1", "h2"]
      },
      "url": canonical ?? siteUrl
    })} />

    <!-- WebSite Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Hughey LLC",
      "url": "https://hugheyllc.com",
      "potentialAction": {
        "@type": "SearchAction",
        "target": { "@type": "EntryPoint", "urlTemplate": "https://hugheyllc.com/search/?q={search_term_string}" },
        "query-input": "required name=search_term_string"
      }
    })} />

    <!-- Page-specific Schema -->
    {schema && (Array.isArray(schema) ? schema : [schema]).map((s: any) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-EGGMB2PJN2"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-EGGMB2PJN2');
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Nav />
    <main id="main-content">
      <slot />
    </main>

    <script>
      function initReveal() {
        const targets = document.querySelectorAll('.rx, .rxl, .rxr');
        if (!targets.length) return;

        targets.forEach(el => {
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight + 100) {
            el.classList.add('in');
          }
        });

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                entry.target.classList.add('in');
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.05, rootMargin: '0px 0px -20px 0px' }
        );

        targets.forEach(el => {
          if (!el.classList.contains('in')) observer.observe(el);
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initReveal);
      } else {
        initReveal();
      }

      document.addEventListener('astro:page-load', initReveal);
      document.addEventListener('astro:after-swap', initReveal);
    </script>
  </body>
</html>
