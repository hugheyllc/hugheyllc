<style>
  /* ── FOOTER ──────────────────────────────────────────────────── */
  footer {
    background: var(--ink);
    padding: 72px 0 40px;
  }

  .ft-top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 52px;
    padding-bottom: 52px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    margin-bottom: 36px;
  }

  /* Footer logo: swap .ft-logo-text block with <img> when real logo available */
  .ft-logo-wrap {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 18px;
  }

  .ft-sig {
    font-family: var(--sig);
    font-weight: 600;
    font-size: 32px;
    color: var(--white);
    letter-spacing: 0.01em;
    line-height: 1.1;
  }

  /* Real logo version: <img src="/images/Signature_800.png" class="logo-img logo-light" style="height:44px;margin-bottom:4px"> */
  .ft-llc-text {
    font-family: var(--man);
    font-weight: 600;
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.28);
    margin-top: -2px;
  }

  .ft-tagline {
    font-family: var(--bas);
    font-style: italic;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.28);
    line-height: 1.65;
    margin-bottom: 20px;
  }

  .ft-nap {
    font-size: 12px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.22);
    line-height: 1.9;
  }

  .ft-nap strong {
    color: rgba(255, 255, 255, 0.42);
    font-weight: 600;
  }

  .ft-ch {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 16px;
  }

  .ft-col ul {
    list-style: none;
  }

  .ft-col ul li {
    margin-bottom: 10px;
  }

  .ft-col ul a {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.3);
    text-decoration: none;
    transition: color 0.2s;
  }

  .ft-col ul a:hover {
    color: rgba(255, 255, 255, 0.8);
  }

  .ft-bot {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .ft-copy {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.18);
    font-weight: 500;
  }

  .ft-soc {
    display: flex;
    gap: 18px;
  }

  .ft-soc a {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.22);
    text-decoration: none;
    transition: color 0.2s;
  }

  .ft-soc a:hover {
    color: var(--gold);
  }
