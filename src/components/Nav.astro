---
---

<nav id="nav">
  <a href="/" class="logo-sig" aria-label="Hughey LLC — Home">
    <img src="/images/logo.png" alt="Hughey LLC" class="logo-img" />
  </a>

  <button class="nav-toggle" id="navToggle" aria-label="Toggle menu">
    <span></span><span></span><span></span>
  </button>

  <div class="nav-r" id="navLinks">
    <a href="/about">About</a>
    <a href="/services">Services</a>
    <a href="/insights">Insights</a>
    <a href="/blog">Blog</a>
    <a href="tel:+17274833222" class="nav-phone" aria-label="Call Hughey LLC">727-483-3222</a>
    <a href="/search/" class="nav-search" aria-label="Search">
      <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    </a>
    <a href="/contact" class="nav-btn">Schedule a Call</a>
  </div>
</nav>

<style>
  /* ── LOGO TREATMENT ──────────────────────────────────────────── */
  .logo-sig {
    display: flex;
    align-items: center;
    text-decoration: none;
    line-height: 1;
  }

  .logo-img {
    height: 64px;
    width: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .logo-img {
      height: 52px;
    }
  }

  /* ── NAV ─────────────────────────────────────────────────────── */
  nav {
    position: fixed;
    inset: 0 0 auto;
    z-index: 600;
    height: 80px;
    padding: 0 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    transition: background 0.4s, border-color 0.4s, box-shadow 0.4s;
    border-bottom: 1px solid transparent;
  }

  nav.scrolled {
    background: rgba(9, 19, 31, 0.96);
    border-color: rgba(200, 151, 58, 0.15);
    box-shadow: 0 2px 32px rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(16px);
  }

  .nav-r {
    display: flex;
    align-items: center;
    gap: 30px;
  }

  .nav-r a {
    font-size: 13px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .nav-r a:hover {
    color: rgba(255, 255, 255, 0.9);
  }

  .nav-btn {
    font-size: 12px !important;
    font-weight: 700 !important;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid var(--gold);
    color: var(--gold) !important;
    padding: 9px 22px;
    border-radius: 2px;
    transition: all 0.22s !important;
  }

  .nav-btn:hover {
    background: var(--gold) !important;
    color: var(--ink) !important;
  }

  .nav-phone {
    font-size: 12px !important;
    font-weight: 600 !important;
    color: rgba(200, 151, 58, 0.7) !important;
    letter-spacing: 0.04em;
  }

  .nav-phone:hover {
    color: var(--gold) !important;
  }

  .nav-search {
    display: flex;
    align-items: center;
    color: rgba(255, 255, 255, 0.45) !important;
    transition: color 0.2s !important;
    padding: 4px;
  }

  .nav-search:hover {
    color: var(--gold) !important;
  }

  @media (max-width: 900px) {
    .nav-phone {
      display: none;
    }
  }

  /* ── HAMBURGER ─────────────────────────────────────────────── */
  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    flex-direction: column;
    gap: 5px;
    z-index: 700;
  }

  .nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--white);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }

  .nav-toggle.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .nav-toggle.open span:nth-child(2) {
    opacity: 0;
  }

  .nav-toggle.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── MOBILE ────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    nav {
      padding: 0 20px;
    }

    .nav-toggle {
      display: flex;
    }

    .nav-r {
      position: fixed;
      inset: 0;
      background: rgba(9, 19, 31, 0.98);
      backdrop-filter: blur(20px);
      flex-direction: column;
      justify-content: center;
      gap: 32px;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s;
      z-index: 650;
    }

    .nav-r.open {
      opacity: 1;
      pointer-events: auto;
    }

    .nav-r a {
      font-size: 20px;
      color: rgba(255, 255, 255, 0.7);
    }

    .nav-btn {
      font-size: 14px !important;
      padding: 12px 28px !important;
    }
  }
</style>

<script>
  // ── NAV SCROLL DETECTION ──────────────────────────────────────
  window.addEventListener(
    'scroll',
    () => {
      document.getElementById('nav')?.classList.toggle('scrolled', window.scrollY > 40);
    },
    { passive: true }
  );

  // ── MOBILE MENU TOGGLE ────────────────────────────────────────
  document.getElementById('navToggle')?.addEventListener('click', () => {
    document.getElementById('navToggle')?.classList.toggle('open');
    document.getElementById('navLinks')?.classList.toggle('open');
  });

  // Close mobile menu when a link is clicked
  document.querySelectorAll('.nav-r a').forEach((link) => {
    link.addEventListener('click', () => {
      document.getElementById('navToggle')?.classList.remove('open');
      document.getElementById('navLinks')?.classList.remove('open');
    });
  });
</script>
