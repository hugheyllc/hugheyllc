---
import { getCollection } from 'astro:content';

const insights = await getCollection('insights');
const featuredInsights = insights.slice(0, 3);
---

<section class="insights rx">
  <div class="w">
    <div class="insights-header">
      <span class="insights-eyebrow">Strategic Guides</span>
      <h2 class="insights-title">Learn From Our Experience</h2>
      <a href="/insights" class="insights-cta">View All Insights →</a>
    </div>

    <div class="insights-grid">
      {featuredInsights.map((insight, i) => (
        <a href={`/insights/${insight.data.slug}`} class={`insight-card rx${i === 0 ? 'l' : i === 1 ? '' : 'r'} d${i + 1}`}>
          <h3>{insight.data.title}</h3>
          <p>{insight.data.excerpt}</p>
          <div class="insight-arrow">Read →</div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .insights {
    padding: 100px 0;
    background: linear-gradient(180deg, #FFFFFF 0%, #FAFAF5 100%);
  }

  .insights-header {
    text-align: center;
    margin-bottom: 80px;
  }

  .insights-eyebrow {
    display: block;
    font-family: var(--man);
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(17, 24, 39, 0.5);
    margin-bottom: 16px;
  }

  .insights-title {
    font-family: var(--man);
    font-weight: 800;
    font-size: clamp(32px, 6vw, 56px);
    color: var(--ink);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin-bottom: 24px;
  }

  .insights-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--man);
    font-weight: 700;
    font-size: 14px;
    color: var(--gold);
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: all 0.3s ease;
  }

  .insights-cta:hover {
    gap: 12px;
    color: var(--glt);
  }

  .insights-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 32px;
  }

  .insight-card {
    padding: 40px;
    background: var(--white);
    border: 1px solid rgba(200, 151, 58, 0.1);
    border-radius: 4px;
    text-decoration: none;
    color: inherit;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .insight-card:hover {
    border-color: var(--gold);
    box-shadow: 0 12px 48px rgba(200, 151, 58, 0.1);
    transform: translateY(-4px);
  }

  .insight-card h3 {
    font-family: var(--man);
    font-weight: 700;
    font-size: 20px;
    color: var(--ink);
    margin-bottom: 16px;
    line-height: 1.3;
    letter-spacing: -0.02em;
  }

  .insight-card p {
    font-size: 15px;
    color: var(--sub);
    line-height: 1.6;
    flex-grow: 1;
    margin-bottom: 20px;
  }

  .insight-arrow {
    font-family: var(--man);
    font-weight: 700;
    font-size: 14px;
    color: var(--gold);
    transition: transform 0.3s ease;
  }

  .insight-card:hover .insight-arrow {
    transform: translateX(4px);
  }
</style>
