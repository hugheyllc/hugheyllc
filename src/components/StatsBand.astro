---
---

<section class="stats-band rx">
  <div class="w">
    <div class="stats-grid">
      <div class="stat-box rxl d1">
        <div class="stat-value">-32%</div>
        <div class="stat-label">Reduction in wasted marketing spend</div>
        <div class="stat-detail">Average across clients after unified KPI system</div>
      </div>

      <div class="stat-box rxl d2">
        <div class="stat-value">+24%</div>
        <div class="stat-label">Increase in form-to-consultation rate</div>
        <div class="stat-detail">Through intake process optimization</div>
      </div>

      <div class="stat-box rxr d1">
        <div class="stat-value">4.2x</div>
        <div class="stat-label">Average ROI improvement after intake optimization</div>
        <div class="stat-detail">Measured against pre-engagement baseline</div>
      </div>
    </div>
  </div>
</section>

<style>
  .stats-band {
    padding: 80px 0;
    background: var(--ink);
    color: var(--white);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 40px;
  }

  .stat-box {
    padding: 0;
    text-align: center;
  }

  .stat-value {
    font-family: var(--bar);
    font-weight: 800;
    font-size: clamp(40px, 8vw, 72px);
    color: var(--gold);
    line-height: 1;
    margin-bottom: 12px;
    letter-spacing: -0.04em;
  }

  .stat-label {
    font-family: var(--man);
    font-weight: 700;
    font-size: 16px;
    color: var(--white);
    margin-bottom: 8px;
    line-height: 1.4;
  }

  .stat-detail {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.6);
  }
</style>
